        public static (String, String) Init(String Ticket)
        {
            String user;
            List<String> Role = [];
            String Company;
            String Departement;
            String Email;
            String FullName;
            List<String> Activities = [];

            Byte[] SessionBytes = Convert.FromBase64String(Ticket);
            String DecodedUser = Encoding.UTF8.GetString(SessionBytes);
            user = DecodedUser.Split('|')[0];
            GetUserCollection getUserCollection = new(user, "", user);

            String User = GeneralCall(getUserCollection, $"{Ldap}/api/ActiveDirectoryHost/GetUserCollection");
            JToken GetUserInfo = JObject.Parse(User)["UserInfo"]!;
            Email = GetUserInfo["Email"]!.ToString();
            Departement = GetUserInfo["Department"]!.ToString();
            FullName = GetUserInfo["FullName"]!.ToString();
            GetUserByEmail getUserByEmail = new(user, "", Email);
            String Branches = GeneralCall(getUserByEmail, $"{Bref}/api/Authorization/GetUserBranchesByEmail");
            JToken BranchesData = JObject.Parse(Branches)["Branches"]!;
            StringBuilder branchesString = new();
            foreach (JToken Data in BranchesData)
            {
                if (Data["AccessAllowedInT24"]!.ToString().ToLower() == "true" ||
                    Data["AccessAllowedInModule"]!.ToString().ToLower() == "true")
                {
                    branchesString.Append(Data["BranchCode"] + ",");
                }
            }

            if (branchesString.Length != 0)
            {
                branchesString.Remove(branchesString.Length - 1, 1);
            }

            Company = branchesString.ToString();

            GetRoleWithActivities getRoleWithActivities = new(user, Company);
            String RoleByUserName = GeneralCall(getRoleWithActivities, $"{OSB}/Rest/Authorization/RoleByUserName");
            JToken RoleByUserNameObject = JObject.Parse(RoleByUserName)["userRoles"]!;
            RoleByUserNameObject = RoleByUserNameObject["userRole"]!;

            foreach (JToken Data in RoleByUserNameObject)
            {
                if (!Role.Contains(Data["roleCode"]!.ToString()))
                {
                    Role.Add(Data["roleCode"]!.ToString());
                }
            }

            String RoleWithActivitiesByModuleName = GeneralCall(getRoleWithActivities,
                $"{OSB}/Rest/Authorization/RoleWithActivitiesByModuleName");
            JToken RoleWithActivitiesByModuleNameObject =
                JObject.Parse(RoleWithActivitiesByModuleName)["roleActivities"]!;
            RoleWithActivitiesByModuleNameObject = RoleWithActivitiesByModuleNameObject["roleActivity"]!;

            foreach (JToken Data in RoleWithActivitiesByModuleNameObject)
            {
                if (Role.Contains(Data["roleCode"]!.ToString()))
                {
                    Activities.Add(Data["actionName"]!.ToString());
                }
            }

            Dictionary<String, Object> dict = new()
            {
                ["Ticket"] = Ticket,
                ["user"] = user,
                ["Role"] = Role,
                ["Activities"] = Activities,
                ["Company"] = Company,
                ["Departement"] = Departement,
