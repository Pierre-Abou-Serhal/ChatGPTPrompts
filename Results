CREATE PROCEDURE [dbo].[usp_Edit_CustomerRequestDepartmentAccess] 
	@P__Id INT,
	@P__DepartmentCode NVARCHAR(20),
	@P__HasFullAccess BIT,
	@P__IsActive BIT,
	@P__User NVARCHAR(255),
	@P__CustomerRequestDepartmentDeliveryMethodAccess TVP_CustomerRequestDepartmentDeliveryMethodAccess READONLY
AS
BEGIN
	SET NOCOUNT ON;

    DECLARE @CurrentDate DATETIME = GETDATE();

	IF(@P__Id = -1)
	BEGIN
	    INSERT INTO [dbo].[t_CustomerRequestDepartmentAccess]
               ([DepartmentCode]
               ,[HasFullAccess]
               ,[IsActive]
               ,[CreatedDate]
               ,[CreatedBy]
               ,[LastModifiedDate]
               ,[LastModifiedBy])
         VALUES
               (@P__DepartmentCode
               ,@P__HasFullAccess
               ,@P__IsActive
               ,@CurrentDate
               ,@P__User
               ,@CurrentDate
               ,@P__User)

        SET @P__Id = SCOPE_IDENTITY();

        INSERT INTO [dbo].[t_CustomerRequestDepartmentDeliveryMethodAccess]
           ([CustomerRequestDepartmentAccessId]
           ,[DeliveryMethodCode]
           ,[IsActive]
           ,[CreatedDate]
           ,[CreatedBy]
           ,[LastModifiedDate]
           ,[LastModifiedBy])
        SELECT
            @P__Id,
            DeliveryMethodCode,
            IsActive,
            @CurrentDate,
            @P__User,
            @CurrentDate,
            @P__User
        FROM @P__CustomerRequestDepartmentDeliveryMethodAccess
	END
    ELSE
    BEGIN
        UPDATE t_CustomerRequestDepartmentAccess
        SET
            [DepartmentCode] = @P__DepartmentCode,
            [HasFullAccess] = @P__HasFullAccess,
            [IsActive] = @P__IsActive,
            [LastModifiedDate] = @CurrentDate,
            [LastModifiedBy] = @P__User
        WHERE Id = @P__Id

        MERGE [dbo].[t_CustomerRequestDepartmentDeliveryMethodAccess] AS Target
        USING @P__CustomerRequestDepartmentDeliveryMethodAccess AS Source ON (Target.Id = Source.Id AND Target.[CustomerRequestDepartmentAccessId] = @P__Id)
        WHEN MATCHED THEN
            UPDATE SET
                Target.[DeliveryMethodCode] = Source.[DeliveryMethodCode],
                Target.[IsActive] = Source.[IsActive],
                Target.[LastModifiedDate] = @CurrentDate,
                Target.[LastModifiedBy] = @P__User
        WHEN NOT MATCHED BY TARGET THEN
            INSERT
               ([CustomerRequestDepartmentAccessId]
               ,[DeliveryMethodCode]
               ,[IsActive]
               ,[CreatedDate]
               ,[CreatedBy]
               ,[LastModifiedDate]
               ,[LastModifiedBy])
            VALUES
                (@P__Id,
                Source.[DeliveryMethodCode],
                Source.[IsActive],
                @CurrentDate,
                @P__User,
                @CurrentDate,
                @P__User)
        WHEN NOT MATCHED BY SOURCE AND Target.[CustomerRequestDepartmentAccessId] = @P__Id THEN
            DELETE;
    END
END
