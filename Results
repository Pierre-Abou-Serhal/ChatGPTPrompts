name: DTE_DB_SIT_$(Date:yyyyMMdd).$(Rev:r)

resources:
  repositories:
  - repository: templates
    type: git
    name: 'Azure Templates/Azure Templates'
    ref: refs/heads/main

trigger:
  branches:
    include:
    - sit
  paths:
    include:
    - DatabaseProjectAlterna_DataExport/**

pr: none

variables:
- group: SIT_VARIABLE_GROUP

stages:
- stage: Build_DB
  displayName: 'Build DB'
  jobs:
  - template: pipelines/build-database-project.yml@templates
    parameters:
      jobName: 'BuildDb'
      jobDisplayName: 'Build database project'
      buildPool: 'Build Pool'
      buildAgentName: 'UAT-ALTERNA-DK1'
      sqlProjectPath: 'DatabaseProjectAlterna_DataExport/DatabaseProjectAlterna_DataExport.sqlproj'
      artifactName: 'card-managemenmt-db-drop'
      previewConnectionString: '$(CONN_STRING)'
