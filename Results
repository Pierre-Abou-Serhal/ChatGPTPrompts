        public static (Boolean, Dictionary<String, Object>) GenerateVariablesLkp(HttpContext Context, String Session)
        {
            Dictionary<String, Object> RetDict = [];
            bool Expired = false;

            Session = DecompressString(Session);
            Session = DecryptString(Session);

            String[] Items = Session.Split(new String[] { "ᓚᘏᗢ" }, StringSplitOptions.RemoveEmptyEntries);

            foreach (String Item in Items)
            {
                String[] Data = Item.Split(new String[] { "[==]" }, StringSplitOptions.RemoveEmptyEntries);
                RetDict[Data[0]] = JsonConvert.DeserializeObject(Data[1])!;
            }

            Int64 exp = -1;
            if (RetDict.TryGetValue("Exp", out var value))
            {
                exp = (Int64)value;
            }

            if (exp < DateTimeOffset.UtcNow.ToUnixTimeSeconds())
            {
                Expired = true;
            }

            RetDict["Exp"] = DateTimeOffset.UtcNow.ToUnixTimeSeconds() + (TTL * 60);
            String FN = "Invalid User";
            if (RetDict.TryGetValue("FullName", out var value2))
            {
                FN = value2.ToString() ?? "Invalid User";
            }

            if (!Expired)
            {
                Context.Response.Cookies.Append("ArchiveData", GenerateSetionVariable(RetDict));
                Context.Session.SetString("ArchiveData", GenerateSetionVariable(RetDict));
                Context.Session.SetString("User", FN);
                Context.Response.Headers["Origin"] = Context.Request.Headers.Origin;
            }

            return (Expired, RetDict);
        }

        public static String generatePublicKey(String CorrelationID, String Username)
        {
            String RetRes = String.Empty;
            RetRes = CorrelationID + "|" + Username + "|ProfessionalStackOverFlowSearcher";
            Byte[] bytes;

            using (SHA256 sha256 = SHA256.Create())
            {
                bytes = sha256.ComputeHash(Encoding.UTF8.GetBytes(RetRes));

                StringBuilder sb = new();
                foreach (Byte b in bytes)
                {
                    sb.Append(b.ToString("x2"));
                }

                RetRes = sb.ToString();
            }

            return RetRes;
        }

        public static Boolean HasUserRole(String Role, HttpContext httpContext)
        {

            String cookieContent = String.Empty;
            if (httpContext.Session.GetString("ArchiveData") != null)
            {
                cookieContent = httpContext.Session.GetString("ArchiveData") ?? string.Empty;
            }
            else
            {
                if (httpContext.Request.Cookies.Count == 0)
                {
                    if (httpContext.Response.Headers.TryGetValue("Set-Cookie", out var Data))
                    {
                        foreach (string? cookie in Data)
                        {
                            if (cookie != null && cookie.Contains("ArchiveData"))
                            {
                                cookieContent = cookie.Substring(cookie.IndexOf("=") + 1, cookie.IndexOf(";") - 12);
                            }
                        }

                        if (String.IsNullOrEmpty(cookieContent))
                        {

                            return false;
                        }

                        cookieContent = HttpUtility.UrlDecode(cookieContent);
                    }
                    else
                    {

                        return false;
                    }
                }
            }


            Dictionary<String, Object> dict = [];
            Boolean Expired = true;
            (Expired, dict) = GenerateVariablesLkp(httpContext,
                httpContext.Request.Cookies["ArchiveData"] ?? cookieContent);
            if (Expired)
            {
                return false;
            }

            List<String>? Roles = [];
            Roles = JsonConvert.DeserializeObject<List<String>>(dict["Role"].ToString()!);
            try
            {
                if (Roles!.Contains(Role))
                {
                    return true;
                }
            }
            catch
            {
                return false;
            }

            return false;
        }

        public static DateTime FormatDate(String dateString)
        {
            String[] parts = dateString.Replace(",", String.Empty).Split(' ');

            Int32 day = Int32.Parse(parts[0]);
            Int32 month = GetMonthIndex(parts[1]);
            Int32 year = Int32.Parse(parts[2]);

            return new DateTime(year, month, day);
        }

