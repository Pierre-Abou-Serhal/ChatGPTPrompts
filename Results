- stage: Deploy_Applications_SIT
  displayName: 'Deploy applications to SIT'
  dependsOn:
  - Resolve_Selected_Builds
  - Approval_SIT_Release
  condition: and(succeeded(), or(${{ eq(parameters.deployBackend, true) }}, ${{ eq(parameters.deployFrontend, true) }}))
  variables:
    BackendPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.BackendPipelineDefinitionId'] ]
    BackendBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.BackendBuildId'] ]
    FrontendPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.FrontendPipelineDefinitionId'] ]
    FrontendBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.FrontendBuildId'] ]
  jobs:
  - ${{ if eq(parameters.deployBackend, true) }}:
    - template: pipelines/deploy-iis.yml@templates
      parameters:
        jobDependsOn: []
        jobCondition: succeeded()
        deploymentName: 'DeployBackend'
        deploymentDisplayName: 'Deploy Backend to SIT (IIS)'
        environmentName: 'SIT'
        deployPool: 'Deployment Pool'
        deployAgentName: 'SIT-ALTERNA-BN1'
        variableGroup: 'SIT_BACK_END_VARIABLE_GROUP'
        componentName: 'BACKEND'
        artifactName: 'alterna-telecom-api-drop'
        artifactBuildType: 'specific'
        artifactProject: '$(System.TeamProject)'
        artifactDefinitionId: '$(BackendPipelineDefinitionId)'
        artifactBuildId: '$(BackendBuildId)'
        artifactBranch: 'refs/heads/sit'
        zipName: 'Alterna-Telecom-Backend.zip'
        siteName: 'Alterna.TelecomAzureDevOps'
        appPoolName: 'Alterna.TelecomAzureDevOps'
        iisTargetPath: 'C:\inetpub\wwwroot\Alterna.TelecomAzureDevOps'
        cleanTargetBeforeCopy: true
        cleanExcludeCsv: ''
        enableJsonTransform: true
        jsonFiles: '**/appsettings.json'
        enableXmlConfigTransform: false
        xmlConfigFiles: []
        xmlVariableValues: {}
        enableCustomXmlEdits: false
        customXmlEdits: []
        customXmlVariableValues: {}
        enableHealthCheck: true
        healthCheckUrl: 'http://10.0.40.41:8046/api/Host/GetIndividualCustomerRange?fromCustomerId=1&toCustomerId=1'
        healthCheckExpectedStatusCode: '200'
        healthCheckRetries: 6
        healthCheckDelaySeconds: 10
        enableRollbackOnHealthCheckFailure: true
        enableLocalBackup: true
        backupRoot: 'C:\DeployBackups'
        backupPath: 'C:\DeployBackups\SIT\AlternaTelecom\BACKEND\$(Build.BuildId)'

  - ${{ if eq(parameters.deployFrontend, true) }}:
    - template: pipelines/deploy-iis.yml@templates
      parameters:
        ${{ if eq(parameters.deployBackend, true) }}:
          jobDependsOn:
          - DeployBackend
        ${{ if eq(parameters.deployBackend, false) }}:
          jobDependsOn: []
        jobCondition: succeeded()
        deploymentName: 'DeployFrontend'
        deploymentDisplayName: 'Deploy Frontend to SIT (IIS)'
        environmentName: 'SIT'
        deployPool: 'Deployment Pool'
        deployAgentName: 'SIT-ALTERNA-FN1'
        variableGroup: 'SIT_FRONT_END_VARIABLE_GROUP'
        componentName: 'FRONTEND'
        artifactName: 'alterna-telecom-front-drop'
        artifactBuildType: 'specific'
        artifactProject: '$(System.TeamProject)'
        artifactDefinitionId: '$(FrontendPipelineDefinitionId)'
        artifactBuildId: '$(FrontendBuildId)'
        artifactBranch: 'refs/heads/sit'
        zipName: 'Alterna-Telecom-Frontend.zip'
        siteName: 'AlternaTelecomAzureDevOps'
        appPoolName: 'AlternaTelecomAzureDevOps'
        iisTargetPath: 'C:\inetpub\wwwroot\AlternaTelecomAzureDevOps'
        cleanTargetBeforeCopy: true
        cleanExcludeCsv: ''
        enableJsonTransform: true
        jsonFiles: '**/appsettings.json'
        enableXmlConfigTransform: false
        xmlConfigFiles: []
        xmlVariableValues: {}
        enableCustomXmlEdits: false
        customXmlEdits: []
        customXmlVariableValues: {}
        enableHealthCheck: true
        healthCheckUrl: 'http://10.0.40.41:8046/api/Host/GetIndividualCustomerRange?fromCustomerId=1&toCustomerId=1'
        healthCheckExpectedStatusCode: '200'
        healthCheckRetries: 6
        healthCheckDelaySeconds: 10
        enableRollbackOnHealthCheckFailure: true
        enableLocalBackup: true
        backupRoot: 'C:\DeployBackups'
        backupPath: 'C:\DeployBackups\SIT\AlternaTelecom\FRONTEND\$(Build.BuildId)'

- stage: Rollback_Backend_After_Frontend_Failure_SIT
  displayName: 'Rollback Backend because Frontend failed'
  dependsOn:
  - Deploy_Applications_SIT
  condition: and(always(), eq('${{ parameters.deployBackend }}', 'true'), eq('${{ parameters.deployFrontend }}', 'true'), eq(dependencies.Deploy_Applications_SIT.outputs['DeployBackend.DeployBackend.publishSuccessOutcome.DeploymentHealthy'], 'true'), ne(dependencies.Deploy_Applications_SIT.outputs['DeployFrontend.DeployFrontend.publishSuccessOutcome.DeploymentHealthy'], 'true'))
  jobs:
  - template: pipelines/rollback-iis.yml@templates
    parameters:
      deploymentName: 'RollbackBackendAfterFrontendFailure'
      deploymentDisplayName: 'Rollback Backend from local backup because Frontend failed'
      environmentName: 'SIT'
      deployPool: 'Deployment Pool'
      deployAgentName: 'SIT-ALTERNA-BN1'
      siteName: 'Alterna.TelecomAzureDevOps'
      appPoolName: 'Alterna.TelecomAzureDevOps'
      iisTargetPath: 'C:\inetpub\wwwroot\Alterna.TelecomAzureDevOps'
      backupPath: 'C:\DeployBackups\SIT\AlternaTelecom\BACKEND\$(Build.BuildId)'
      cleanExcludeCsv: ''

- stage: Tag_APP_LKG_SIT
  displayName: 'Tag successful application builds as LKG'
  dependsOn:
  - Resolve_Selected_Builds
  - Deploy_Applications_SIT
  condition: and(succeeded('Deploy_Applications_SIT'), or(${{ eq(parameters.deployBackend, true) }}, ${{ eq(parameters.deployFrontend, true) }}))
  variables:
    BackendBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.BackendBuildId'] ]
    BackendPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.BackendPipelineDefinitionId'] ]
    FrontendBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.FrontendBuildId'] ]
    FrontendPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.FrontendPipelineDefinitionId'] ]
  jobs:
  - job: TagApplicationBuilds
    displayName: 'Tag Frontend / Backend builds'
    pool:
      name: 'Deployment Pool'
      demands:
      - Agent.Name -equals SIT-ALTERNA-BN1
    steps:
    - checkout: none

    - ${{ if eq(parameters.deployBackend, true) }}:
      - template: pipelines/tag-builds.yml@templates
        parameters:
          tagTargets:
          - name: 'Alterna Telecom Backend'
            buildId: '$(BackendBuildId)'
            definitionId: '$(BackendPipelineDefinitionId)'
            deployedTag: 'DEPLOYED-SIT-ATC-BACKEND'
            lkgTag: 'LKG-SIT-ATC-BACKEND'
            makeLkgUnique: true

    - ${{ if eq(parameters.deployFrontend, true) }}:
      - template: pipelines/tag-builds.yml@templates
        parameters:
          tagTargets:
          - name: 'Alterna Telecom Frontend'
            buildId: '$(FrontendBuildId)'
            definitionId: '$(FrontendPipelineDefinitionId)'
            deployedTag: 'DEPLOYED-SIT-ATC-FRONTEND'
            lkgTag: 'LKG-SIT-ATC-FRONTEND'
            makeLkgUnique: true

- stage: Deploy_DB_After_Apps_SIT
  displayName: 'Deploy DB to SIT after applications'
  dependsOn:
  - Resolve_Selected_Builds
  - Tag_APP_LKG_SIT
  condition: and(succeeded('Tag_APP_LKG_SIT'), ${{ eq(parameters.deployDatabase, true) }}, or(${{ eq(parameters.deployBackend, true) }}, ${{ eq(parameters.deployFrontend, true) }}))
  variables:
    DbPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbPipelineDefinitionId'] ]
    DbBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbBuildId'] ]
  jobs:
  - template: pipelines/deploy-database.yml@templates
    parameters:
      deploymentName: 'DeployDb'
      deploymentDisplayName: 'Deploy Alterna Telecom database'
      environmentName: 'SIT'
      deployPool: 'Deployment Pool'
      deployAgentName: 'SIT-ALTERNA-BN1'
      artifactName: 'alterna-telecom-db-drop'
      artifactBuildType: 'specific'
      artifactProject: '$(System.TeamProject)'
      artifactDefinitionId: '$(DbPipelineDefinitionId)'
      artifactBuildId: '$(DbBuildId)'
      artifactBranch: 'refs/heads/sit'
      targetConnectionString: '$(GlobalSettings.ConnString)'

- stage: Deploy_DB_Only_SIT
  displayName: 'Deploy DB to SIT'
  dependsOn:
  - Resolve_Selected_Builds
  - Approval_SIT_Release
  condition: and(succeeded(), ${{ eq(parameters.deployDatabase, true) }}, ${{ eq(parameters.deployBackend, false) }}, ${{ eq(parameters.deployFrontend, false) }})
  variables:
    DbPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbPipelineDefinitionId'] ]
    DbBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbBuildId'] ]
  jobs:
  - template: pipelines/deploy-database.yml@templates
    parameters:
      deploymentName: 'DeployDb'
      deploymentDisplayName: 'Deploy Alterna Telecom database'
      environmentName: 'SIT'
      deployPool: 'Deployment Pool'
      deployAgentName: 'SIT-ALTERNA-BN1'
      artifactName: 'alterna-telecom-db-drop'
      artifactBuildType: 'specific'
      artifactProject: '$(System.TeamProject)'
      artifactDefinitionId: '$(DbPipelineDefinitionId)'
      artifactBuildId: '$(DbBuildId)'
      artifactBranch: 'refs/heads/sit'
      targetConnectionString: '$(GlobalSettings.ConnString)'

- stage: Tag_DB_DEPLOYED_SIT
  displayName: 'Tag deployed database build'
  dependsOn:
  - Resolve_Selected_Builds
  - Deploy_DB_After_Apps_SIT
  - Deploy_DB_Only_SIT
  condition: and(eq('${{ parameters.deployDatabase }}', 'true'), or(eq(dependencies.Deploy_DB_After_Apps_SIT.result, 'Succeeded'), eq(dependencies.Deploy_DB_Only_SIT.result, 'Succeeded')))
  variables:
    DbBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbBuildId'] ]
    DbPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbPipelineDefinitionId'] ]
  jobs:
  - job: TagDatabaseBuild
    displayName: 'Tag DB build'
    pool:
      name: 'Deployment Pool'
      demands:
      - Agent.Name -equals SIT-ALTERNA-BN1
    steps:
    - checkout: none

    - template: pipelines/tag-builds.yml@templates
      parameters:
        tagTargets:
        - name: 'Alterna Telecom DB'
          buildId: '$(DbBuildId)'
          definitionId: '$(DbPipelineDefinitionId)'
          deployedTag: 'DEPLOYED-SIT-ATC-DB'
          lkgTag: 'LKG-SIT-ATC-DB'
          makeLkgUnique: true
