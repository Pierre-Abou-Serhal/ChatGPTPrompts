trigger:
  branches:
    include:
      - SIT
      - UAT
      - master

stages:
- stage: Build
  displayName: Build MVC + API
  jobs:
  # MVC
  - template: pipelines/templates/build-dotnetframework-webapi.yml
    parameters:
      jobName: Build_MVC
      jobDisplayName: 'Build MVC'
      buildPool: 'MySelfHostedPool'
      buildAgentName: 'WIN-SERVER-01'
      solution: 'MySolution.sln'
      runTests: false
      zipName: 'MVC.zip'
      packageLocation: '$(Build.ArtifactStagingDirectory)\package-mvc'

  # API
  - template: pipelines/templates/build-dotnetframework-webapi.yml
    parameters:
      jobName: Build_API
      jobDisplayName: 'Build Web API'
      buildPool: 'MySelfHostedPool'
      buildAgentName: 'WIN-SERVER-01'
      solution: 'MySolution.sln'
      runTests: true
      zipName: 'API.zip'
      packageLocation: '$(Build.ArtifactStagingDirectory)\package-api'
