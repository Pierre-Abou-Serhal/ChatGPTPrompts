parameters:
- name: tagTargets
  type: object
  default: []

- name: apiVersion
  type: string
  default: '7.1'

steps:
- powershell: |
    $ErrorActionPreference = 'Stop'

    $collectionUri = "$(System.CollectionUri)".TrimEnd('/')
    $projectName   = [System.Uri]::EscapeDataString("$(System.TeamProject)")
    $apiVersion    = '${{ parameters.apiVersion }}'

    $headers = @{
      Authorization = "Bearer $env:SYSTEM_ACCESSTOKEN"
    }

    $targetsJson = @'
    ${{ convertToJson(parameters.tagTargets) }}
    '@

    $targets = $targetsJson | ConvertFrom-Json

    if (-not $targets) {
      throw 'No tagTargets were provided to the tagging template.'
    }

    function Add-BuildTag {
      param(
        [string]$BuildId,
        [string]$Tag
      )

      if ([string]::IsNullOrWhiteSpace($BuildId) -or [string]::IsNullOrWhiteSpace($Tag)) {
        return
      }

      $tagEscaped = [System.Uri]::EscapeDataString($Tag)
      $uri = "{0}/{1}/_apis/build/builds/{2}/tags/{3}?api-version={4}" -f `
        $collectionUri,
        $projectName,
        $BuildId,
        $tagEscaped,
        $apiVersion

      Write-Host "Adding tag [$Tag] to build [$BuildId]"
      Invoke-RestMethod -Method Put -Uri $uri -Headers $headers | Out-Null
    }

    function Remove-BuildTag {
      param(
        [string]$BuildId,
        [string]$Tag
      )

      if ([string]::IsNullOrWhiteSpace($BuildId) -or [string]::IsNullOrWhiteSpace($Tag)) {
        return
      }

      $tagEscaped = [System.Uri]::EscapeDataString($Tag)
      $uri = "{0}/{1}/_apis/build/builds/{2}/tags/{3}?api-version={4}" -f `
        $collectionUri,
        $projectName,
        $BuildId,
        $tagEscaped,
        $apiVersion

      Write-Host "Removing tag [$Tag] from build [$BuildId]"
      Invoke-RestMethod -Method Delete -Uri $uri -Headers $headers | Out-Null
    }

    function Remove-OldLkgTags {
      param(
        [string]$CurrentBuildId,
        [string]$DefinitionId,
        [string]$LkgTag
      )

      if ([string]::IsNullOrWhiteSpace($CurrentBuildId) -or [string]::IsNullOrWhiteSpace($DefinitionId) -or [string]::IsNullOrWhiteSpace($LkgTag)) {
        return
      }

      $listUri = "{0}/{1}/_apis/build/builds?definitions={2}&tagFilters={3}&statusFilter=completed&queryOrder=finishTimeDescending&api-version={4}" -f `
        $collectionUri,
        $projectName,
        $DefinitionId,
        [System.Uri]::EscapeDataString($LkgTag),
        $apiVersion

      Write-Host "Looking for existing builds tagged [$LkgTag] in definition [$DefinitionId]"
      $response = Invoke-RestMethod -Method Get -Uri $listUri -Headers $headers

      if ($response.value) {
        foreach ($b in $response.value) {
          $oldBuildId = [string]$b.id
          if ($oldBuildId -ne $CurrentBuildId) {
            Remove-BuildTag -BuildId $oldBuildId -Tag $LkgTag
          }
        }
      }
    }

    foreach ($target in @($targets)) {
      $name           = [string]$target.name
      $buildId        = [string]$target.buildId
      $definitionId   = [string]$target.definitionId
      $deployedTag    = [string]$target.deployedTag
      $lkgTag         = [string]$target.lkgTag
      $makeLkgUnique  = $false

      if ($null -ne $target.makeLkgUnique) {
        $makeLkgUnique = [System.Convert]::ToBoolean($target.makeLkgUnique)
      }

      if ([string]::IsNullOrWhiteSpace($name)) {
        $name = 'UnnamedTarget'
      }

      if ([string]::IsNullOrWhiteSpace($buildId)) {
        throw "[$name] buildId is empty."
      }

      Write-Host "----------------------------------------"
      Write-Host "Processing tag target: $name"
      Write-Host "Build ID: $buildId"
      Write-Host "Definition ID: $definitionId"
      Write-Host "DEPLOYED tag: $deployedTag"
      Write-Host "LKG tag: $lkgTag"
      Write-Host "Unique LKG: $makeLkgUnique"

      if ($makeLkgUnique -and -not [string]::IsNullOrWhiteSpace($lkgTag)) {
        if ([string]::IsNullOrWhiteSpace($definitionId)) {
          throw "[$name] definitionId is required when makeLkgUnique=true."
        }

        Remove-OldLkgTags -CurrentBuildId $buildId -DefinitionId $definitionId -LkgTag $lkgTag
      }

      if (-not [string]::IsNullOrWhiteSpace($lkgTag)) {
        Add-BuildTag -BuildId $buildId -Tag $lkgTag
      }

      if (-not [string]::IsNullOrWhiteSpace($deployedTag)) {
        Add-BuildTag -BuildId $buildId -Tag $deployedTag
      }
    }
  displayName: 'Tag deployed builds'
  env:
    SYSTEM_ACCESSTOKEN: $(System.AccessToken)










- stage: Tag_API_LKG_SIT
  displayName: 'Tag successful API build as LKG'
  dependsOn:
  - Resolve_Selected_Build
  - Deploy_API_SIT
  condition: and(succeeded('Deploy_API_SIT'), eq('${{ parameters.deployApi }}', 'true'))
  variables:
    ApiBuildId: $[ stageDependencies.Resolve_Selected_Build.ResolveBuildNumber.outputs['Resolve.ApiBuildId'] ]
    ApiPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Build.ResolveBuildNumber.outputs['Resolve.ApiPipelineDefinitionId'] ]
  jobs:
  - job: TagBuilds
    displayName: 'Tag API build'
    pool:
      name: 'Deployment Pool'
      demands:
      - Agent.Name -equals SIT-ALTERNA-BN1
    steps:
    - checkout: none
    - template: pipelines/tag-builds.steps.yml@templates
      parameters:
        tagTargets:
        - name: 'DataGateway API'
          buildId: '$(ApiBuildId)'
          definitionId: '$(ApiPipelineDefinitionId)'
          deployedTag: 'DEPLOYED-SIT-DATAGATEWAY-API'
          lkgTag: 'LKG-SIT-DATAGATEWAY-API'
          makeLkgUnique: true









- stage: Tag_APP_LKG_SIT
  displayName: 'Tag successful application builds as LKG'
  dependsOn:
  - Resolve_Selected_Builds
  - Deploy_Applications_SIT
  condition: succeeded('Deploy_Applications_SIT')
  variables:
    ApiBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.ApiBuildId'] ]
    ApiPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.ApiPipelineDefinitionId'] ]
    MvcBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.MvcBuildId'] ]
    MvcPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.MvcPipelineDefinitionId'] ]
  jobs:
  - job: TagBuilds
    displayName: 'Tag deployed builds'
    pool:
      name: 'Deployment Pool'
      demands:
      - Agent.Name -equals SIT-ALTERNA-BN1
    steps:
    - checkout: none
    - template: pipelines/tag-builds.steps.yml@templates
      parameters:
        tagTargets:
        - name: 'CardManagement API'
          buildId: '$(ApiBuildId)'
          definitionId: '$(ApiPipelineDefinitionId)'
          deployedTag: 'DEPLOYED-SIT-API'
          lkgTag: 'LKG-SIT-API'
          makeLkgUnique: true

        - name: 'CardManagement MVC'
          buildId: '$(MvcBuildId)'
          definitionId: '$(MvcPipelineDefinitionId)'
          deployedTag: 'DEPLOYED-SIT-MVC'
          lkgTag: 'LKG-SIT-MVC'
          makeLkgUnique: true











- template: pipelines/tag-builds.steps.yml@templates
  parameters:
    tagTargets:
    - name: 'DataExport DB'
      buildId: '$(DbBuildId)'
      definitionId: '$(DbPipelineDefinitionId)'
      deployedTag: 'DEPLOYED-SIT-DTE-DB'
      lkgTag: ''
      makeLkgUnique: false
