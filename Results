parameters:
- name: jobName
  type: string
  default: 'DeployService'

- name: jobDisplayName
  type: string
  default: 'Deploy Windows Service'

- name: deployPool
  type: string

- name: deployAgentName
  type: string

# Artifact inputs
- name: artifactName
  type: string
  default: 'drop'

- name: zipName
  type: string
  default: 'Service.zip'

# Deployment folder on the server
- name: installDir
  type: string
  default: 'C:\Apps\MyService'

# Windows Service details
- name: serviceName
  type: string
  default: 'MyService'

- name: serviceDisplayName
  type: string
  default: 'My Service'

# Path to the EXE inside installDir after unzip (relative path)
# Example: 'MyService.exe' or 'bin\MyService.exe'
- name: exeRelativePath
  type: string
  default: 'MyService.exe'

# Service account (optional)
# If empty -> LocalSystem
- name: serviceUser
  type: string
  default: ''

# If you use a domain/local user, pass password via secret variable and map it
- name: servicePassword
  type: string
  default: ''

# If your service needs args (optional)
- name: serviceArgs
  type: string
  default: ''

# Backup old version (optional)
- name: backupEnabled
  type: boolean
  default: true

jobs:
- job: ${{ parameters.jobName }}
  displayName: ${{ parameters.jobDisplayName }}

  pool:
    name: ${{ parameters.deployPool }}
    demands:
    - Agent.Name -equals ${{ parameters.deployAgentName }}

  steps:
  - checkout: none

  # Download artifact produced by build
  - download: current
    artifact: ${{ parameters.artifactName }}
    displayName: 'Download artifact'

  - task: PowerShell@2
    displayName: 'Deploy Windows Service (stop/copy/install/start)'
    inputs:
      targetType: 'inline'
      script: |
        $ErrorActionPreference = "Stop"

        $zipPath = "$(Pipeline.Workspace)\${{ parameters.artifactName }}\${{ parameters.zipName }}"
        if (!(Test-Path $zipPath)) {
          throw "Zip not found: $zipPath"
        }

        $installDir = "${{ parameters.installDir }}"
        $serviceName = "${{ parameters.serviceName }}"
        $displayName = "${{ parameters.serviceDisplayName }}"
        $exeRel = "${{ parameters.exeRelativePath }}"
        $args = "${{ parameters.serviceArgs }}"

        $exePath = Join-Path $installDir $exeRel

        Write-Host "Zip: $zipPath"
        Write-Host "InstallDir: $installDir"
        Write-Host "Service: $serviceName"
        Write-Host "ExePath: $exePath"

        # Ensure install dir exists
        New-Item -ItemType Directory -Force -Path $installDir | Out-Null

        # Backup current folder (optional)
        if ("${{ parameters.backupEnabled }}" -eq "true" -and (Test-Path $installDir) ) {
          $timestamp = Get-Date -Format "yyyyMMdd-HHmmss"
          $backupDir = "$installDir-backup-$timestamp"
          # only backup if there's something deployed already
          if (Get-ChildItem -Path $installDir -Force -ErrorAction SilentlyContinue) {
            Write-Host "Backing up current version to: $backupDir"
            Copy-Item -Path $installDir -Destination $backupDir -Recurse -Force
          }
        }

        # Stop service if exists
        $svc = Get-Service -Name $serviceName -ErrorAction SilentlyContinue
        if ($null -ne $svc) {
          if ($svc.Status -ne "Stopped") {
            Write-Host "Stopping service: $serviceName"
            Stop-Service -Name $serviceName -Force
            $svc.WaitForStatus("Stopped", (New-TimeSpan -Seconds 60))
          } else {
            Write-Host "Service already stopped."
          }
        } else {
          Write-Host "Service does not exist yet: $serviceName"
        }

        # Clean install dir (keep folder, remove contents)
        Write-Host "Cleaning install directory contents..."
        Get-ChildItem -Path $installDir -Force | Remove-Item -Recurse -Force

        # Extract zip to install dir
        Write-Host "Extracting zip..."
        Expand-Archive -Path $zipPath -DestinationPath $installDir -Force

        if (!(Test-Path $exePath)) {
          throw "Service EXE not found after extraction: $exePath (check exeRelativePath)"
        }

        # Create or update service
        $binPath = "`"$exePath`""
        if ($args -and $args.Trim().Length -gt 0) {
          $binPath = "$binPath $args"
        }

        if ($null -eq $svc) {
          Write-Host "Creating service..."
          $user = "${{ parameters.serviceUser }}"
          $pass = "${{ parameters.servicePassword }}"

          if ([string]::IsNullOrWhiteSpace($user)) {
            # LocalSystem
            sc.exe create $serviceName binPath= $binPath DisplayName= "`"$displayName`"" start= auto | Out-Host
          } else {
            if ([string]::IsNullOrWhiteSpace($pass)) {
              throw "servicePassword is required when serviceUser is provided."
            }
            sc.exe create $serviceName binPath= $binPath DisplayName= "`"$displayName`"" start= auto obj= $user password= $pass | Out-Host
          }
        } else {
          Write-Host "Updating service binPath..."
          sc.exe config $serviceName binPath= $binPath start= auto | Out-Host
        }

        # Start service
        Write-Host "Starting service..."
        Start-Service -Name $serviceName

        # Confirm running
        $svc2 = Get-Service -Name $serviceName
        Write-Host "Service status: $($svc2.Status)"
        if ($svc2.Status -ne "Running") {
          throw "Service failed to start."
        }
