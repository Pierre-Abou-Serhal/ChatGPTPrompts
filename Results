          BackendPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.BackendPipelineDefinitionId'] ]
          FrontendBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.FrontendBuildId'] ]
          FrontendPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.FrontendPipelineDefinitionId'] ]
        jobs:
          - job: TagApplicationBuilds
            displayName: 'Tag Frontend / Backend builds'
            pool:
              name: '$(deploymentPool)'
              demands:
                - Agent.Name -equals $(resolveAgentName)
            steps:
              - checkout: none

              - ${{ if eq(parameters.deployBackend, true) }}:
                  - template: pipelines/tag-builds.yml@templates
                    parameters:
                      tagTargets:
                        - name: 'Alterna Telecom Backend'
                          buildId: '$(BackendBuildId)'
                          definitionId: '$(BackendPipelineDefinitionId)'
                          deployedTag: 'DEPLOYED-$(environmentName)-ATC-BACKEND'
                          lkgTag: 'LKG-$(environmentName)-ATC-BACKEND'
                          makeLkgUnique: true

              - ${{ if eq(parameters.deployFrontend, true) }}:
                  - template: pipelines/tag-builds.yml@templates
                    parameters:
                      tagTargets:
                        - name: 'Alterna Telecom Frontend'
                          buildId: '$(FrontendBuildId)'
                          definitionId: '$(FrontendPipelineDefinitionId)'
                          deployedTag: 'DEPLOYED-$(environmentName)-ATC-FRONTEND'
                          lkgTag: 'LKG-$(environmentName)-ATC-FRONTEND'
                          makeLkgUnique: true

  - ${{ if and(eq(parameters.deployDatabase, true), or(eq(parameters.deployBackend, true), eq(parameters.deployFrontend, true))) }}:
      - stage: Deploy_DB_After_Apps
        displayName: 'Deploy DB to $(environmentName) after applications'
