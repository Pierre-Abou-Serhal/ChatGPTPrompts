      $dacpac = "${{ parameters.outputFolder }}\${{ parameters.dacpacFileName }}"
      $script = "${{ parameters.outputFolder }}\preview-deploy.sql"
      $report = "${{ parameters.outputFolder }}\deploy-report.xml"

      & "${{ parameters.sqlPackagePath }}" /Action:Script `
        /SourceFile:"$dacpac" `
        /TargetConnectionString:"${{ parameters.previewConnectionString }}" `
        /OutputPath:"$script" `
