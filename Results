  - name: servicePipelineName
    value: 'BUILD - SERVICE - Alterna Logger'

  - name: dbPipelineName
    value: 'BUILD - DB - Alterna Logger'

  - name: resolveAgentName
    value: 'UAT-ALTERNA-BN1'   # TODO verify

  - name: serviceAgentName
    value: 'UAT-ALTERNA-BN1'   # TODO verify

  - name: dbAgentName
    value: 'UAT-ALTERNA-BN1'   # TODO verify

  - name: approvalNotifyUsers
    value: 'SGBL\pabouserhal'

  - name: approvalInstructions
    value: 'Approve UAT Alterna Logger deployment.'

  - name: managementApprovalNotifyUsers
    value: 'SGBL\kabbas'

  - name: dbaApprovalNotifyUsers
    value: 'SGBL\hkassab'

  - name: serviceNameValue
    value: 'LoggerServiceAzureDevOps'   # TODO verify

  - name: serviceTargetPathValue
    value: 'C:\Alterna-Backend-Services\AlternaLoggerAzureDevOps-UAT'   # TODO verify

  - name: healthCheckUrlValue
    value: 'http://UAT-LOGGER-URL/health'   # TODO replace

  - name: backupRoot
    value: 'C:\DeployBackups\UAT\LOGGER'

# PROD
- ${{ if eq(parameters.targetEnvironment, 'PROD') }}:
  - group: PROD_VARIABLE_GROUP   # TODO verify actual group name

  - name: environmentName
    value: 'PROD'

  - name: servicePipelineName
    value: 'BUILD - SERVICE - Alterna Logger'

  - name: dbPipelineName
    value: 'BUILD - DB - Alterna Logger'

  - name: resolveAgentName
    value: 'PROD-ALTERNA-BN1'   # TODO verify

  - name: serviceAgentName
    value: 'PROD-ALTERNA-BN1'   # TODO verify

  - name: dbAgentName
    value: 'PROD-ALTERNA-BN1'   # TODO verify

  - name: approvalNotifyUsers
    value: 'SGBL\pabouserhal'

  - name: approvalInstructions
    value: 'Approve PROD Alterna Logger deployment.'

  - name: managementApprovalNotifyUsers
    value: 'SGBL\kabbas'

  - name: dbaApprovalNotifyUsers
    value: 'SGBL\hkassab'

  - name: serviceNameValue
    value: 'LoggerServiceAzureDevOps'   # TODO verify

  - name: serviceTargetPathValue
    value: 'C:\Alterna-Backend-Services\AlternaLoggerAzureDevOps-PROD'   # TODO verify

  - name: healthCheckUrlValue
    value: 'http://PROD-LOGGER-URL/health'   # TODO replace

  - name: backupRoot
    value: 'C:\DeployBackups\PROD\LOGGER'

stages:

- stage: Resolve_Selected_Builds
  displayName: 'Resolve selected build numbers'
  jobs:
  - job: ResolveBuildNumbers
    displayName: 'Resolve pipeline names and build numbers'
    pool:
      name: '$(deploymentPool)'
      demands:
      - Agent.Name -equals $(resolveAgentName)
    steps:
    - checkout: none

    - powershell: |
        $ErrorActionPreference = 'Stop'

        $collectionUri = "$(System.CollectionUri)".TrimEnd('/')
        $projectName   = [System.Uri]::EscapeDataString("$(System.TeamProject)")
        $apiVersion    = '7.1'
        $allowedBranchPattern = '$(buildSourceBranchRegex)'

        $headers = @{
          Authorization = "Bearer $env:SYSTEM_ACCESSTOKEN"
        }

        $deployService = "${{ parameters.deployService }}".ToLower() -eq 'true'
        $deployDb      = "${{ parameters.deployDatabase }}".ToLower() -eq 'true'

        if (-not ($deployService -or $deployDb)) {
          throw 'At least one deployment target must be selected: Logger Service or Database.'
        }

        function Normalize-BuildNumber {
          param([string]$BuildNumber)

          if ($BuildNumber -eq '__EMPTY__') {
            return ''
          }

          return $BuildNumber
        }

        function Resolve-DefinitionIdByName {
          param(
            [string]$Label,
            [string]$PipelineName
          )

          if ([string]::IsNullOrWhiteSpace($PipelineName)) {
            throw "$Label pipeline name is empty."
          }

          $encodedName = [System.Uri]::EscapeDataString($PipelineName)
          $uri = "{0}/{1}/_apis/build/definitions?name={2}&includeAllProperties=false&includeLatestBuilds=false&api-version={3}" -f `
            $collectionUri,
            $projectName,
            $encodedName,
            $apiVersion

          Write-Host "Resolving $Label pipeline name [$PipelineName]"
          $response = Invoke-RestMethod -Method Get -Uri $uri -Headers $headers

          if (-not $response.value -or $response.count -lt 1) {
            throw "No pipeline definition found for $Label with name [$PipelineName]."
          }

          $exactMatches = @($response.value | Where-Object { $_.name -eq $PipelineName })

          if ($exactMatches.Count -eq 0) {
            throw "No exact pipeline definition match found for $Label with name [$PipelineName]."
          }

          if ($exactMatches.Count -gt 1) {
            throw "More than one exact pipeline definition match was found for [$PipelineName]. Make the pipeline name unique."
          }

          $definition = $exactMatches[0]

          Write-Host "$Label definition resolved:"
          Write-Host "  Definition ID   = $($definition.id)"
          Write-Host "  Definition Name = $($definition.name)"

          return $definition.id
        }

        function Resolve-Build {
          param(
            [string]$Label,
            [string]$PipelineName,
            [string]$BuildNumber
          )

          $BuildNumber = Normalize-BuildNumber -BuildNumber $BuildNumber

          if ([string]::IsNullOrWhiteSpace($BuildNumber)) {
            throw "$Label build number is required because deployment of $Label was selected."
          }

          $definitionId = Resolve-DefinitionIdByName -Label $Label -PipelineName $PipelineName
          $encodedBuildNumber = [System.Uri]::EscapeDataString($BuildNumber)

          $uri = "{0}/{1}/_apis/build/builds?definitions={2}&buildNumber={3}&statusFilter=completed&resultFilter=succeeded&`$top=1&queryOrder=finishTimeDescending&api-version={4}" -f `
            $collectionUri,
            $projectName,
            $definitionId,
            $encodedBuildNumber,
            $apiVersion

          Write-Host "Resolving $Label build number [$BuildNumber] using pipeline definition [$definitionId]"
          $response = Invoke-RestMethod -Method Get -Uri $uri -Headers $headers

          if (-not $response.value -or $response.count -lt 1) {
            throw "No succeeded build found for $Label with build number [$BuildNumber] in pipeline [$PipelineName]."
          }

          $build = $response.value[0]

          if ($build.sourceBranch -notmatch $allowedBranchPattern) {
            throw "$Label build [$BuildNumber] was resolved, but it belongs to branch [$($build.sourceBranch)]. Only release/* or hotfix/* builds can be deployed."
          }

          Write-Host "$Label build resolved:"
          Write-Host "  Build ID         = $($build.id)"
          Write-Host "  Build Number     = $($build.buildNumber)"
          Write-Host "  Definition ID    = $definitionId"
          Write-Host "  Definition Name  = $PipelineName"
          Write-Host "  Branch           = $($build.sourceBranch)"

          Write-Host "##vso[task.setvariable variable=${Label}PipelineDefinitionId;isOutput=true]$definitionId"
          Write-Host "##vso[task.setvariable variable=${Label}BuildId;isOutput=true]$($build.id)"
          Write-Host "##vso[task.setvariable variable=${Label}ResolvedBuildNumber;isOutput=true]$($build.buildNumber)"
          Write-Host "##vso[task.setvariable variable=${Label}SourceBranch;isOutput=true]$($build.sourceBranch)"
        }

        if ($deployService) {
          Resolve-Build -Label 'Service' -PipelineName '$(servicePipelineName)' -BuildNumber '${{ parameters.serviceBuildNumber }}'
        } else {
          Write-Host '##vso[task.setvariable variable=ServicePipelineDefinitionId;isOutput=true]'
          Write-Host '##vso[task.setvariable variable=ServiceBuildId;isOutput=true]'
          Write-Host '##vso[task.setvariable variable=ServiceResolvedBuildNumber;isOutput=true]'
          Write-Host '##vso[task.setvariable variable=ServiceSourceBranch;isOutput=true]'
        }

        if ($deployDb) {
          Resolve-Build -Label 'Db' -PipelineName '$(dbPipelineName)' -BuildNumber '${{ parameters.dbBuildNumber }}'
        } else {
          Write-Host '##vso[task.setvariable variable=DbPipelineDefinitionId;isOutput=true]'
          Write-Host '##vso[task.setvariable variable=DbBuildId;isOutput=true]'
          Write-Host '##vso[task.setvariable variable=DbResolvedBuildNumber;isOutput=true]'
          Write-Host '##vso[task.setvariable variable=DbSourceBranch;isOutput=true]'
        }
      name: Resolve
      displayName: 'Resolve pipeline names and build numbers'
      env:
        SYSTEM_ACCESSTOKEN: $(System.AccessToken)

- stage: Generate_DB_Preview
  displayName: 'Generate DB preview for $(environmentName)'
  dependsOn:
  - Resolve_Selected_Builds
  condition: and(succeeded('Resolve_Selected_Builds'), eq('${{ parameters.deployDatabase }}', 'true'))
  variables:
    DbPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbPipelineDefinitionId'] ]
    DbBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbBuildId'] ]
  jobs:
  - template: pipelines/generate-db-preview.yml@templates
    parameters:
      jobName: 'GenerateDbPreview'
      jobDisplayName: 'Generate DB preview for $(environmentName)'
      deployPool: '$(deploymentPool)'
      deployAgentName: '$(dbAgentName)'
      artifactProject: '$(System.TeamProject)'
      artifactDefinitionId: '$(DbPipelineDefinitionId)'
      artifactBuildId: '$(DbBuildId)'
      artifactName: '$(dbArtifactName)'
      previewArtifactName: 'db-preview-$(environmentName)'
      targetConnectionString: '$(AppSettings.LoggerConnectionString)'   # TODO replace with your real Logger DB variable if different

- stage: Approval_Release
  displayName: 'Approval for $(environmentName) release'
  dependsOn:
  - Resolve_Selected_Builds
  - ${{ if eq(parameters.deployDatabase, true) }}:
    - Generate_DB_Preview
  condition: succeeded()
  jobs:
  - ${{ if eq(parameters.targetEnvironment, 'SIT') }}:
    - job: NoApprovalRequired
      displayName: 'No approval required for SIT'
      pool:
        name: '$(deploymentPool)'
        demands:
        - Agent.Name -equals $(resolveAgentName)
      steps:
      - checkout: none
      - powershell: |
          Write-Host 'SIT selected. No manual approval is required.'
        displayName: 'Skip manual approval'

  - ${{ if ne(parameters.targetEnvironment, 'SIT') }}:
    - job: WaitForBusinessApproval
      displayName: 'Wait for Business Approval'
      pool: server
      timeoutInMinutes: 1500
      steps:
      - task: ManualValidation@0
        timeoutInMinutes: 1440
        inputs:
          notifyUsers: '$(approvalNotifyUsers)'
          instructions: '$(approvalInstructions)'
          onTimeout: 'reject'

    - job: WaitForManagementApproval
      displayName: 'Wait for Management Approval'
      dependsOn: WaitForBusinessApproval
      pool: server
      timeoutInMinutes: 1500
      steps:
      - task: ManualValidation@0
        timeoutInMinutes: 1440
        inputs:
          notifyUsers: '$(managementApprovalNotifyUsers)'
          instructions: '$(approvalInstructions)'
          onTimeout: 'reject'

  - ${{ if and(ne(parameters.targetEnvironment, 'SIT'), eq(parameters.deployDatabase, true)) }}:
    - job: WaitForDbaApproval
      displayName: 'Wait for DBA approval'
      dependsOn: WaitForManagementApproval
      pool: server
      timeoutInMinutes: 1500
      steps:
      - task: ManualValidation@0
        timeoutInMinutes: 1440
        inputs:
          notifyUsers: '$(dbaApprovalNotifyUsers)'
          instructions: 'Approve $(environmentName) Alterna Logger database deployment.'
          onTimeout: 'reject'

- ${{ if eq(parameters.deployService, true) }}:
  - stage: Deploy_Service
    displayName: 'Deploy Logger Service to $(environmentName)'
    dependsOn:
    - Resolve_Selected_Builds
    - Approval_Release
    condition: succeeded('Approval_Release')
    variables:
      ServicePipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.ServicePipelineDefinitionId'] ]
      ServiceBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.ServiceBuildId'] ]
      ServiceSourceBranch: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.ServiceSourceBranch'] ]
    jobs:
    - template: pipelines/deploy-windows-service.yml@templates
      parameters:
        jobDependsOn: []
        jobCondition: succeeded()
        deploymentName: 'DeployLoggerService'
        deploymentDisplayName: 'Deploy Alterna Logger Windows Service - ${{ parameters.targetEnvironment }}'
        environmentName: '${{ parameters.targetEnvironment }}'
        deployPool: '$(deploymentPool)'
        deployAgentName: '$(serviceAgentName)'
        ${{ if eq(parameters.targetEnvironment, 'SIT') }}:
          variableGroup: 'SIT_VARIABLE_GROUP'
        ${{ if eq(parameters.targetEnvironment, 'UAT') }}:
          variableGroup: 'UAT_VARIABLE_GROUP'
        ${{ if eq(parameters.targetEnvironment, 'PROD') }}:
          variableGroup: 'PROD_VARIABLE_GROUP'
        componentName: 'LOGGER'
        artifactName: '$(serviceArtifactName)'
        artifactBuildType: 'specific'
        artifactProject: '$(System.TeamProject)'
        artifactDefinitionId: '$(ServicePipelineDefinitionId)'
        artifactBuildId: '$(ServiceBuildId)'
        artifactBranch: '$(ServiceSourceBranch)'
        zipName: '$(serviceZipName)'
        serviceName: '$(serviceNameValue)'
        serviceTargetPath: '$(serviceTargetPathValue)'
        cleanTargetBeforeCopy: true
        cleanExcludeCsv: 'logs,Keys'
        enableJsonTransform: true
        jsonFiles: '**/appsettings.json'
        enableXmlConfigTransform: false
        xmlConfigFiles: []
        xmlVariableValues: {}
        enableCustomXmlEdits: false
        customXmlEdits: []
        customXmlVariableValues: {}
        enableHealthCheck: true
        healthCheckUrl: '$(healthCheckUrlValue)'
        healthCheckExpectedStatusCode: '200'
        healthCheckRetries: 6
        healthCheckDelaySeconds: 10
        enableLocalBackup: true
        backupRoot: '$(backupRoot)'
        backupPath: '$(backupRoot)\$(Build.BuildId)'

- ${{ if eq(parameters.deployService, true) }}:
  - stage: Tag_SERVICE_LKG
    displayName: 'Tag successful service build as LKG'
    dependsOn:
    - Resolve_Selected_Builds
    - Deploy_Service
    condition: succeeded('Deploy_Service')
    variables:
      ServiceBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.ServiceBuildId'] ]
      ServicePipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.ServicePipelineDefinitionId'] ]
    jobs:
    - job: TagServiceBuild
      displayName: 'Tag service build'
      pool:
        name: '$(deploymentPool)'
        demands:
        - Agent.Name -equals $(resolveAgentName)
      steps:
      - checkout: none

      - template: pipelines/tag-builds.yml@templates
        parameters:
          tagTargets:
          - name: 'Alterna Logger Service'
            buildId: '$(ServiceBuildId)'
            definitionId: '$(ServicePipelineDefinitionId)'
            deployedTag: 'DEPLOYED-$(environmentName)-LOGGER-SVC'
            lkgTag: 'LKG-$(environmentName)-LOGGER-SVC'
            makeLkgUnique: true

- ${{ if and(eq(parameters.deployDatabase, true), eq(parameters.deployService, true)) }}:
  - stage: Deploy_DB_After_Service
    displayName: 'Deploy Logger DB to $(environmentName) after Service'
    dependsOn:
    - Resolve_Selected_Builds
    - Tag_SERVICE_LKG
    condition: succeeded('Tag_SERVICE_LKG')
    variables:
      DbPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbPipelineDefinitionId'] ]
      DbBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbBuildId'] ]
      DbSourceBranch: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbSourceBranch'] ]
    jobs:
    - template: pipelines/deploy-database.yml@templates
      parameters:
        jobDependsOn: []
        jobCondition: succeeded()
        deploymentName: 'DeployDb'
        deploymentDisplayName: 'Deploy Alterna Logger database'
        environmentName: '${{ parameters.targetEnvironment }}'
        deployPool: '$(deploymentPool)'
        deployAgentName: '$(dbAgentName)'
        artifactName: '$(dbArtifactName)'
        artifactBuildType: 'specific'
        artifactProject: '$(System.TeamProject)'
        artifactDefinitionId: '$(DbPipelineDefinitionId)'
        artifactBuildId: '$(DbBuildId)'
        artifactBranch: '$(DbSourceBranch)'
        targetConnectionString: '$(AppSettings.LoggerConnectionString)'   # TODO replace with your real Logger DB variable if different
        dacpacFileName: '$(dbDacpacFileName)'
        artifactDownloadPath: '$(Pipeline.Workspace)\db-deploy'

- ${{ if and(eq(parameters.deployDatabase, true), eq(parameters.deployService, false)) }}:
  - stage: Deploy_DB_Only
    displayName: 'Deploy Logger DB to $(environmentName)'
    dependsOn:
    - Resolve_Selected_Builds
    - Approval_Release
    condition: succeeded('Approval_Release')
    variables:
      DbPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbPipelineDefinitionId'] ]
      DbBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbBuildId'] ]
      DbSourceBranch: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbSourceBranch'] ]
    jobs:
    - template: pipelines/deploy-database.yml@templates
      parameters:
        jobDependsOn: []
        jobCondition: succeeded()
        deploymentName: 'DeployDb'
        deploymentDisplayName: 'Deploy Alterna Logger database'
        environmentName: '${{ parameters.targetEnvironment }}'
        deployPool: '$(deploymentPool)'
        deployAgentName: '$(dbAgentName)'
        artifactName: '$(dbArtifactName)'
        artifactBuildType: 'specific'
        artifactProject: '$(System.TeamProject)'
        artifactDefinitionId: '$(DbPipelineDefinitionId)'
        artifactBuildId: '$(DbBuildId)'
        artifactBranch: '$(DbSourceBranch)'
        targetConnectionString: '$(AppSettings.LoggerConnectionString)'   # TODO replace with your real Logger DB variable if different
        dacpacFileName: '$(dbDacpacFileName)'
        artifactDownloadPath: '$(Pipeline.Workspace)\db-deploy'

- ${{ if eq(parameters.deployDatabase, true) }}:
  - stage: Tag_DB_DEPLOYED
    displayName: 'Tag deployed database build'
    dependsOn:
    - Resolve_Selected_Builds
    - ${{ if and(eq(parameters.deployDatabase, true), eq(parameters.deployService, true)) }}:
      - Deploy_DB_After_Service
    - ${{ if and(eq(parameters.deployDatabase, true), eq(parameters.deployService, false)) }}:
      - Deploy_DB_Only
    condition: succeeded()
    variables:
      DbBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbBuildId'] ]
      DbPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbPipelineDefinitionId'] ]
    jobs:
    - job: TagDatabaseBuild
      displayName: 'Tag DB build'
      pool:
        name: '$(deploymentPool)'
        demands:
        - Agent.Name -equals $(resolveAgentName)
      steps:
      - checkout: none

      - template: pipelines/tag-builds.yml@templates
        parameters:
          tagTargets:
          - name: 'Alterna Logger DB'
            buildId: '$(DbBuildId)'
            definitionId: '$(DbPipelineDefinitionId)'
            deployedTag: 'DEPLOYED-$(environmentName)-LOGGER-DB'
            lkgTag: 'LKG-$(environmentName)-LOGGER-DB'
            makeLkgUnique: true
