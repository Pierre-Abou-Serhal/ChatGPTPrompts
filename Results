Actually I am using the Owasp in my build tempaltes:

This is an exmaple:

parameters:
- name: jobName
  type: string
  default: 'BuildAngular'

- name: jobDisplayName
  type: string
  default: 'Build (Angular)'

- name: buildPool
  type: string

- name: buildAgentName
  type: string

# Where your Angular project lives relative to repo root
- name: workingDirectory
  type: string
  default: '.'

# Node version to use (must exist on server or be installed)
- name: nodeVersion
  type: string
  default: '22.x'

# install command
- name: installCommand
  type: string
  default: 'ci'   # npm install

# whether to run tests
- name: runTests
  type: boolean
  default: false

# test command (customizable)
- name: testCommand
  type: string
  default: 'test -- --watch=false --browsers=ChromeHeadless'

# build configuration / command
- name: buildCommand
  type: string
  default: 'npx ng build'

# Angular dist folder (relative to workingDirectory)
# Example: 'dist/my-app'
- name: distFolder
  type: string

# Zip file name produced as artifact
- name: zipName
  type: string
  default: 'AngularApp.zip'

- name: artifactName
  type: string
  default: 'drop'

# Where to stage files before zipping
- name: publishOutputFolder
  type: string
  default: '$(Build.ArtifactStagingDirectory)\publish'

# OWASP Security Check
- name: runDependencyCheck
  type: boolean
  default: false

- name: dependencyCheckCliPath
  type: string
  default: 'C:\Tools\dependency-check\dependency-check-12.2.0\bin\dependency-check.bat'

- name: dependencyCheckDataPath
  type: string
  default: 'C:\Tools\dependency-check-data'

- name: dependencyCheckProjectName
  type: string
  default: '$(Build.Repository.Name)'

- name: dependencyCheckAdditionalArguments
  type: string
  default: ''

jobs:
- job: ${{ parameters.jobName }}
  displayName: ${{ parameters.jobDisplayName }}

  pool:
    name: ${{ parameters.buildPool }}
    demands:
    - Agent.Name -equals ${{ parameters.buildAgentName }}

  steps:
  - checkout: self
    clean: true

  - powershell: |
      Write-Host "Working directory: ${{ parameters.workingDirectory }}"
      if (-not (Test-Path "${{ parameters.workingDirectory }}")) {
        throw "Working directory not found: ${{ parameters.workingDirectory }}"
      }
    displayName: 'Validate working directory'

  - script: |
      whoami
      npm config list -l
      node -p "process.env.HTTP_PROXY"
      node -p "process.env.HTTPS_PROXY"
      nslookup registry.npmjs.org
      npm ping --registry=https://registry.npmjs.org/
    displayName: 'Diagnose npm network'

  # Install dependencies
  - script: |
      npm ${{ parameters.installCommand }}
    workingDirectory: ${{ parameters.workingDirectory }}
    displayName: 'Install dependencies (npm)'
  
  # OWASP dependency check
  - powershell: |
      $dc = '${{ parameters.dependencyCheckCliPath }}'
      $reportDir = '$(Build.ArtifactStagingDirectory)\dependency-check'
      $scanPath = Join-Path '$(Build.SourcesDirectory)' '${{ parameters.workingDirectory }}'

      if (-not (Test-Path $dc)) {
        throw "Dependency-Check CLI not found at: $dc"
      }

      New-Item -ItemType Directory -Force -Path $reportDir | Out-Null

      & $dc `
        --project "${{ parameters.dependencyCheckProjectName }}" `
        --scan "$scanPath" `
        --format "HTML" `
        --format "JSON" `
        --format "JUNIT" `
        --out "$reportDir" `
        --data "${{ parameters.dependencyCheckDataPath }}" `
        --nvdApiKey "$env:NVD_API_KEY" `
        --disableKnownExploited `
        --disableHostedSuppressions `
        --disableYarnAudit `
        --disablePnpmAudit `
        --disableNodeAudit `
        --disableRetireJS `
        --disableVersionCheck `
        ${{ parameters.dependencyCheckAdditionalArguments }}

      if ($LASTEXITCODE -ne 0) {
        exit $LASTEXITCODE
      }
    displayName: 'OWASP Dependency Check (local CLI)'
    condition: and(succeeded(), eq('${{ parameters.runDependencyCheck }}', 'true'))
    env:
      NVD_API_KEY: $(NVD_API_KEY)

  - task: PublishTestResults@2
    displayName: 'Publish Dependency Check JUnit'
    condition: and(always(), eq('${{ parameters.runDependencyCheck }}', 'true'))
    inputs:
      testResultsFormat: 'JUnit'
      testResultsFiles: '**\*junit.xml'
      searchFolder: '$(Build.ArtifactStagingDirectory)\dependency-check'
      failTaskOnFailedTests: false

  # Optional tests
  - script: |
      npm ${{ parameters.testCommand }}
    workingDirectory: ${{ parameters.workingDirectory }}
    displayName: 'Run tests'
    condition: and(succeeded(), eq('${{ parameters.runTests }}', 'true'))
    # If you use yarn/pnpm tests, switch this command accordingly.

  # Build
  - script: |
      ${{ parameters.buildCommand }}
    workingDirectory: ${{ parameters.workingDirectory }}
    displayName: 'Build Angular'

  # Copy dist output to staging folder (clean staging first)
  - task: CopyFiles@2
    displayName: 'Copy dist to staging folder'
    inputs:
      SourceFolder: '${{ parameters.workingDirectory }}\${{ parameters.distFolder }}'
      Contents: '**'
      TargetFolder: '${{ parameters.publishOutputFolder }}'
      OverWrite: true

  # Zip staged files (no nested dist folder in zip)
  - task: ArchiveFiles@2
    displayName: 'Zip dist output'
    inputs:
      rootFolderOrFile: '${{ parameters.publishOutputFolder }}'
      includeRootFolder: false
      archiveType: 'zip'
      archiveFile: '$(Build.ArtifactStagingDirectory)\${{ parameters.zipName }}'
      replaceExistingArchive: true

  # Publish artifact (on-prem compatible)
  - task: PublishBuildArtifacts@1
    displayName: 'Publish Build Artifact'
    inputs:
      PathtoPublish: '$(Build.ArtifactStagingDirectory)\${{ parameters.zipName }}'
      ArtifactName: '${{ parameters.artifactName }}'
      publishLocation: 'Container'

