## 7. Add these helper methods in the main component

```ts
private getFileValidationIssues(
  items: FileImportContent[]
): FileValidationIssue[] {
  const counts = new Map<string, number>();
  const issuesMap = new Map<number, FileValidationIssue>();

  for (const item of items) {
    const accNbr = item.accNbr?.trim();

    if (!accNbr) continue;

    counts.set(accNbr, (counts.get(accNbr) ?? 0) + 1);
  }

  for (const item of items) {
    const accNbr = item.accNbr?.trim() ?? '';
    const sourceAccountNumber = item.sourceAccountNumber?.trim() ?? '';

    const isDuplicate =
      !!accNbr && (counts.get(accNbr) ?? 0) > 1;

    const fileCurrencyCode = this.normalizeCurrencyCode(
      this.fileImport?.fileCurrencyCode
    );

    const debitAccountCurrencyCode =
      this.getDebitAccountCurrencyCode(sourceAccountNumber);

    const hasInvalidCurrency =
      !!fileCurrencyCode && fileCurrencyCode !== debitAccountCurrencyCode;

    if (!isDuplicate && !hasInvalidCurrency) {
      continue;
    }

    const issue: FileValidationIssue = {
      id: item.id,
      accNbr,
      sourceAccountNumber,
      amount: item.amount,
      other: item.other,

      issueTypes: [],

      fileCurrencyCode,
      fileCurrencyDescription: this.getCurrencyDescription(fileCurrencyCode),

      debitAccountCurrencyCode,
      debitAccountCurrencyDescription:
        this.getCurrencyDescription(debitAccountCurrencyCode),
    };

    if (isDuplicate) {
      issue.issueTypes.push(ValidationIssueType.DuplicateAccount);
    }

    if (hasInvalidCurrency) {
      issue.issueTypes.push(ValidationIssueType.InvalidCurrency);
    }

    issuesMap.set(item.id, issue);
  }

  return Array.from(issuesMap.values()).sort((a, b) => {
    return (
      a.accNbr.localeCompare(b.accNbr) ||
      b.amount - a.amount
    );
  });
}

private getDebitAccountCurrencyCode(
  debitAccountNumber?: string | null
): string {
  const accountNumber = debitAccountNumber?.trim().toUpperCase() ?? '';

  if (!accountNumber) {
    return '';
  }

  if (
    accountNumber.includes(Currency[Currency.LBP]) ||
    accountNumber.slice(-3) === Currency.LBP.toString()
  ) {
    return Currency.LBP.toString();
  }

  if (
    accountNumber.includes(Currency[Currency.USD]) ||
    accountNumber.slice(-3) === Currency.USD.toString()
  ) {
    return Currency.USD.toString();
  }

  if (
    accountNumber.includes(Currency[Currency.EUR]) ||
    accountNumber.slice(-3) === Currency.EUR.toString()
  ) {
    return Currency.EUR.toString();
  }

  return '';
}

private normalizeCurrencyCode(
  currency?: string | number | null
): string {
  const value = currency?.toString().trim().toUpperCase() ?? '';

  if (!value) {
    return '';
  }

  if (
    value === Currency.LBP.toString() ||
    value === Currency[Currency.LBP]
  ) {
    return Currency.LBP.toString();
  }

  if (
    value === Currency.USD.toString() ||
    value === Currency[Currency.USD]
  ) {
    return Currency.USD.toString();
  }

  if (
    value === Currency.EUR.toString() ||
    value === Currency[Currency.EUR]
  ) {
    return Currency.EUR.toString();
  }

  return value;
}

private getCurrencyDescription(
  currencyCode?: string | number | null
): string {
  const normalized = this.normalizeCurrencyCode(currencyCode);

  if (!normalized) {
    return '';
  }

  if (normalized === Currency.LBP.toString()) {
    return Currency[Currency.LBP];
  }

  if (normalized === Currency.USD.toString()) {
    return Currency[Currency.USD];
  }

  if (normalized === Currency.EUR.toString()) {
    return Currency[Currency.EUR];
  }

  return normalized;
}
```

