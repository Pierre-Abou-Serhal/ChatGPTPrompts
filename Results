  private getFileValidationIssues(
    items: FileImportContent[]
  ): FileValidationIssue[] {
    const accountCounts = new Map<string, number>();
    const issues: FileValidationIssue[] = [];

    for (const item of items) {
      const proposedAccount = item.accNbr?.trim();

      if (!proposedAccount) {
        continue;
      }

      accountCounts.set(
        proposedAccount,
        (accountCounts.get(proposedAccount) ?? 0) + 1
      );
    }

    for (const item of items) {
      const proposedAccount = item.accNbr?.trim() ?? '';
      const debitAccount = item.sourceAccountNumber?.trim() ?? '';

      const issueTypes: ValidationIssueType[] = [];

      const isDuplicate =
        !!proposedAccount &&
        (accountCounts.get(proposedAccount) ?? 0) > 1;

      if (isDuplicate) {
        issueTypes.push(ValidationIssueType.DuplicateAccount);
      }

      const proposedAccountCurrencyCode =
        this.getAccountCurrencyCode(proposedAccount);

      const debitAccountCurrencyCode =
        this.getAccountCurrencyCode(debitAccount);

      const hasInvalidCurrency =
        !!proposedAccount &&
        !!debitAccount &&
        !!proposedAccountCurrencyCode &&
        !!debitAccountCurrencyCode &&
        proposedAccountCurrencyCode !== debitAccountCurrencyCode;

      if (hasInvalidCurrency) {
        issueTypes.push(ValidationIssueType.InvalidCurrency);
      }

      if (issueTypes.length === 0) {
        continue;
      }

      issues.push({
        id: item.id,
        accNbr: proposedAccount,
        sourceAccountNumber: debitAccount,
        amount: item.amount,
        other: item.other,

        issueTypes,

        t24AccountCurrencyCode: proposedAccountCurrencyCode,
        t24AccountCurrencyDescription: this.getCurrencyDescription(
          proposedAccountCurrencyCode
        ),

        debitAccountCurrencyCode: debitAccountCurrencyCode,
        debitAccountCurrencyDescription: this.getCurrencyDescription(
          debitAccountCurrencyCode
        ),
      } as FileValidationIssue);
    }

    return issues.sort((a, b) => {
      return a.accNbr.localeCompare(b.accNbr) || b.amount - a.amount;
    });
  }

  private getAccountCurrencyCode(accountNumber?: string | null): string {
    const account = accountNumber?.trim().toUpperCase() ?? '';

    if (!account) {
      return '';
    }

    if (
      account.includes(Currency[Currency.LBP]) ||
      account.slice(-3) === Currency.LBP.toString()
    ) {
      return Currency.LBP.toString();
    }

    if (
      account.includes(Currency[Currency.USD]) ||
      account.slice(-3) === Currency.USD.toString()
    ) {
      return Currency.USD.toString();
    }

    if (
      account.includes(Currency[Currency.EUR]) ||
      account.slice(-3) === Currency.EUR.toString()
    ) {
      return Currency.EUR.toString();
    }

    return '';
  }

  private getCurrencyDescription(currencyCode?: string | number | null): string {
    const code = currencyCode?.toString().trim() ?? '';

    if (!code) {
      return '';
    }

    if (code === Currency.LBP.toString()) {
      return Currency[Currency.LBP];
    }

    if (code === Currency.USD.toString()) {
      return Currency[Currency.USD];
    }

    if (code === Currency.EUR.toString()) {
      return Currency[Currency.EUR];
    }

    return code;
  }
