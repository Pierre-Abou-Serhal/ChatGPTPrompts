name: ATC_DB_$(SourceBranchName)_rc$(Rev:r)

resources:
  repositories:
  - repository: templates
    type: git
    name: 'Azure Templates/Azure Templates'
    ref: refs/heads/main

trigger:
  branches:
    include:
    - release/*
  paths:
    include:
    - DatabaseProjectAlterna_Telecom/**

pr: none

variables:
- group: SIT_BACK_END_VARIABLE_GROUP

stages:
- stage: Build_DB
  displayName: 'Build DB'
  jobs:
  - template: pipelines/build-database-project.yml@templates
    parameters:
      jobName: 'BuildDb'
      jobDisplayName: 'Build database project'
      buildPool: 'Build Pool'
      buildAgentName: 'UAT-ALTERNA-DK1'
      sqlProjectPath: 'DatabaseProjectAlterna_Telecom/DatabaseProjectAlterna_Telecom.sqlproj'
      artifactName: 'alterna-telecom-db-drop'
      previewConnectionString: '$(GlobalSettings.ConnString)'
