Yes. The clean way is to register YARP with `AddReverseProxy().LoadFromConfig(...).AddTransforms(...)`, then inspect `builderContext.Route.ClusterId` and add the outbound headers in a request transform. YARP’s transforms apply to the **proxied outbound request**, and the `AddTransforms` callback can inspect the route config each time a route is built or rebuilt. ([Microsoft Learn][1])

Also, in your current `Program.cs`, you are missing the YARP service registration. `app.MapReverseProxy()` alone is not enough.

Use this structure.

### 1) `Program.cs`

```csharp
using BrgccReverseProxy.Extensions;
using Serilog;

var isWindowsService = !Environment.UserInteractive;
if (isWindowsService)
{
    Directory.SetCurrentDirectory(AppContext.BaseDirectory);
}

Directory.CreateDirectory(Path.Combine(Directory.GetCurrentDirectory(), "logs"));

var builder = WebApplication.CreateBuilder(args);

if (OperatingSystem.IsWindows())
{
    builder.Host.UseWindowsService();
}

// Serilog
Log.Logger = new LoggerConfiguration()
    .ReadFrom.Configuration(builder.Configuration)
    .CreateLogger();

builder.Host.UseSerilog();

// CORS
builder.Services.AddCors(options =>
{
    options.AddPolicy("CorsPolicyConfig", corsPolicyBuilder =>
        corsPolicyBuilder.AllowAnyOrigin().AllowAnyMethod().AllowAnyHeader());
});

// Register YARP + per-cluster auth transform
builder.Services.AddClusterBasedReverseProxyAuth(builder.Configuration);

var app = builder.Build();

app.UseCors("CorsPolicyConfig");
app.UseRequestLogging();
app.UseHttpsRedirection();
app.UseRouting();

app.MapReverseProxy();

app.Run();
```

### 2) Create the extension class

`Extensions/ReverseProxyAuthExtensions.cs`

```csharp
using System.Text;
using Microsoft.Extensions.Configuration;
using Microsoft.Extensions.DependencyInjection;
using Microsoft.Extensions.Options;
using Yarp.ReverseProxy.Transforms;

namespace BrgccReverseProxy.Extensions;

public static class ReverseProxyAuthExtensions
{
    public static IServiceCollection AddClusterBasedReverseProxyAuth(
        this IServiceCollection services,
        IConfiguration configuration)
    {
        services.Configure<ClusterAuthOptions>(
            configuration.GetSection("ClusterAuth"));

        services
            .AddReverseProxy()
            .LoadFromConfig(configuration.GetSection("ReverseProxy"))
            .AddTransforms(builderContext =>
            {
                var authOptions = builderContext.Services
                    .GetRequiredService<IOptions<ClusterAuthOptions>>()
                    .Value;

                var clusterId = builderContext.Route.ClusterId;

                if (string.IsNullOrWhiteSpace(clusterId))
                    return;

                if (!authOptions.Clusters.TryGetValue(clusterId, out var clusterAuth))
                    return;

                if (string.IsNullOrWhiteSpace(clusterAuth.Username) ||
                    string.IsNullOrWhiteSpace(clusterAuth.Password))
                    return;

                builderContext.AddRequestTransform(transformContext =>
                {
                    // OPTION A: Standard HTTP Basic auth
                    var raw = $"{clusterAuth.Username}:{clusterAuth.Password}";
                    var base64 = Convert.ToBase64String(Encoding.UTF8.GetBytes(raw));

                    transformContext.ProxyRequest.Headers.Remove("Authorization");
                    transformContext.ProxyRequest.Headers.TryAddWithoutValidation(
                        "Authorization",
                        $"Basic {base64}");

                    return ValueTask.CompletedTask;
                });
            });

        return services;
    }
}

public sealed class ClusterAuthOptions
{
    public Dictionary<string, ClusterCredential> Clusters { get; set; } = new();
}

public sealed class ClusterCredential
{
    public string Username { get; set; } = string.Empty;
    public string Password { get; set; } = string.Empty;
}
```

