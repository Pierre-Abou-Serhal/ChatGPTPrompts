            {
                LogError(ex.Message, new CorrelationInfo()
                {
                    CorrelationId = Guid.NewGuid().ToString(),
                    UserName = "No User",
                    RequestURL = "FrontEndErrorHandler",
                    StatusCode = HttpStatusCode.InternalServerError,
                    RDirection = RequestDirection.Processing,
                    RType = RequestType.POST
                }, ex);
                return RedirectDashboard();
            }
        }


        public IActionResult RedirectDashboard()
        {
            HttpContext.Session.Clear();
            Response.Cookies.Delete("ArchiveData");
            return View("RedirectDashboard");
        }
