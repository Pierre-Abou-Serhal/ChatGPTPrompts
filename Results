            if (Context.Session.GetString("ArchiveData") != null)
            {
                CookieContent = Context.Session.GetString("ArchiveData") ?? string.Empty;
            }
            else
            {
                if (Context.Request.Cookies.Count == 0)
                {
                    if (Context.Response.Headers.TryGetValue("Set-Cookie", out var Data))
                    {
                        foreach (string? cookie in Data)
                        {
                            if (cookie != null && cookie.Contains("ArchiveData"))
                            {
                                CookieContent = cookie.Substring(cookie.IndexOf("=") + 1, cookie.IndexOf(";") - 12);
                            }
                        }

                        if (String.IsNullOrEmpty(CookieContent))
                        {

                            return false;
                        }

                        CookieContent = HttpUtility.UrlDecode(CookieContent);
                    }
                    else
                    {

                        return false;
                    }
                }
            }

            Dictionary<String, Object> dict = [];
            Object? dicRetVal = new();
            Boolean Expired = true;
            (Expired, dict) = GenerateVariablesLkp(Context,
                Context.Request.Cookies["ArchiveData"] ?? CookieContent);
            if (Expired)
            {
                return false;
            }

