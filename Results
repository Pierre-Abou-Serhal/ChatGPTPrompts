			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// === 1. Generate Systems Trace Audit Number (STAN) ===",
					"const randomNumber = Math.floor(Math.random() * 1000000);",
					"const stan = String(randomNumber).padStart(6, '0');",
					"pm.collectionVariables.set(\"stan\", stan);",
					"",
					"",
					"// === 2. Generate Retrieval Reference Number (RRN) ===",
					"const now = new Date();",
					"",
					"// Get the last digit of the year (y)",
					"const lastDigitOfYear = String(now.getFullYear()).slice(-1);",
					"",
					"// Calculate Day of the Year (ddd)",
					"const startOfYear = new Date(now.getFullYear(), 0, 0);",
					"const diffInMs = now - startOfYear;",
					"const oneDayInMs = 1000 * 60 * 60 * 24;",
					"const dayOfYear = Math.floor(diffInMs / oneDayInMs);",
					"const ddd = String(dayOfYear).padStart(3, '0');",
					"",
					"// Get 24-hour format hour (HH)",
					"const hh = String(now.getHours()).padStart(2, '0');",
					"",
					"// Combine into final RRN (ydddHH + stan)",
					"const rrn = `${lastDigitOfYear}${ddd}${hh}${stan}`;",
					"pm.collectionVariables.set(\"rrn\", rrn);",
					"",
					"// === 3. Get the localTransactionDateTime",
					"",
					"// Get the current date and time",
					"",
					"// Format to ISO string and remove the milliseconds/Z suffix",
					"const formattedTimestamp = now.toISOString().split('.')[0];",
					"",
					"// Save to a variable",
					"pm.collectionVariables.set(\"timestamp\", formattedTimestamp);"
				]
			}
