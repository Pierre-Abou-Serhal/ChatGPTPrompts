# 2) Add this new stage before approval

This downloads the chosen DACPAC and generates:

* `preview-deploy.sql`
* `deploy-report.xml`

for the selected environment.

```yaml
- stage: Generate_DB_Preview
  displayName: 'Generate DB preview for $(environmentName)'
  dependsOn:
  - Resolve_Selected_Builds
  condition: and(succeeded('Resolve_Selected_Builds'), eq('${{ parameters.deployDatabase }}', 'true'))
  variables:
    DbPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbPipelineDefinitionId'] ]
    DbBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbBuildId'] ]
    DbSourceBranch: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbSourceBranch'] ]
  jobs:
  - job: GenerateDbPreview
    displayName: 'Generate preview SQL and deploy report'
    pool:
      name: '$(deploymentPool)'
      demands:
      - Agent.Name -equals $(dbAgentName)
    steps:
    - checkout: none

    - task: DownloadPipelineArtifact@2
      displayName: 'Download DB DACPAC artifact'
      inputs:
        project: '$(System.TeamProject)'
        buildType: 'specific'
        definition: '$(DbPipelineDefinitionId)'
        buildVersionToDownload: 'specific'
        pipelineId: '$(DbBuildId)'
        artifactName: '$(dbArtifactName)'
        targetPath: '$(Pipeline.Workspace)\dbdrop'

    - powershell: |
        $ErrorActionPreference = 'Stop'

        $dacpac = Get-ChildItem "$(Pipeline.Workspace)\dbdrop" -Recurse -Filter *.dacpac |
                  Select-Object -First 1

        if (-not $dacpac) {
          throw "No .dacpac found in downloaded DB artifact."
        }

        $outDir = "$(Pipeline.Workspace)\db-preview"
        New-Item -ItemType Directory -Force -Path $outDir | Out-Null

        $scriptPath = Join-Path $outDir 'preview-deploy.sql'
        $reportPath = Join-Path $outDir 'deploy-report.xml'

        & "SqlPackage" `
          /Action:Script `
          /SourceFile:"$($dacpac.FullName)" `
          /TargetConnectionString:"$(GlobalSettings.ConnString)" `
          /DeployScriptPath:"$scriptPath" `
          /DeployReportPath:"$reportPath" `
          /p:IgnorePermissions=true `
          /p:IgnoreRoleMembership=true `
          /p:IgnoreUserSettingsObjects=true `
          /p:BlockOnPossibleDataLoss=true `
          /p:DropObjectsNotInSource=false

        if ($LASTEXITCODE -ne 0) {
          throw "SqlPackage Script failed with exit code $LASTEXITCODE"
        }

        Write-Host "Preview SQL generated at: $scriptPath"
        Write-Host "Deploy report generated at: $reportPath"
      displayName: 'Generate DB preview files'

    - task: PublishPipelineArtifact@1
      displayName: 'Publish DB preview artifact'
      inputs:
        targetPath: '$(Pipeline.Workspace)\db-preview'
        artifact: 'db-preview-$(environmentName)'
```

