deploy-iis.yml:
parameters:
- name: deploymentName
  type: string
  default: 'DeployJob'

- name: deploymentDisplayName
  type: string
  default: 'Deploy IIS'

- name: environmentName
  type: string

- name: deployPool
  type: string

- name: deployAgentName
  type: string

- name: variableGroup
  type: string

- name: artifactName
  type: string
  default: 'drop'

- name: artifactBuildType
  type: string
  default: 'specific'   # current | specific

- name: artifactProject
  type: string
  default: '$(System.TeamProject)'

- name: artifactDefinitionId
  type: string
  default: ''           # Build pipeline definition ID when buildType = specific

- name: artifactBranch
  type: string
  default: ''

- name: artifactDownloadPath
  type: string
  default: '$(Pipeline.Workspace)'

- name: zipName
  type: string

- name: siteName
  type: string

- name: appPoolName
  type: string

- name: iisTargetPath
  type: string

- name: cleanTargetBeforeCopy
  type: boolean
  default: true

- name: cleanExcludeCsv
  type: string
  default: 'web.config,logs,Keys'

- name: enableJsonTransform
  type: boolean
  default: true

- name: jsonFiles
  type: string
  default: '**/appsettings.json'

- name: enableXmlConfigTransform
  type: boolean
  default: false

- name: xmlConfigFiles
  type: object
  default: []

- name: xmlVariableValues
  type: object
  default: {}

- name: enableCustomXmlEdits
  type: boolean
  default: false

- name: customXmlEdits
  type: object
  default: []

- name: customXmlVariableValues
  type: object
  default: {}

# Health check / rollback / tagging
- name: enableHealthCheck
  type: boolean
  default: false

- name: healthCheckUrl
  type: string
  default: ''

- name: healthCheckExpectedStatusCode
  type: string
  default: '200'

- name: healthCheckRetries
  type: number
  default: 6

- name: healthCheckDelaySeconds
  type: number
  default: 10

- name: enableRollbackOnHealthCheckFailure
  type: boolean
  default: true

- name: rollbackTag
  type: string
  default: 'LKG-SIT'

- name: tagSuccessfulBuild
  type: boolean
  default: true

jobs:
- deployment: ${{ parameters.deploymentName }}
  displayName: ${{ parameters.deploymentDisplayName }}

  environment: ${{ parameters.environmentName }}

  pool:
    name: ${{ parameters.deployPool }}
    demands:
    - Agent.Name -equals ${{ parameters.deployAgentName }}

  variables:
  - group: ${{ parameters.variableGroup }}

  strategy:
    runOnce:
      deploy:
        steps:
        - task: DownloadBuildArtifacts@0
          name: DownloadRequestedArtifact
          displayName: 'Download requested build artifact'
          inputs:
            buildType: '${{ parameters.artifactBuildType }}'
            project: '${{ parameters.artifactProject }}'
            pipeline: '${{ parameters.artifactDefinitionId }}'
            buildVersionToDownload: 'latestFromBranch'
            branchName: '${{ parameters.artifactBranch }}'
            downloadType: 'single'
            artifactName: '${{ parameters.artifactName }}'
            downloadPath: '${{ parameters.artifactDownloadPath }}'

        - task: ExtractFiles@1
          displayName: 'Extract requested artifact'
          inputs:
            archiveFilePatterns: '${{ parameters.artifactDownloadPath }}\${{ parameters.artifactName }}\${{ parameters.zipName }}'
            destinationFolder: '$(Pipeline.Workspace)\extracted'
            cleanDestinationFolder: true

        - task: FileTransform@2
          displayName: 'JSON substitution (appsettings.json)'
          condition: and(succeeded(), eq('${{ parameters.enableJsonTransform }}','true'))
          inputs:
            folderPath: '$(Pipeline.Workspace)\extracted'
            enableXmlTransform: false
            xmlTransformationRules: ''
            jsonTargetFiles: ${{ parameters.jsonFiles }}

        - powershell: |
            $ErrorActionPreference = "Stop"
            $root = "$(Pipeline.Workspace)\extracted"

            $patternsJson = @'
            ${{ convertToJson(parameters.xmlConfigFiles) }}
            '@
            $patterns = $patternsJson | ConvertFrom-Json

            if (-not $patterns -or $patterns.Count -eq 0) {
              Write-Host "No xmlConfigFiles patterns provided. Skipping."
              exit 0
            }

            function Resolve-Files([string]$base, [string]$pattern) {
              $pattern = $pattern -replace '\\','/'

              if ($pattern.StartsWith("**/")) {
                $name = $pattern.Substring(3)
                return Get-ChildItem $base -Recurse -File | Where-Object { $_.Name -ieq $name }
              }

              if ($pattern.Contains("/") -or $pattern.Contains("\")) {
                $p = Join-Path $base ($pattern -replace '/','\')
                return Get-Item $p -ErrorAction SilentlyContinue
              }

              return Get-ChildItem $base -Recurse -File | Where-Object { $_.Name -ieq $pattern }
            }

            $files = @()
            foreach ($pat in $patterns) {
              $files += Resolve-Files $root ([string]$pat)
            }
            $files = $files | Where-Object { $_ } | Select-Object -Unique

            if (-not $files -or $files.Count -eq 0) {
              throw "No config files matched xmlConfigFiles patterns under: $root"
            }

            foreach ($f in $files) {
              Write-Host "Editing: $($f.FullName)"
              [xml]$xml = Get-Content -Raw -Path $f.FullName

              $nodes = $xml.SelectNodes("/configuration/appSettings/add[@key]")
              if (-not $nodes -or $nodes.Count -eq 0) {
                Write-Host "No /configuration/appSettings/add nodes found in $($f.Name). Skipping."
                continue
              }

              $changed = 0

              foreach ($n in $nodes) {
                $key = [string]$n.GetAttribute("key")
                $val = (Get-Item "Env:$key" -ErrorAction SilentlyContinue).Value

                if ([string]::IsNullOrWhiteSpace($val)) { continue }

                $current = [string]$n.GetAttribute("value")
                if ($current -ne $val) {
                  $n.SetAttribute("value", $val)
                  $changed++
                }
              }

              $xml.Save($f.FullName)
              Write-Host "Updated $changed setting(s) in $($f.Name)"
            }
          displayName: 'XML appSettings substitution (.config)'
          condition: and(succeeded(), eq('${{ parameters.enableXmlConfigTransform }}','true'))
          env:
            ${{ each pair in parameters.xmlVariableValues }}:
              ${{ pair.key }}: ${{ pair.value }}

        - powershell: |
            $ErrorActionPreference = "Stop"
            $root = "$(Pipeline.Workspace)\extracted"

            $rulesJson = @'
            ${{ convertToJson(parameters.customXmlEdits) }}
            '@
            $rules = $rulesJson | ConvertFrom-Json

            if (-not $rules -or $rules.Count -eq 0) {
              Write-Host "No custom XML edits provided. Skipping."
              exit 0
            }

            function Resolve-Files($base, $pattern) {
              $pattern = $pattern -replace '\\','/'
              if ($pattern.StartsWith("**/")) {
                $name = $pattern.Substring(3)
                return Get-ChildItem $base -Recurse -File | Where-Object { $_.Name -ieq $name }
              }
              if ($pattern.Contains("/") -or $pattern.Contains("\")) {
                $p = Join-Path $base ($pattern -replace '/','\')
                return Get-Item $p -ErrorAction SilentlyContinue
              }
              return Get-ChildItem $base -Recurse -File | Where-Object { $_.Name -ieq $pattern }
            }

            foreach ($r in $rules) {
              $filePat = [string]$r.file
              $xpath   = [string]$r.xpath
              $varName = [string]$r.variable

              if (-not $filePat -or -not $xpath -or -not $varName) {
                throw "Rule must contain file, xpath, variable. Rule=$($r | ConvertTo-Json -Compress)"
              }

              $value = (Get-Item "Env:$varName" -ErrorAction SilentlyContinue).Value
              if ([string]::IsNullOrWhiteSpace($value)) {
                throw "Pipeline variable '$varName' is missing/empty."
              }

              $files = Resolve-Files $root $filePat
              if (-not $files) { throw "No files matched '$filePat' under '$root'." }

              foreach ($f in @($files)) {
                [xml]$xml = Get-Content -Raw -Path $f.FullName

                if ($xpath -match "/@([^/]+)$") {
                  $attrName = $Matches[1]
                  $nodePath = $xpath -replace "/@[^/]+$",""
                  $node = $xml.SelectSingleNode($nodePath)
                  if (-not $node) { throw "Node not found: $nodePath in $($f.FullName)" }

                  $attr = $node.Attributes[$attrName]
                  if (-not $attr) {
                    $attr = $xml.CreateAttribute($attrName)
                    [void]$node.Attributes.Append($attr)
                  }
                  $attr.Value = $value
                } else {
                  $node = $xml.SelectSingleNode($xpath)
                  if (-not $node) { throw "Node not found: $xpath in $($f.FullName)" }
                  $node.InnerText = $value
                }

                $xml.Save($f.FullName)
                Write-Host "Updated $($f.Name): $xpath (from $varName)"
              }
            }
          displayName: 'Custom XML substitution (XPath)'
          condition: and(succeeded(), eq('${{ parameters.enableCustomXmlEdits }}','true'))
          env:
            ${{ each pair in parameters.customXmlVariableValues }}:
              ${{ pair.key }}: ${{ pair.value }}

        - powershell: |
            Import-Module WebAdministration

            $siteName = "${{ parameters.siteName }}"
            $appPool  = "${{ parameters.appPoolName }}"

            $site = Get-Website -Name $siteName
            Write-Host "Website current state: $($site.State)"
            if ($site.State -ne "Stopped") {
              Write-Host "Stopping website: $siteName"
              Stop-Website -Name $siteName
            } else {
              Write-Host "Website already stopped."
            }

            $poolState = (Get-WebAppPoolState -Name $appPool).Value
            Write-Host "AppPool current state: $poolState"
            if ($poolState -ne "Stopped") {
              Write-Host "Stopping app pool: $appPool"
              Stop-WebAppPool -Name $appPool
            } else {
              Write-Host "AppPool already stopped."
            }

            $maxTries = 30
            for ($i = 1; $i -le $maxTries; $i++) {
              $siteState = (Get-Website -Name $siteName).State
              $poolState = (Get-WebAppPoolState -Name $appPool).Value

              Write-Host "Website state: $siteState | AppPool state: $poolState"

              if ($siteState -eq "Stopped" -and $poolState -eq "Stopped") {
                Write-Host "Website and App Pool are stopped."
                break
              }

              Start-Sleep -Seconds 2
            }

            $finalSiteState = (Get-Website -Name $siteName).State
            $finalPoolState = (Get-WebAppPoolState -Name $appPool).Value

            if ($finalSiteState -ne "Stopped" -or $finalPoolState -ne "Stopped") {
              throw "Failed to stop Website/AppPool. Final states => Website: $finalSiteState | AppPool: $finalPoolState"
            }

            Start-Sleep -Seconds 2
          displayName: 'Stop Website + App Pool'

        - powershell: |
            $target = '${{ parameters.iisTargetPath }}'

            if (-not (Test-Path $target)) {
              throw "Target folder does not exist: $target"
            }

            $excludeCsv = '${{ parameters.cleanExcludeCsv }}'.Trim()
            $exclude = @()

            if ($excludeCsv) {
              $exclude = $excludeCsv.Split(',') | ForEach-Object { $_.Trim() } | Where-Object { $_ }
            }

            Write-Host "Cleaning target folder: $target"
            Write-Host "Excluding: $($exclude -join ', ')"

            Get-ChildItem -Path $target -Force | ForEach-Object {
              if ($exclude -contains $_.Name) {
                Write-Host "Skipping excluded item: $($_.FullName)"
              } else {
                Write-Host "Removing: $($_.FullName)"
                Remove-Item -LiteralPath $_.FullName -Recurse -Force -ErrorAction Stop
              }
            }
          displayName: 'Clean target folder (before copy)'
          condition: and(succeeded(), eq('${{ parameters.cleanTargetBeforeCopy }}','true'))

        - task: CopyFiles@2
          displayName: 'Copy files'
          inputs:
            SourceFolder: '$(Pipeline.Workspace)\extracted'
            Contents: '**'
            TargetFolder: '${{ parameters.iisTargetPath }}'
            OverWrite: true

        - powershell: |
            Import-Module WebAdministration

            $siteName = "${{ parameters.siteName }}"
            $appPool  = "${{ parameters.appPoolName }}"

            $poolState = (Get-WebAppPoolState -Name $appPool).Value
            if ($poolState -ne "Started") {
              Write-Host "Starting app pool: $appPool"
              Start-WebAppPool -Name $appPool
            } else {
              Write-Host "AppPool already started."
            }

            $siteState = (Get-Website -Name $siteName).State
            if ($siteState -ne "Started") {
              Write-Host "Starting website: $siteName"
              Start-Website -Name $siteName
            } else {
              Write-Host "Website already started."
            }

            $siteState = (Get-Website -Name $siteName).State
            $poolState = (Get-WebAppPoolState -Name $appPool).Value
            Write-Host "Website state: $siteState | AppPool state: $poolState"
          displayName: 'Start Website + App Pool'

        - powershell: |
            $ErrorActionPreference = "Stop"

            if ('${{ parameters.enableHealthCheck }}' -ne 'true') {
              Write-Host "Health check disabled."
              exit 0
            }

            if ([string]::IsNullOrWhiteSpace('${{ parameters.healthCheckUrl }}')) {
              throw "enableHealthCheck=true but healthCheckUrl is empty."
            }

            $url = '${{ parameters.healthCheckUrl }}'
            $expected = [int]'${{ parameters.healthCheckExpectedStatusCode }}'
            $retries = [int]'${{ parameters.healthCheckRetries }}'
            $delay = [int]'${{ parameters.healthCheckDelaySeconds }}'
            $passed = $false

            for ($i = 1; $i -le $retries; $i++) {
              try {
                Write-Host "Health check attempt $i/$retries => $url"
                $response = Invoke-WebRequest -Uri $url -Method Get -UseBasicParsing -TimeoutSec 30
                $statusCode = [int]$response.StatusCode
                Write-Host "Health check status code: $statusCode"

                if ($statusCode -eq $expected) {
                  $passed = $true
                  break
                }
              }
              catch {
                Write-Host "Health check failed on attempt ${i}: $($_.Exception.Message)"
              }

              if ($i -lt $retries) {
                Start-Sleep -Seconds $delay
              }
            }

            if (-not $passed) {
              Write-Host "##vso[task.setvariable variable=RollbackRequested]true"
              throw "Health check failed after $retries attempt(s)."
            }

            Write-Host "##vso[task.setvariable variable=RollbackRequested]false"
            Write-Host "Health check passed."
          displayName: 'Health check'
          condition: and(succeeded(), eq('${{ parameters.enableHealthCheck }}','true'))

        - powershell: |
            $ErrorActionPreference = "Stop"

            if ('${{ parameters.tagSuccessfulBuild }}' -ne 'true') {
              Write-Host "Tagging disabled."
              exit 0
            }

            $buildId = "$(DownloadRequestedArtifact.BuildNumber)"
            $tag     = '${{ parameters.rollbackTag }}'.Trim()

            if ([string]::IsNullOrWhiteSpace($buildId)) {
              throw "Source build id is empty."
            }

            if ([string]::IsNullOrWhiteSpace($tag)) {
              throw "rollbackTag is empty before calling the Build Tag API."
            }

            $collectionUri = "$(System.CollectionUri)".TrimEnd('/')
            $projectName   = [System.Uri]::EscapeDataString("$(System.TeamProject)")
            $tagEscaped    = [System.Uri]::EscapeDataString($tag)
            $apiVersion    = "7.0"

            $uri = '{0}/{1}/_apis/build/builds/{2}/tags/{3}?api-version={4}' -f `
              $collectionUri,
              $projectName,
              $buildId,
              $tagEscaped,
              $apiVersion

            Write-Host "Resolved tag     : [$tag]"
            Write-Host "Resolved build id: [$buildId]"
            Write-Host "URI              : [$uri]"

            $headers = @{
              Authorization = "Bearer $env:SYSTEM_ACCESSTOKEN"
            }

            Invoke-RestMethod -Method Put -Uri $uri -Headers $headers | Out-Null
            Write-Host "Tagged source build successfully."
          displayName: 'Tag source build as last known good'
          condition: succeeded()
          env:
            SYSTEM_ACCESSTOKEN: $(System.AccessToken)

        - task: DownloadBuildArtifacts@0
          name: DownloadRollbackArtifact
          displayName: 'Download rollback artifact (last known good)'
          condition: and(failed(), eq(variables['RollbackRequested'], 'true'), eq('${{ parameters.enableRollbackOnHealthCheckFailure }}','true'))
          inputs:
            buildType: 'specific'
            project: '${{ parameters.artifactProject }}'
            pipeline: '${{ parameters.artifactDefinitionId }}'
            buildVersionToDownload: 'latestFromBranch'
            branchName: '${{ parameters.artifactBranch }}'
            tags: '${{ parameters.rollbackTag }}'
            downloadType: 'single'
            artifactName: '${{ parameters.artifactName }}'
            downloadPath: '$(Pipeline.Workspace)\rollback-download'

        - powershell: |
            $ErrorActionPreference = "Stop"
            $zip = '$(Pipeline.Workspace)\rollback-download\${{ parameters.artifactName }}\${{ parameters.zipName }}'

            if (Test-Path $zip) {
              Write-Host "Rollback zip found: $zip"
              Write-Host "##vso[task.setvariable variable=RollbackZipReady]true"
            } else {
              Write-Host "##vso[task.setvariable variable=RollbackZipReady]false"
              throw "Rollback artifact download failed or expected zip not found: $zip"
            }
          displayName: 'Validate rollback artifact download'
          condition: and(failed(), eq(variables['RollbackRequested'], 'true'), eq('${{ parameters.enableRollbackOnHealthCheckFailure }}','true'))

        - task: ExtractFiles@1
          displayName: 'Extract rollback artifact'
          condition: and(failed(), eq(variables['RollbackRequested'], 'true'), eq(variables['RollbackZipReady'], 'true'), eq('${{ parameters.enableRollbackOnHealthCheckFailure }}','true'))
          inputs:
            archiveFilePatterns: '$(Pipeline.Workspace)\rollback-download\${{ parameters.artifactName }}\${{ parameters.zipName }}'
            destinationFolder: '$(Pipeline.Workspace)\rollback-extracted'
            cleanDestinationFolder: true

        - powershell: |
            $ErrorActionPreference = "Stop"
            $folder = '$(Pipeline.Workspace)\rollback-extracted'

            if ((Test-Path $folder) -and (Get-ChildItem -Path $folder -Force | Measure-Object).Count -gt 0) {
              Write-Host "Rollback extraction is valid."
              Write-Host "##vso[task.setvariable variable=RollbackExtractReady]true"
            } else {
              Write-Host "##vso[task.setvariable variable=RollbackExtractReady]false"
              throw "Rollback extraction folder is missing or empty: $folder"
            }
          displayName: 'Validate rollback extraction'
          condition: and(failed(), eq(variables['RollbackRequested'], 'true'), eq(variables['RollbackZipReady'], 'true'), eq('${{ parameters.enableRollbackOnHealthCheckFailure }}','true'))

        - powershell: |
            Import-Module WebAdministration

            $siteName = "${{ parameters.siteName }}"
            $appPool  = "${{ parameters.appPoolName }}"

            $site = Get-Website -Name $siteName
            if ($site.State -ne "Stopped") {
              Write-Host "Stopping website for rollback: $siteName"
              Stop-Website -Name $siteName
            }

            $poolState = (Get-WebAppPoolState -Name $appPool).Value
            if ($poolState -ne "Stopped") {
              Write-Host "Stopping app pool for rollback: $appPool"
              Stop-WebAppPool -Name $appPool
            }

            Start-Sleep -Seconds 2
          displayName: 'Stop Website + App Pool for rollback'
          condition: and(failed(), eq(variables['RollbackRequested'], 'true'), eq(variables['RollbackExtractReady'], 'true'), eq('${{ parameters.enableRollbackOnHealthCheckFailure }}','true'))

        - powershell: |
            $target = '${{ parameters.iisTargetPath }}'

            if (-not (Test-Path $target)) {
              throw "Target folder does not exist: $target"
            }

            $excludeCsv = '${{ parameters.cleanExcludeCsv }}'.Trim()
            $exclude = @()

            if ($excludeCsv) {
              $exclude = $excludeCsv.Split(',') | ForEach-Object { $_.Trim() } | Where-Object { $_ }
            }

            Write-Host "Cleaning target folder for rollback: $target"
            Write-Host "Excluding: $($exclude -join ', ')"

            Get-ChildItem -Path $target -Force | ForEach-Object {
              if ($exclude -contains $_.Name) {
                Write-Host "Skipping excluded item: $($_.FullName)"
              } else {
                Write-Host "Removing: $($_.FullName)"
                Remove-Item -LiteralPath $_.FullName -Recurse -Force -ErrorAction Stop
              }
            }
          displayName: 'Clean target folder for rollback'
          condition: and(failed(), eq(variables['RollbackRequested'], 'true'), eq(variables['RollbackExtractReady'], 'true'), eq('${{ parameters.enableRollbackOnHealthCheckFailure }}','true'))

        - task: CopyFiles@2
          displayName: 'Restore rollback files'
          condition: and(failed(), eq(variables['RollbackRequested'], 'true'), eq(variables['RollbackExtractReady'], 'true'), eq('${{ parameters.enableRollbackOnHealthCheckFailure }}','true'))
          inputs:
            SourceFolder: '$(Pipeline.Workspace)\rollback-extracted'
            Contents: '**'
            TargetFolder: '${{ parameters.iisTargetPath }}'
            OverWrite: true

        - powershell: |
            Import-Module WebAdministration

            $siteName = "${{ parameters.siteName }}"
            $appPool  = "${{ parameters.appPoolName }}"

            $poolState = (Get-WebAppPoolState -Name $appPool).Value
            if ($poolState -ne "Started") {
              Start-WebAppPool -Name $appPool
            }

            $siteState = (Get-Website -Name $siteName).State
            if ($siteState -ne "Started") {
              Start-Website -Name $siteName
            }

            $siteState = (Get-Website -Name $siteName).State
            $poolState = (Get-WebAppPoolState -Name $appPool).Value
            Write-Host "After rollback => Website state: $siteState | AppPool state: $poolState"
          displayName: 'Start Website + App Pool after rollback'
          condition: and(failed(), eq(variables['RollbackRequested'], 'true'), eq(variables['RollbackExtractReady'], 'true'), eq('${{ parameters.enableRollbackOnHealthCheckFailure }}','true'))

        - powershell: |
            throw "Deployment failed health check. Rollback was executed successfully."
          displayName: 'Fail deployment after rollback'
          condition: and(failed(), eq(variables['RollbackRequested'], 'true'), eq(variables['RollbackExtractReady'], 'true'), eq('${{ parameters.enableRollbackOnHealthCheckFailure }}','true'))

        - powershell: |
            throw "Deployment failed health check, but no valid rollback artifact was available. Rollback destructive steps were skipped to avoid deleting the IIS app."
          displayName: 'Fail safely when rollback artifact is unavailable'
          condition: and(failed(), eq(variables['RollbackRequested'], 'true'), ne(variables['RollbackExtractReady'], 'true'), eq('${{ parameters.enableRollbackOnHealthCheckFailure }}','true'))

deploy-windows-service.yml:
parameters:
- name: deploymentName
  type: string
  default: 'DeployJob'

- name: deploymentDisplayName
  type: string
  default: 'Deploy Windows Service'

- name: environmentName
  type: string

- name: deployPool
  type: string

- name: deployAgentName
  type: string

- name: variableGroup
  type: string

- name: artifactName
  type: string
  default: 'drop'

- name: artifactBuildType
  type: string
  default: 'specific'   # current | specific

- name: artifactProject
  type: string
  default: '$(System.TeamProject)'

- name: artifactDefinitionId
  type: string
  default: ''           # Build pipeline definition ID when buildType = specific

- name: artifactBranch
  type: string
  default: 'refs/heads/sit'

- name: artifactDownloadPath
  type: string
  default: '$(Pipeline.Workspace)'

- name: zipName
  type: string

- name: serviceName
  type: string

- name: serviceDisplayName
  type: string
  default: ''

- name: serviceDescription
  type: string
  default: ''

- name: serviceTargetPath
  type: string

- name: serviceUser
  type: string
  default: ''

- name: servicePassword
  type: string
  default: ''

- name: createServiceIfMissing
  type: boolean
  default: true

- name: updateBinPathIfExists
  type: boolean
  default: true

- name: serviceExeName
  type: string

- name: serviceStartType
  type: string
  default: 'auto'

- name: cleanTargetBeforeCopy
  type: boolean
  default: true

- name: cleanExcludeCsv
  type: string
  default: 'logs,Keys'

- name: enableJsonTransform
  type: boolean
  default: true

- name: jsonFiles
  type: string
  default: '**/appsettings.json'

- name: enableXmlConfigTransform
  type: boolean
  default: false

- name: xmlConfigFiles
  type: object
  default: []

- name: xmlVariableValues
  type: object
  default: {}

- name: enableCustomXmlEdits
  type: boolean
  default: false

- name: customXmlEdits
  type: object
  default: []

- name: customXmlVariableValues
  type: object
  default: {}

jobs:
- deployment: ${{ parameters.deploymentName }}
  displayName: ${{ parameters.deploymentDisplayName }}

  environment: ${{ parameters.environmentName }}

  pool:
    name: ${{ parameters.deployPool }}
    demands:
    - Agent.Name -equals ${{ parameters.deployAgentName }}

  variables:
  - group: ${{ parameters.variableGroup }}

  strategy:
    runOnce:
      deploy:
        steps:
        - task: DownloadBuildArtifacts@0
          displayName: 'Download Build Artifact'
          inputs:
            buildType: '${{ parameters.artifactBuildType }}'
            project: '${{ parameters.artifactProject }}'
            pipeline: '${{ parameters.artifactDefinitionId }}'
            buildVersionToDownload: 'latestFromBranch'
            branchName: '${{ parameters.artifactBranch }}'
            downloadType: 'single'
            artifactName: '${{ parameters.artifactName }}'
            downloadPath: '${{ parameters.artifactDownloadPath }}'

        - task: ExtractFiles@1
          displayName: 'Extract artifact'
          inputs:
            archiveFilePatterns: '${{ parameters.artifactDownloadPath }}\${{ parameters.artifactName }}\${{ parameters.zipName }}'
            destinationFolder: '$(Pipeline.Workspace)\extracted'
            cleanDestinationFolder: true

        - task: FileTransform@2
          displayName: 'JSON substitution (appsettings.json)'
          condition: and(succeeded(), eq('${{ parameters.enableJsonTransform }}','true'))
          inputs:
            folderPath: '$(Pipeline.Workspace)\extracted'
            enableXmlTransform: false
            xmlTransformationRules: ''
            jsonTargetFiles: ${{ parameters.jsonFiles }}

        - powershell: |
            $ErrorActionPreference = "Stop"
            $root = "$(Pipeline.Workspace)\extracted"

            $patternsJson = @'
            ${{ convertToJson(parameters.xmlConfigFiles) }}
            '@
            $patterns = $patternsJson | ConvertFrom-Json

            if (-not $patterns -or $patterns.Count -eq 0) {
              Write-Host "No xmlConfigFiles patterns provided. Skipping."
              exit 0
            }

            function Resolve-Files([string]$base, [string]$pattern) {
              $pattern = $pattern -replace '\\','/'

              if ($pattern.StartsWith("**/")) {
                $name = $pattern.Substring(3)
                return Get-ChildItem $base -Recurse -File | Where-Object { $_.Name -ieq $name }
              }

              if ($pattern.Contains("/") -or $pattern.Contains("\")) {
                $p = Join-Path $base ($pattern -replace '/','\')
                return Get-Item $p -ErrorAction SilentlyContinue
              }

              return Get-ChildItem $base -Recurse -File | Where-Object { $_.Name -ieq $pattern }
            }

            # collect unique files
            $files = @()
            foreach ($pat in $patterns) {
              $files += Resolve-Files $root ([string]$pat)
            }
            $files = $files | Where-Object { $_ } | Select-Object -Unique

            if (-not $files -or $files.Count -eq 0) {
              throw "No config files matched xmlConfigFiles patterns under: $root"
            }

            foreach ($f in $files) {
              Write-Host "Editing: $($f.FullName)"
              [xml]$xml = Get-Content -Raw -Path $f.FullName

              $nodes = $xml.SelectNodes("/configuration/appSettings/add[@key]")
              if (-not $nodes -or $nodes.Count -eq 0) {
                Write-Host "No /configuration/appSettings/add nodes found in $($f.Name). Skipping."
                continue
              }

              $changed = 0

              foreach ($n in $nodes) {
                $key = [string]$n.GetAttribute("key")
                $val = (Get-Item "Env:$key" -ErrorAction SilentlyContinue).Value

                # no variable provided => skip
                if ([string]::IsNullOrWhiteSpace($val)) { continue }

                $current = [string]$n.GetAttribute("value")
                if ($current -ne $val) {
                  $n.SetAttribute("value", $val)
                  $changed++
                }
              }

              $xml.Save($f.FullName)
              Write-Host "Updated $changed setting(s) in $($f.Name)"
            }
          displayName: 'XML appSettings substitution (.config)'
          condition: and(succeeded(), eq('${{ parameters.enableXmlConfigTransform }}','true'))
          env:
            ${{ each pair in parameters.xmlVariableValues }}:
              ${{ pair.key }}: ${{ pair.value }}

        # ---- Custom XML substitution (XPath) ----
        - powershell: |
            $ErrorActionPreference = "Stop"
            $root = "$(Pipeline.Workspace)\extracted"

            $rulesJson = @'
            ${{ convertToJson(parameters.customXmlEdits) }}
            '@
            $rules = $rulesJson | ConvertFrom-Json

            if (-not $rules -or $rules.Count -eq 0) {
              Write-Host "No custom XML edits provided. Skipping."
              exit 0
            }

            function Resolve-Files($base, $pattern) {
              # supports: **/File.xml, File.xml, or folder\File.xml
              $pattern = $pattern -replace '\\','/'
              if ($pattern.StartsWith("**/")) {
                $name = $pattern.Substring(3)
                return Get-ChildItem $base -Recurse -File | Where-Object { $_.Name -ieq $name }
              }
              if ($pattern.Contains("/") -or $pattern.Contains("\")) {
                $p = Join-Path $base ($pattern -replace '/','\')
                return Get-Item $p -ErrorAction SilentlyContinue
              }
              return Get-ChildItem $base -Recurse -File | Where-Object { $_.Name -ieq $pattern }
            }

            foreach ($r in $rules) {
              $filePat = [string]$r.file
              $xpath   = [string]$r.xpath
              $varName = [string]$r.variable

              if (-not $filePat -or -not $xpath -or -not $varName) {
                throw "Rule must contain file, xpath, variable. Rule=$($r | ConvertTo-Json -Compress)"
              }

              $value = (Get-Item "Env:$varName" -ErrorAction SilentlyContinue).Value
              if ([string]::IsNullOrWhiteSpace($value)) {
                throw "Pipeline variable '$varName' is missing/empty."
              }

              $files = Resolve-Files $root $filePat
              if (-not $files) { throw "No files matched '$filePat' under '$root'." }

              foreach ($f in @($files)) {
                [xml]$xml = Get-Content -Raw -Path $f.FullName

                if ($xpath -match "/@([^/]+)$") {
                  $attrName = $Matches[1]
                  $nodePath = $xpath -replace "/@[^/]+$",""
                  $node = $xml.SelectSingleNode($nodePath)
                  if (-not $node) { throw "Node not found: $nodePath in $($f.FullName)" }

                  $attr = $node.Attributes[$attrName]
                  if (-not $attr) {
                    $attr = $xml.CreateAttribute($attrName)
                    [void]$node.Attributes.Append($attr)
                  }
                  $attr.Value = $value
                } else {
                  $node = $xml.SelectSingleNode($xpath)
                  if (-not $node) { throw "Node not found: $xpath in $($f.FullName)" }
                  $node.InnerText = $value
                }

                $xml.Save($f.FullName)
                Write-Host "Updated $($f.Name): $xpath (from $varName)"
              }
            }
          displayName: 'Custom XML substitution (XPath)'
          condition: and(succeeded(), eq('${{ parameters.enableCustomXmlEdits }}','true'))
          env:
            ${{ each pair in parameters.customXmlVariableValues }}:
              ${{ pair.key }}: ${{ pair.value }}

        # Stop Windows Service safely (idempotent)
        - powershell: |
            $ErrorActionPreference = "Stop"
            $svcName = "${{ parameters.serviceName }}"

            $svc = Get-Service -Name $svcName -ErrorAction SilentlyContinue
            if (-not $svc) {
              Write-Host "Service '$svcName' not found. Nothing to stop."
              exit 0
            }

            Write-Host "Service current status: $($svc.Status)"
            if ($svc.Status -ne "Stopped") {
              Write-Host "Stopping service: $svcName"
              Stop-Service -Name $svcName -Force -ErrorAction Stop
            } else {
              Write-Host "Service already stopped."
            }

            $maxTries = 30
            for ($i=1; $i -le $maxTries; $i++) {
              $status = (Get-Service -Name $svcName).Status
              Write-Host "Service status: $status"
              if ($status -eq "Stopped") {
                Write-Host "Service is stopped."
                break
              }
              Start-Sleep -Seconds 2
            }

            $final = (Get-Service -Name $svcName).Status
            if ($final -ne "Stopped") {
              throw "Failed to stop service '$svcName'. Final status: $final"
            }

            Start-Sleep -Seconds 2
          displayName: 'Stop Windows Service'

        - powershell: |
            $target = '${{ parameters.serviceTargetPath }}'

            if (-not (Test-Path $target)) {
              throw "Target folder does not exist: $target"
            }

            $excludeCsv = '${{ parameters.cleanExcludeCsv }}'.Trim()
            $exclude = @()

            if ($excludeCsv) {
              $exclude = $excludeCsv.Split(',') | ForEach-Object { $_.Trim() } | Where-Object { $_ }
            }

            Write-Host "Cleaning target folder: $target"
            Write-Host "Excluding: $($exclude -join ', ')"

            Get-ChildItem -Path $target -Force | ForEach-Object {
              if ($exclude -contains $_.Name) {
                Write-Host "Skipping excluded item: $($_.FullName)"
              } else {
                Write-Host "Removing: $($_.FullName)"
                Remove-Item -LiteralPath $_.FullName -Recurse -Force -ErrorAction Stop
              }
            }
          displayName: 'Clean target folder (before copy)'
          condition: and(succeeded(), eq('${{ parameters.cleanTargetBeforeCopy }}','true'))

        - task: CopyFiles@2
          displayName: 'Copy files'
          inputs:
            SourceFolder: '$(Pipeline.Workspace)\extracted'
            Contents: '**'
            TargetFolder: '${{ parameters.serviceTargetPath }}'
            OverWrite: true

        # Create or update Windows Service to point to the deployed EXE
        - powershell: |
            $ErrorActionPreference = "Stop"

            $svcName   = "${{ parameters.serviceName }}"
            $exeName   = "${{ parameters.serviceExeName }}"
            $targetDir = "${{ parameters.serviceTargetPath }}"
            $exePath   = Join-Path $targetDir $exeName

            if (-not (Test-Path $exePath)) {
              throw "Service executable not found: $exePath"
            }

            $displayName = "${{ parameters.serviceDisplayName }}"
            if ([string]::IsNullOrWhiteSpace($displayName)) { $displayName = $svcName }

            $desc = "${{ parameters.serviceDescription }}"
            $startType = "${{ parameters.serviceStartType }}"  # auto|demand|disabled

            $user = "${{ parameters.serviceUser }}"
            $pass = "${{ parameters.servicePassword }}"

            $existing = Get-Service -Name $svcName -ErrorAction SilentlyContinue

            function Set-StartType([string]$name, [string]$st) {
              switch ($st.ToLowerInvariant()) {
                "auto"     { sc.exe config $name start= auto    | Out-Host }
                "demand"   { sc.exe config $name start= demand  | Out-Host }
                "disabled" { sc.exe config $name start= disabled| Out-Host }
                default    { throw "Invalid serviceStartType: $st (use auto|demand|disabled)" }
              }
            }

            if (-not $existing) {
              if ('${{ parameters.createServiceIfMissing }}' -ne 'true') {
                throw "Service '$svcName' does not exist and createServiceIfMissing=false."
              }

              Write-Host "Creating service: $svcName"
              # Important: sc.exe spacing rules (space after '=')
              if (-not [string]::IsNullOrWhiteSpace($user)) {
                if ([string]::IsNullOrWhiteSpace($pass)) { throw "servicePassword is required when serviceUser is set." }

                sc.exe create $svcName binPath= "`"$exePath`"" DisplayName= "`"$displayName`"" start= $startType obj= "`"$user`"" password= "`"$pass`"" | Out-Host
              } else {
                sc.exe create $svcName binPath= "`"$exePath`"" DisplayName= "`"$displayName`"" start= $startType | Out-Host
              }

              if (-not [string]::IsNullOrWhiteSpace($desc)) {
                sc.exe description $svcName "`"$desc`"" | Out-Host
              }
            }
            else {
              Write-Host "Service exists: $svcName"

              if ('${{ parameters.updateBinPathIfExists }}' -eq 'true') {
                Write-Host "Updating binPath to: $exePath"
                # binPath is updated using 'config'
                sc.exe config $svcName binPath= "`"$exePath`"" | Out-Host
              }

              # Keep start type aligned
              Set-StartType $svcName $startType

              if (-not [string]::IsNullOrWhiteSpace($desc)) {
                sc.exe description $svcName "`"$desc`"" | Out-Host
              }

              if (-not [string]::IsNullOrWhiteSpace($user)) {
                if ([string]::IsNullOrWhiteSpace($pass)) { throw "servicePassword is required when serviceUser is set." }
                sc.exe config $svcName obj= "`"$user`"" password= "`"$pass`"" | Out-Host
              }
            }
          displayName: 'Create/Update Windows Service'

        # Start Windows Service safely (idempotent)
        - powershell: |
            $ErrorActionPreference = "Stop"
            $svcName = "${{ parameters.serviceName }}"

            $svc = Get-Service -Name $svcName -ErrorAction SilentlyContinue
            if (-not $svc) { throw "Service '$svcName' not found." }

            if ($svc.Status -ne "Running") {
              Write-Host "Starting service: $svcName"
              Start-Service -Name $svcName -ErrorAction Stop
            } else {
              Write-Host "Service already running."
            }

            $maxTries = 30
            for ($i=1; $i -le $maxTries; $i++) {
              $status = (Get-Service -Name $svcName).Status
              Write-Host "Service status: $status"
              if ($status -eq "Running") {
                Write-Host "Service is running."
                break
              }
              Start-Sleep -Seconds 2
            }

            $final = (Get-Service -Name $svcName).Status
            if ($final -ne "Running") {
              throw "Failed to start service '$svcName'. Final status: $final"
            }
          displayName: 'Start Windows Service'

release-azure-pipelines-sit.yml
parameters:
- name: deployDatabase
  type: boolean
  default: false

- name: deployMvc
  type: boolean
  default: false

- name: deployApi
  type: boolean
  default: false

resources:
  repositories:
  - repository: templates
    type: git
    name: 'Azure Templates/Azure Templates'
    ref: refs/heads/main

trigger: none
pr: none

variables:
- group: SIT_API_VARIABLE_GROUP

stages:

- ${{ if eq(parameters.deployMvc, true) }}:
  - stage: Deploy_MVC_SIT
    displayName: 'Deploy MVC to SIT'
    jobs:
    - template: pipelines/deploy-iis.yml@templates
      parameters:
        deploymentName: 'DeployMVC'
        deploymentDisplayName: 'Deploy MVC to SIT (IIS)'
        environmentName: 'SIT'
        deployPool: 'Deployment Pool'
        deployAgentName: 'SIT-ALTERNA-FN1'
        variableGroup: 'SIT_MVC_VARIABLE_GROUP'
        artifactName: 'mvc-drop'
        artifactBuildType: 'specific'
        artifactProject: '$(System.TeamProject)'
        artifactDefinitionId: '13'
        artifactBranch: 'refs/heads/sit'
        zipName: 'AlternaCardManagementMVC.zip'
        siteName: 'AlternaCardManagement-AzureDevOps'
        appPoolName: 'AlternaCardManagement-AzureDevOps'
        iisTargetPath: 'C:\inetpub\wwwroot\AlternaCardManagement-AzureDevOps-FN1'
        cleanTargetBeforeCopy: true
        cleanExcludeCsv: ''
        enableJsonTransform: false
        jsonFiles: ''
        enableXmlConfigTransform: true
        xmlConfigFiles:
          - '**/Web.config'
        xmlVariableValues:
          BaseUrl: $(BaseUrl)
          BaseUrlOsb: $(BaseUrlOsb)
          CDN_IP_LINK: $(CDN_IP_LINK)
          DASHBOARD_LINK: $(DASHBOARD_LINK)
          GenerateAccountFileImportFileNameChecking: $(GenerateAccountFileImportFileNameChecking)
          GeneratePaymentFileImportFileNameChecking: $(GeneratePaymentFileImportFileNameChecking)
          LDAP_WEB_SERVICES_IP_ADDRESS: $(LDAP_WEB_SERVICES_IP_ADDRESS)
          UploadFilesPath: $(UploadFilesPath)
          USER_GUIDE_LINK: $(USER_GUIDE_LINK)
        enableCustomXmlEdits: false
        customXmlEdits: {}

        enableHealthCheck: true
        healthCheckUrl: 'http://10.0.40.41:8046/api/Host/GetIndividualCustomerRange?fromCustomerId=1&toCustomerId=1'
        healthCheckExpectedStatusCode: '500'
        healthCheckRetries: 6
        healthCheckDelaySeconds: 10
        enableRollbackOnHealthCheckFailure: true
        rollbackTag: 'LKG-SIT-MVC'
        tagSuccessfulBuild: true

- ${{ if eq(parameters.deployApi, true) }}:
  - stage: Deploy_API_SIT
    displayName: 'Deploy API to SIT'
    jobs:
    - template: pipelines/deploy-iis.yml@templates
      parameters:
        deploymentName: 'DeployAPI'
        deploymentDisplayName: 'Deploy API to SIT (IIS)'
        environmentName: 'SIT'
        deployPool: 'Deployment Pool'
        deployAgentName: 'SIT-ALTERNA-BN1'
        variableGroup: 'SIT_API_VARIABLE_GROUP'
        artifactName: 'api-drop'
        artifactBuildType: 'specific'
        artifactProject: '$(System.TeamProject)'
        artifactDefinitionId: '13'
        artifactBranch: 'refs/heads/sit'
        zipName: 'AlternaCardManagementAPI.zip'
        siteName: 'AlternaCardManagement-AzureDevOps'
        appPoolName: 'AlternaCardManagement-AzureDevOps'
        iisTargetPath: 'C:\inetpub\wwwroot\AlternaCardManagement-AzureDevOps-BN1'
        cleanTargetBeforeCopy: true
        cleanExcludeCsv: ''
        enableJsonTransform: false
        jsonFiles: ''
        enableXmlConfigTransform: true
        xmlConfigFiles:
          - '**/Web.config'
        xmlVariableValues:
          BaseUrl: $(BaseUrl)
          BrefBaseUrl: $(BrefBaseUrl)
          CONN_STRING: $(CONN_STRING)
          SMSUrl: $(SMSUrl)
        enableCustomXmlEdits: false
        customXmlEdits: {}

        enableHealthCheck: true
        healthCheckUrl: 'http://10.0.40.41:8046/api/Host/GetIndividualCustomerRange?fromCustomerId=1&toCustomerId=1'
        healthCheckExpectedStatusCode: '200'
        healthCheckRetries: 6
        healthCheckDelaySeconds: 10
        enableRollbackOnHealthCheckFailure: true
        rollbackTag: 'LKG-SIT-API'
        tagSuccessfulBuild: true

- ${{ if eq(parameters.deployDatabase, true) }}:
  - stage: Deploy_DB
    displayName: 'Deploy DB'
    jobs:
    - template: pipelines/deploy-database.yml@templates
      parameters:
        deploymentName: 'DeployDb'
        deploymentDisplayName: 'Deploy database'
        environmentName: 'SIT'
        deployPool: 'Deployment Pool'
        deployAgentName: 'SIT-ALTERNA-BN1'
        artifactName: 'db-drop'
        artifactBuildType: 'specific'
        artifactProject: '$(System.TeamProject)'
        artifactDefinitionId: '18'
        artifactBranch: 'refs/heads/sit'
        targetConnectionString: '$(CONN_STRING)'
