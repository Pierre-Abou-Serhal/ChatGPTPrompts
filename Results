## 3) Update your **SIT pipeline** call to pass the variable values

Add this right next to `customXmlEdits:`:

```yaml
customXmlVariableValues:
  TOKEN_GET_CUSTOMER_APPORTEUR_AFFAIRE: $(TOKEN_GET_CUSTOMER_APPORTEUR_AFFAIRE)
  TOKEN_GET_CUSTOMER_AMS: $(TOKEN_GET_CUSTOMER_AMS)
  TOKEN_GET_CUSTOMER_FRESH_ACCOUNT: $(TOKEN_GET_CUSTOMER_FRESH_ACCOUNT)

  TOKEN_GET_CUSTOMER_APPORTEUR_AFFAIRE_HAVE_ACCESS_TO_GET_AVAILABLE_VARIABLES: $(TOKEN_GET_CUSTOMER_APPORTEUR_AFFAIRE_HAVE_ACCESS_TO_GET_AVAILABLE_VARIABLES)

  TOKEN_GET_COMPANY_APPORTEUR_AFFAIRE: $(TOKEN_GET_COMPANY_APPORTEUR_AFFAIRE)
  TOKEN_GET_T24USER_AMS: $(TOKEN_GET_T24USER_AMS)
  TOKEN_LDAP_PSS: $(TOKEN_LDAP_PSS)
  TOKEN_GET_PRODUCT_FRESH_ACCOUNT: $(TOKEN_GET_PRODUCT_FRESH_ACCOUNT)
```

Full snippet (only the relevant part):

```yaml
enableCustomXmlEdits: true

customXmlVariableValues:
  TOKEN_GET_CUSTOMER_APPORTEUR_AFFAIRE: $(TOKEN_GET_CUSTOMER_APPORTEUR_AFFAIRE)
  TOKEN_GET_CUSTOMER_AMS: $(TOKEN_GET_CUSTOMER_AMS)
  TOKEN_GET_CUSTOMER_FRESH_ACCOUNT: $(TOKEN_GET_CUSTOMER_FRESH_ACCOUNT)
  TOKEN_GET_CUSTOMER_APPORTEUR_AFFAIRE_HAVE_ACCESS_TO_GET_AVAILABLE_VARIABLES: $(TOKEN_GET_CUSTOMER_APPORTEUR_AFFAIRE_HAVE_ACCESS_TO_GET_AVAILABLE_VARIABLES)
  TOKEN_GET_COMPANY_APPORTEUR_AFFAIRE: $(TOKEN_GET_COMPANY_APPORTEUR_AFFAIRE)
  TOKEN_GET_T24USER_AMS: $(TOKEN_GET_T24USER_AMS)
  TOKEN_LDAP_PSS: $(TOKEN_LDAP_PSS)
  TOKEN_GET_PRODUCT_FRESH_ACCOUNT: $(TOKEN_GET_PRODUCT_FRESH_ACCOUNT)

customXmlEdits:
  - file: '**/APITOKEN.xml'
    xpath: '/APITOKEN/GET_CUSTOMER/TOKEN[@APPLICATION_NAME="APPORTEUR_AFFAIRE"]/@VALUE'
    variable: 'TOKEN_GET_CUSTOMER_APPORTEUR_AFFAIRE'
  # ... keep the rest of your rules as-is
```

