This is my Alterna-DataExport API pipeline (SIT - BUILD - API - Alterna-DataExport):
name: DTE_API_SIT_$(Date:yyyyMMdd).$(Rev:r)

resources:
  repositories:
    - repository: templates
      type: git
      name: 'Azure Templates/Azure Templates'
      ref: refs/heads/main

trigger:
  branches:
    include:
      - sit
  paths:
    include:
      - Alterna-DataExport/**

pr: none

stages:
- stage: Build
  displayName: 'Build & Publish Artifact'
  jobs:
  - template: pipelines/build-dotnet-core-webapi.yml@templates
    parameters:
      jobName: 'BuildJob'
      jobDisplayName: 'Build DataExport'
      buildPool: 'Build Pool'
      buildAgentName: 'UAT-ALTERNA-DK1'
      buildConfiguration: 'Release'
      restoreProjects: '**/*.csproj'
      runTests: false
      testProjects: ''
      publishProject: 'Alterna-DataExport/Alterna-DataExport/Alterna-DataExport.csproj'
      nugetConfigPath: 'nuget.config'
      zipName: 'Alterna-DataExport.zip'
      artifactName: 'data-export-api-drop'
      publishOutputFolder: '$(Build.ArtifactStagingDirectory)\Alterna-DataExport'

