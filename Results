## 1) Updated `build-database-project.yml`

You can keep it almost as it is. I’d only make the intent explicit and leave `dacpacFileName` as the build output name.

```yaml
parameters:
- name: jobName
  type: string
  default: 'BuildDatabase'

- name: jobDisplayName
  type: string
  default: 'Build Database Project'

- name: buildPool
  type: string

- name: buildAgentName
  type: string

- name: sqlProjectPath
  type: string

- name: buildConfiguration
  type: string
  default: 'Release'

- name: artifactName
  type: string
  default: 'db-drop'

- name: outputFolder
  type: string
  default: '$(Build.ArtifactStagingDirectory)\db'

- name: dacpacFileName
  type: string
  default: 'database.dacpac'

jobs:
- job: ${{ parameters.jobName }}
  displayName: ${{ parameters.jobDisplayName }}

  pool:
    name: ${{ parameters.buildPool }}
    demands:
    - Agent.Name -equals ${{ parameters.buildAgentName }}

  steps:
  - checkout: self
    clean: true

  - powershell: |
      $ErrorActionPreference = 'Stop'
      dotnet build "${{ parameters.sqlProjectPath }}" -c "${{ parameters.buildConfiguration }}"
    displayName: 'Build SQL project'

  - powershell: |
      $ErrorActionPreference = 'Stop'

      $dacpac = Get-ChildItem "$(Build.SourcesDirectory)" -Recurse -Filter *.dacpac |
                Sort-Object LastWriteTime -Descending |
                Select-Object -First 1

      if (-not $dacpac) {
        throw "No .dacpac found after build."
      }

      New-Item -Path "${{ parameters.outputFolder }}" -ItemType Directory -Force | Out-Null

      $targetDacpac = Join-Path "${{ parameters.outputFolder }}" "${{ parameters.dacpacFileName }}"
      Copy-Item $dacpac.FullName $targetDacpac -Force

      Write-Host "Source DACPAC : $($dacpac.FullName)"
      Write-Host "Target DACPAC : $targetDacpac"
    displayName: 'Collect dacpac'

  - task: PublishBuildArtifacts@1
    displayName: 'Publish DB artifact'
    inputs:
      PathtoPublish: '${{ parameters.outputFolder }}'
      ArtifactName: '${{ parameters.artifactName }}'
      publishLocation: 'Container'
```

