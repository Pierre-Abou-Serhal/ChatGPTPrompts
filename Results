resources:
  repositories:
  - repository: templates
    type: git
    name: 'Azure Templates/Azure Templates'
    ref: refs/heads/main

trigger:
  branches:
    include:
    - sit
    - uat
    - master

stages:
# =========================
# BUILD
# =========================
- stage: Build
  displayName: 'Build Angular & Publish Artifact'
  jobs:
  - template: pipelines/build-angular-webapp.yml@templates
    parameters:
      buildPool: 'Build Pool'
      buildAgentName: 'UAT-ALTERNA-DK1'
      workingDirectory: '.'              # folder containing package.json
      nodeVersion: '22.x'
      installCommand: 'i'
      runTests: false
      buildCommand: 'npx ng build'
      distFolder: 'dist/Alterna-Telecom-Frontend/browser'
      zipName: 'Alterna-Telecom-Frontend.zip'
      publishOutputFolder: '$(Build.ArtifactStagingDirectory)\publish'

# =========================
# DEPLOY SIT
# =========================
- stage: Deploy_SIT
  displayName: 'Deploy to SIT'
  dependsOn: Build
  condition: and(succeeded(), eq(variables['Build.SourceBranch'], 'refs/heads/sit'))
  jobs:
  - template: pipelines/deploy-iis.yml@templates
    parameters:
      deploymentName: 'DeploySIT'
      deploymentDisplayName: 'Deploy SIT (IIS)'
      environmentName: 'SIT'
      deployPool: 'Deployment Pool'
      deployAgentName: 'SIT-ALTERNA-FN1'
      variableGroup: 'SIT_FRONT_END_VARIABLE_GROUP'
      zipName: 'Alterna-Telecom-Frontend.zip'
      siteName: 'AlternaTelecomAzureDevOps'
      appPoolName: 'AlternaTelecomAzureDevOps'
      iisTargetPath: 'C:\inetpub\wwwroot\AlternaTelecomAzureDevOps'
      appSettingsFilePattern: '**/appsettings.json'
      cleanTargetBeforeCopy: true
      cleanExcludeCsv: ''

