PS C:\Windows\System32\WindowsPowerShell\v1.0> # ===== SETTINGS =====
$jdkHome = 'D:\Java\jdk-21.0.10'
$dcBat   = 'C:\Tools\dependency-check\dependency-check-12.2.0\bin\dependency-check.bat'
$dataDir = 'C:\Tools\dependency-check-data'
$logFile = 'C:\Tools\dependency-check-data\odc-update.log'

# Put your real NVD API key here for local use,
# or replace this with a safer method if you prefer.
$nvdApiKey = 'PASTE_YOUR_NVD_API_KEY_HERE'

# ===== JAVA OVERRIDE FOR THIS POWERSHELL SESSION ONLY =====
$env:JAVA_HOME = $jdkHome
$env:PATH = "$jdkHome\bin;$env:PATH"

# ===== BASIC CHECKS =====
if (-not (Test-Path $dcBat)) {
    throw "Dependency-Check CLI not found at: $dcBat"
}

if (-not (Test-Path $dataDir)) {
    New-Item -ItemType Directory -Force -Path $dataDir | Out-Null
}

Write-Host "JAVA_HOME = $env:JAVA_HOME"
Write-Host "Using java:"
Get-Command java | Select-Object Source
java -version

# ===== UPDATE LOCAL DATABASE =====
& $dcBat `
  --updateonly `
  --data "$dataDir" `
  --nvdApiKey "$nvdApiKey" `
  --disableKnownExploited `
  --disableHostedSuppressions `
  --disableRetireJS `
  --disableVersionCheck `
  --log "$logFile"

if ($LASTEXITCODE -ne 0) {
    Write-Host "Dependency-Check update failed. Last log lines:"
    if (Test-Path $logFile) {
        Get-Content $logFile -Tail 200
    }
    exit $LASTEXITCODE
}

Write-Host "Dependency-Check data update completed."
Write-Host "Data folder: $dataDir"
