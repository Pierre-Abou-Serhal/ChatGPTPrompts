stages:

- stage: Resolve_Selected_Builds
  displayName: 'Resolve selected build numbers'
  jobs:
  - job: ResolveBuildNumbers
    displayName: 'Resolve pipeline names and build numbers'
    pool:
      name: '$(deploymentPool)'
      demands:
      - Agent.Name -equals $(resolveAgentName)
    steps:
    - checkout: none

    - powershell: |
        $ErrorActionPreference = 'Stop'

        $collectionUri = "$(System.CollectionUri)".TrimEnd('/')
        $projectName   = [System.Uri]::EscapeDataString("$(System.TeamProject)")
        $apiVersion    = '7.1'
        $allowedBranchPattern = '$(buildSourceBranchRegex)'

        $headers = @{
          Authorization = "Bearer $env:SYSTEM_ACCESSTOKEN"
        }

        $deployMvc = "${{ parameters.deployMvc }}".ToLower() -eq 'true'
        $deployApi = "${{ parameters.deployApi }}".ToLower() -eq 'true'
        $deployDb  = "${{ parameters.deployDatabase }}".ToLower() -eq 'true'

        if (-not ($deployMvc -or $deployApi -or $deployDb)) {
          throw 'At least one deployment target must be selected: MVC, API, or Database.'
        }

        function Resolve-DefinitionIdByName {
          param(
            [string]$Label,
            [string]$PipelineName
          )

          if ([string]::IsNullOrWhiteSpace($PipelineName)) {
            throw "$Label pipeline name is empty."
          }

          $encodedName = [System.Uri]::EscapeDataString($PipelineName)
          $uri = "{0}/{1}/_apis/build/definitions?name={2}&includeAllProperties=false&includeLatestBuilds=false&api-version={3}" -f `
            $collectionUri,
            $projectName,
            $encodedName,
            $apiVersion

          Write-Host "Resolving $Label pipeline name [$PipelineName]"
          $response = Invoke-RestMethod -Method Get -Uri $uri -Headers $headers

          if (-not $response.value -or $response.count -lt 1) {
            throw "No pipeline definition found for $Label with name [$PipelineName]."
          }

          $exactMatches = @($response.value | Where-Object { $_.name -eq $PipelineName })

          if ($exactMatches.Count -eq 0) {
            throw "No exact pipeline definition match found for $Label with name [$PipelineName]."
          }

          if ($exactMatches.Count -gt 1) {
            throw "More than one exact pipeline definition match was found for [$PipelineName]. Make the pipeline name unique."
          }

          $definition = $exactMatches[0]

          Write-Host "$Label definition resolved:"
          Write-Host "  Definition ID   = $($definition.id)"
          Write-Host "  Definition Name = $($definition.name)"

          return $definition.id
        }

        function Resolve-Build {
          param(
            [string]$Label,
            [string]$PipelineName,
            [string]$BuildNumber
          )

          if ([string]::IsNullOrWhiteSpace($BuildNumber) -or $BuildNumber -eq '__EMPTY__') {
            throw "$Label build number is required because deployment of $Label was selected."
          }

          $definitionId = Resolve-DefinitionIdByName -Label $Label -PipelineName $PipelineName
          $encodedBuildNumber = [System.Uri]::EscapeDataString($BuildNumber)

          $uri = "{0}/{1}/_apis/build/builds?definitions={2}&buildNumber={3}&statusFilter=completed&resultFilter=succeeded&`$top=1&queryOrder=finishTimeDescending&api-version={4}" -f `
            $collectionUri,
            $projectName,
            $definitionId,
            $encodedBuildNumber,
            $apiVersion

          Write-Host "Resolving $Label build number [$BuildNumber] using pipeline definition [$definitionId]"
          $response = Invoke-RestMethod -Method Get -Uri $uri -Headers $headers

          if (-not $response.value -or $response.count -lt 1) {
            throw "No succeeded build found for $Label with build number [$BuildNumber] in pipeline [$PipelineName]."
          }

          $build = $response.value[0]

          if ($build.sourceBranch -notmatch $allowedBranchPattern) {
            throw "$Label build [$BuildNumber] was resolved, but it belongs to branch [$($build.sourceBranch)]. Only release/* or hotfix/* builds can be deployed."
          }

          Write-Host "$Label build resolved:"
          Write-Host "  Build ID         = $($build.id)"
          Write-Host "  Build Number     = $($build.buildNumber)"
          Write-Host "  Definition ID    = $definitionId"
          Write-Host "  Definition Name  = $PipelineName"
          Write-Host "  Branch           = $($build.sourceBranch)"

          Write-Host "##vso[task.setvariable variable=${Label}PipelineDefinitionId;isOutput=true]$definitionId"
          Write-Host "##vso[task.setvariable variable=${Label}BuildId;isOutput=true]$($build.id)"
          Write-Host "##vso[task.setvariable variable=${Label}ResolvedBuildNumber;isOutput=true]$($build.buildNumber)"
          Write-Host "##vso[task.setvariable variable=${Label}SourceBranch;isOutput=true]$($build.sourceBranch)"
        }

        if ($deployMvc) {
          Resolve-Build -Label 'Mvc' -PipelineName '$(mvcPipelineName)' -BuildNumber '${{ parameters.mvcBuildNumber }}'
        } else {
          Write-Host '##vso[task.setvariable variable=MvcPipelineDefinitionId;isOutput=true]'
          Write-Host '##vso[task.setvariable variable=MvcBuildId;isOutput=true]'
          Write-Host '##vso[task.setvariable variable=MvcResolvedBuildNumber;isOutput=true]'
          Write-Host '##vso[task.setvariable variable=MvcSourceBranch;isOutput=true]'
        }

        if ($deployApi) {
          Resolve-Build -Label 'Api' -PipelineName '$(apiPipelineName)' -BuildNumber '${{ parameters.apiBuildNumber }}'
        } else {
          Write-Host '##vso[task.setvariable variable=ApiPipelineDefinitionId;isOutput=true]'
          Write-Host '##vso[task.setvariable variable=ApiBuildId;isOutput=true]'
          Write-Host '##vso[task.setvariable variable=ApiResolvedBuildNumber;isOutput=true]'
          Write-Host '##vso[task.setvariable variable=ApiSourceBranch;isOutput=true]'
        }

        if ($deployDb) {
          Resolve-Build -Label 'Db' -PipelineName '$(dbPipelineName)' -BuildNumber '${{ parameters.dbBuildNumber }}'
        } else {
          Write-Host '##vso[task.setvariable variable=DbPipelineDefinitionId;isOutput=true]'
          Write-Host '##vso[task.setvariable variable=DbBuildId;isOutput=true]'
          Write-Host '##vso[task.setvariable variable=DbResolvedBuildNumber;isOutput=true]'
          Write-Host '##vso[task.setvariable variable=DbSourceBranch;isOutput=true]'
        }
      name: Resolve
      displayName: 'Resolve pipeline names and build numbers'
      env:
        SYSTEM_ACCESSTOKEN: $(System.AccessToken)

- stage: Generate_DB_Preview
  displayName: 'Generate DB preview for $(environmentName)'
  dependsOn:
  - Resolve_Selected_Builds
  condition: and(succeeded('Resolve_Selected_Builds'), eq('${{ parameters.deployDatabase }}', 'true'))
  variables:
    DbPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbPipelineDefinitionId'] ]
    DbBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbBuildId'] ]
    DbSourceBranch: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbSourceBranch'] ]
  jobs:
  - template: pipelines/generate-db-preview.yml@templates
    parameters:
      jobName: 'GenerateDbPreview'
      jobDisplayName: 'Generate DB preview for $(environmentName)'
      deployPool: '$(deploymentPool)'
      deployAgentName: '$(dbAgentName)'
      artifactProject: '$(System.TeamProject)'
      artifactDefinitionId: '$(DbPipelineDefinitionId)'
      artifactBuildId: '$(DbBuildId)'
      artifactName: '$(dbArtifactName)'
      previewArtifactName: 'db-preview-$(environmentName)'
      targetConnectionString: '$(CONN_STRING)'

- stage: Approval_Release
  displayName: 'Approval for $(environmentName) release'
  dependsOn:
  - Resolve_Selected_Builds
  - ${{ if eq(parameters.deployDatabase, true) }}:
    - Generate_DB_Preview
  condition: succeeded()
  jobs:
  - ${{ if eq(parameters.targetEnvironment, 'SIT') }}:
    - job: NoApprovalRequired
      displayName: 'No approval required for SIT'
      pool:
        name: '$(deploymentPool)'
        demands:
        - Agent.Name -equals $(resolveAgentName)
      steps:
      - checkout: none
      - powershell: |
          Write-Host 'SIT selected. No manual approval is required.'
        displayName: 'Skip manual approval'

  - ${{ if ne(parameters.targetEnvironment, 'SIT') }}:
    - job: WaitForBusinessApproval
      displayName: 'Wait for Business Approval'
      pool: server
      timeoutInMinutes: 1500
      steps:
      - task: ManualValidation@0
        timeoutInMinutes: 1440
        inputs:
          notifyUsers: '$(approvalNotifyUsers)'
          instructions: '$(approvalInstructions)'
          onTimeout: 'reject'

    - job: WaitForManagementApproval
      displayName: 'Wait for Management Approval'
      dependsOn: WaitForBusinessApproval
      pool: server
      timeoutInMinutes: 1500
      steps:
      - task: ManualValidation@0
        timeoutInMinutes: 1440
        inputs:
          notifyUsers: '$(managementApprovalNotifyUsers)'
          instructions: '$(approvalInstructions)'
          onTimeout: 'reject'

  - ${{ if and(ne(parameters.targetEnvironment, 'SIT'), eq(parameters.deployDatabase, true)) }}:
    - job: WaitForDbaApproval
      displayName: 'Wait for DBA approval'
      dependsOn: WaitForManagementApproval
      pool: server
      timeoutInMinutes: 1500
      steps:
      - task: ManualValidation@0
        timeoutInMinutes: 1440
        inputs:
          notifyUsers: '$(dbaApprovalNotifyUsers)'
          instructions: 'Approve $(environmentName) database deployment.'
          onTimeout: 'reject'

- stage: Deploy_Applications
  displayName: 'Deploy applications to $(environmentName)'
  dependsOn:
  - Resolve_Selected_Builds
  - Approval_Release
  condition: and(succeeded(), or(${{ eq(parameters.deployApi, true) }}, ${{ eq(parameters.deployMvc, true) }}))
  variables:
    ApiPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.ApiPipelineDefinitionId'] ]
    ApiBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.ApiBuildId'] ]
    ApiSourceBranch: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.ApiSourceBranch'] ]
    MvcPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.MvcPipelineDefinitionId'] ]
    MvcBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.MvcBuildId'] ]
    MvcSourceBranch: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.MvcSourceBranch'] ]
  jobs:
  - ${{ if eq(parameters.deployApi, true) }}:
    - template: pipelines/deploy-iis.yml@templates
      parameters:
        jobDependsOn: []
        jobCondition: succeeded()
        deploymentName: 'DeployAPI'
        deploymentDisplayName: 'Deploy API to ${{ parameters.targetEnvironment }} (IIS)'
        environmentName: '${{ parameters.targetEnvironment }}'
        deployPool: '$(deploymentPool)'
        deployAgentName: '$(apiAgentName)'
        ${{ if eq(parameters.targetEnvironment, 'SIT') }}:
          variableGroup: 'SIT_API_VARIABLE_GROUP'
        ${{ if eq(parameters.targetEnvironment, 'UAT') }}:
          variableGroup: 'UAT_API_VARIABLE_GROUP'
        ${{ if eq(parameters.targetEnvironment, 'PROD') }}:
          variableGroup: 'PROD_API_VARIABLE_GROUP'
        componentName: 'API'
        artifactName: '$(apiArtifactName)'
        artifactBuildType: 'specific'
        artifactProject: '$(System.TeamProject)'
        artifactDefinitionId: '$(ApiPipelineDefinitionId)'
        artifactBuildId: '$(ApiBuildId)'
        artifactBranch: '$(ApiSourceBranch)'
        zipName: '$(apiZipName)'
        siteName: '$(apiSiteName)'
        appPoolName: '$(apiAppPoolName)'
        iisTargetPath: '$(apiTargetPath)'
        cleanTargetBeforeCopy: true
        cleanExcludeCsv: ''
        enableJsonTransform: false
        jsonFiles: ''
        enableXmlConfigTransform: true
        xmlConfigFiles:
        - '**/Web.config'
        xmlVariableValues:
          BaseUrl: $(BaseUrl)
          BrefBaseUrl: $(BrefBaseUrl)
          CONN_STRING: $(CONN_STRING)
          SMSUrl: $(SMSUrl)
        enableCustomXmlEdits: false
        customXmlEdits: []
        enableHealthCheck: true
        healthCheckUrl: '$(apiHealthCheckUrl)'
        healthCheckExpectedStatusCode: '200'
        healthCheckRetries: 6
        healthCheckDelaySeconds: 10
        enableRollbackOnHealthCheckFailure: true
        enableLocalBackup: true
        backupRoot: '$(backupRoot)'
        backupPath: '$(backupRoot)\API\$(Build.BuildId)'

  - ${{ if eq(parameters.deployMvc, true) }}:
    - template: pipelines/deploy-iis.yml@templates
      parameters:
        ${{ if eq(parameters.deployApi, true) }}:
          jobDependsOn:
          - DeployAPI
        ${{ if eq(parameters.deployApi, false) }}:
          jobDependsOn: []
        jobCondition: succeeded()
        deploymentName: 'DeployMVC'
        deploymentDisplayName: 'Deploy MVC to ${{ parameters.targetEnvironment }} (IIS)'
        environmentName: '${{ parameters.targetEnvironment }}'
        deployPool: '$(deploymentPool)'
        deployAgentName: '$(mvcAgentName)'
        ${{ if eq(parameters.targetEnvironment, 'SIT') }}:
          variableGroup: 'SIT_MVC_VARIABLE_GROUP'
        ${{ if eq(parameters.targetEnvironment, 'UAT') }}:
          variableGroup: 'UAT_MVC_VARIABLE_GROUP'
        ${{ if eq(parameters.targetEnvironment, 'PROD') }}:
          variableGroup: 'PROD_MVC_VARIABLE_GROUP'
        componentName: 'MVC'
        artifactName: '$(mvcArtifactName)'
        artifactBuildType: 'specific'
        artifactProject: '$(System.TeamProject)'
        artifactDefinitionId: '$(MvcPipelineDefinitionId)'
        artifactBuildId: '$(MvcBuildId)'
        artifactBranch: '$(MvcSourceBranch)'
        zipName: '$(mvcZipName)'
        siteName: '$(mvcSiteName)'
        appPoolName: '$(mvcAppPoolName)'
        iisTargetPath: '$(mvcTargetPath)'
        cleanTargetBeforeCopy: true
        cleanExcludeCsv: ''
        enableJsonTransform: false
        jsonFiles: ''
        enableXmlConfigTransform: true
        xmlConfigFiles:
        - '**/Web.config'
        xmlVariableValues:
          BaseUrl: $(BaseUrl)
          BaseUrlOsb: $(BaseUrlOsb)
          CDN_IP_LINK: $(CDN_IP_LINK)
          DASHBOARD_LINK: $(DASHBOARD_LINK)
          GenerateAccountFileImportFileNameChecking: $(GenerateAccountFileImportFileNameChecking)
          GeneratePaymentFileImportFileNameChecking: $(GeneratePaymentFileImportFileNameChecking)
          LDAP_WEB_SERVICES_IP_ADDRESS: $(LDAP_WEB_SERVICES_IP_ADDRESS)
          UploadFilesPath: $(UploadFilesPath)
          USER_GUIDE_LINK: $(USER_GUIDE_LINK)
        enableCustomXmlEdits: false
        customXmlEdits: []
        enableHealthCheck: true
        healthCheckUrl: '$(mvcHealthCheckUrl)'
        healthCheckExpectedStatusCode: '200'
        healthCheckRetries: 6
        healthCheckDelaySeconds: 10
        enableRollbackOnHealthCheckFailure: true
        enableLocalBackup: true
        backupRoot: '$(backupRoot)'
        backupPath: '$(backupRoot)\MVC\$(Build.BuildId)'

- stage: Rollback_API_After_MVC_Failure
  displayName: 'Rollback API because MVC failed'
  dependsOn:
  - Deploy_Applications
  condition: and(always(), eq('${{ parameters.deployApi }}', 'true'), eq('${{ parameters.deployMvc }}', 'true'), eq(dependencies.Deploy_Applications.outputs['DeployAPI.DeployAPI.publishSuccessOutcome.DeploymentHealthy'], 'true'), ne(dependencies.Deploy_Applications.outputs['DeployMVC.DeployMVC.publishSuccessOutcome.DeploymentHealthy'], 'true'))
  jobs:
  - template: pipelines/rollback-iis.yml@templates
    parameters:
      deploymentName: 'RollbackAPIAfterMVCFailure'
      deploymentDisplayName: 'Rollback API from local backup because MVC failed'
      environmentName: '${{ parameters.targetEnvironment }}'
      deployPool: '$(deploymentPool)'
      deployAgentName: '$(apiAgentName)'
      siteName: '$(apiSiteName)'
      appPoolName: '$(apiAppPoolName)'
      iisTargetPath: '$(apiTargetPath)'
      backupPath: '$(backupRoot)\API\$(Build.BuildId)'
      cleanExcludeCsv: ''

- stage: Tag_APP_LKG
  displayName: 'Tag successful application builds as LKG'
  dependsOn:
  - Resolve_Selected_Builds
  - Deploy_Applications
  condition: and(succeeded('Deploy_Applications'), or(${{ eq(parameters.deployApi, true) }}, ${{ eq(parameters.deployMvc, true) }}))
  variables:
    ApiBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.ApiBuildId'] ]
    ApiPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.ApiPipelineDefinitionId'] ]
    MvcBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.MvcBuildId'] ]
    MvcPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.MvcPipelineDefinitionId'] ]
  jobs:
  - job: TagApplicationBuilds
    displayName: 'Tag MVC / API builds'
    pool:
      name: '$(deploymentPool)'
      demands:
      - Agent.Name -equals $(resolveAgentName)
    steps:
    - checkout: none

    - ${{ if eq(parameters.deployApi, true) }}:
      - template: pipelines/tag-builds.yml@templates
        parameters:
          tagTargets:
          - name: 'AlternaCardManagement API'
            buildId: '$(ApiBuildId)'
            definitionId: '$(ApiPipelineDefinitionId)'
            deployedTag: 'DEPLOYED-$(environmentName)-ACM-API'
            lkgTag: 'LKG-$(environmentName)-ACM-API'
            makeLkgUnique: true

    - ${{ if eq(parameters.deployMvc, true) }}:
      - template: pipelines/tag-builds.yml@templates
        parameters:
          tagTargets:
          - name: 'AlternaCardManagement MVC'
            buildId: '$(MvcBuildId)'
            definitionId: '$(MvcPipelineDefinitionId)'
            deployedTag: 'DEPLOYED-$(environmentName)-ACM-MVC'
            lkgTag: 'LKG-$(environmentName)-ACM-MVC'
            makeLkgUnique: true

- stage: Deploy_DB_After_Apps
  displayName: 'Deploy DB to $(environmentName) after applications'
  dependsOn:
  - Resolve_Selected_Builds
  - Tag_APP_LKG
  condition: and(succeeded('Tag_APP_LKG'), eq('${{ parameters.deployDatabase }}', 'true'), or(${{ eq(parameters.deployApi, true) }}, ${{ eq(parameters.deployMvc, true) }}))
  variables:
    DbPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbPipelineDefinitionId'] ]
    DbBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbBuildId'] ]
    DbSourceBranch: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbSourceBranch'] ]
  jobs:
  - template: pipelines/deploy-database.yml@templates
    parameters:
      deploymentName: 'DeployDb'
      deploymentDisplayName: 'Deploy database'
      environmentName: '${{ parameters.targetEnvironment }}'
      deployPool: '$(deploymentPool)'
      deployAgentName: '$(dbAgentName)'
      artifactName: '$(dbArtifactName)'
      artifactBuildType: 'specific'
      artifactProject: '$(System.TeamProject)'
      artifactDefinitionId: '$(DbPipelineDefinitionId)'
      artifactBuildId: '$(DbBuildId)'
