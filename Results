## 6. Replace duplicate validation logic in main component

Replace this method:

```ts
private handleDuplicateAccountsBeforeValidation(request: ValidateFileRequest): void
```

with this new version:

```ts
private handleValidationIssuesBeforeValidation(request: ValidateFileRequest): void {
  const issues = this.getFileValidationIssues(
    this.fileImport?.fileImportContents ?? []
  );

  if (issues.length === 0) {
    this.validateFileApiCall(request);
    return;
  }

  const modalRef = this.modalService.open(FileValidationIssuesModalComponent, {
    size: 'xl',
    backdrop: 'static',
    centered: true,
    keyboard: false,
  });

  modalRef.componentInstance.issues = issues;

  modalRef.result
    .then(async (result) => {
      if (result === 'continue') {
        this.validateFileApiCall(request);
        return;
      }

      if (result?.action === 'edit' && result?.id) {
        const rowIndex =
          this.fileImport?.fileImportContents?.findIndex(
            (x) => x.id === result.id
          ) ?? -1;

        if (rowIndex >= 0) {
          await this.openEditDataModal(rowIndex, result.id);
        }

        /**
         * Re-check everything after edit.
         * 
         * This is important because:
         * - The user may fix the duplicate but not the currency issue.
         * - The user may fix the currency but not the duplicate issue.
         * - The user may create another duplicate while editing.
         */
        this.handleValidationIssuesBeforeValidation(request);
      }
    })
    .catch(() => {
      // No / dismissed => do nothing
    });
}
```

