ALTER PROCEDURE [dbo].[usp_Search_Customer_Requests] 
	@P__Key NVARCHAR(255),
    @P__LoggedInUserDepartment NVARCHAR(250),
    @P__Status NVARCHAR(50) NULL
AS
BEGIN
	SET NOCOUNT ON;

    SELECT TOP 10
        cr.[Id]
        ,cr.[Reference]
        ,cr.[CorrelationId]
        ,cr.[RequestTypeCode]
        ,lkp_RequestTypeDescription.[Description] AS RequestTypeDescription
        ,cr.[StatusCode]
        ,lkp_CustomerRequestStatus.[Name] AS StatusDescription
        ,cr.[Reason]
        ,cr.[DeliveryMethodCode]
		,lkp_DeliveryMethodDescription.[Description] AS DeliveryMethodDescription
        ,cr.[Channel]
        ,cr.[CustomerId]
        ,cr.[ExternalId]
        ,cr.[CustomerFirstName]
        ,cr.[CustomerLastName]
        ,cr.[CustomerBranchCode]
        ,c.CompanyAddress AS [CustomerBranchDescription]
        ,shipmentStatus.StatusCode AS ShipmentStatusCode
        ,shipmentStatus.ShipmentNumber
        ,lkp_ShipmentStatus.[Description] AS ShipmentStatusDescription
        ,cr.[CreatedDate]
        ,cr.[CreatedBy]
        ,cr.[LastModifiedDate]
        ,cr.[LastModifiedBy]
    FROM [dbo].[t_CustomerRequest] cr
    OUTER APPLY(
    SELECT TOP 1 [StatusCode],[ShipmentNumber] FROM t_RequestShipment
    WHERE CustomerRequestId = cr.Id
    ORDER BY [Id] DESC
    ) shipmentStatus
    LEFT JOIN t_Lookup lkp_ShipmentStatus ON shipmentStatus.StatusCode = lkp_ShipmentStatus.Code AND lkp_ShipmentStatus.TableName = 'ShipmentStatus'
    LEFT JOIN t_Lookup lkp_CustomerRequestStatus ON cr.StatusCode = lkp_CustomerRequestStatus.Code AND lkp_CustomerRequestStatus.TableName = 'RequestStatus'
    LEFT JOIN t_Lookup lkp_RequestTypeDescription ON cr.[RequestTypeCode] = lkp_RequestTypeDescription.Code AND lkp_RequestTypeDescription.TableName = 'RequestType'
	LEFT JOIN t_Lookup lkp_DeliveryMethodDescription ON cr.[DeliveryMethodCode] = lkp_DeliveryMethodDescription.Code AND lkp_DeliveryMethodDescription.TableName = 'DeliveryMethod'
    LEFT JOIN [Alterna.Bref].[dbo].[t_Company] c ON c.CompanyCode COLLATE SQL_Latin1_General_CP1_CI_AS = cr.CustomerBranchCode
    WHERE
    EXISTS
    (
        SELECT 1
        FROM [dbo].[t_CustomerRequestDepartmentAccess] departmentAccess
        INNER JOIN [dbo].[t_CustomerRequestDepartmentDeliveryMethodAccess] deliveryAccess
            ON deliveryAccess.CustomerRequestDepartmentAccessId = departmentAccess.Id
        WHERE 
            departmentAccess.DepartmentCode = @P__LoggedInUserDepartment
            AND departmentAccess.IsActive = 1
            AND deliveryAccess.IsActive = 1
            AND deliveryAccess.DeliveryMethodCode = cr.DeliveryMethodCode
    )
    AND cr.Reference LIKE ('%'+ @P__Key + '%')
    AND 
    (
        @P__Status IS NULL OR cr.StatusCode = @P__Status
    )
    ORDER BY cr.Id DESC
END
