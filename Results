- powershell: |
    $dc = '${{ parameters.dependencyCheckCliPath }}'
    $reportDir = '$(Build.ArtifactStagingDirectory)\dependency-check'
    $scanPath = Join-Path '$(Build.SourcesDirectory)' '${{ parameters.workingDirectory }}'

    if (-not (Test-Path $dc)) {
      throw "Dependency-Check CLI not found at: $dc"
    }

    New-Item -ItemType Directory -Force -Path $reportDir | Out-Null

    & $dc `
      --project "${{ parameters.dependencyCheckProjectName }}" `
      --scan "$scanPath" `
      --format "HTML" `
      --format "JSON" `
      --format "JUNIT" `
      --out "$reportDir" `
      --data "${{ parameters.dependencyCheckDataPath }}" `
      --noupdate `
      --disableKnownExploited `
      --disableHostedSuppressions `
      --disableYarnAudit `
      --disablePnpmAudit `
      --disableNodeAudit `
      --disableRetireJS `
      --disableVersionCheck `
      ${{ parameters.dependencyCheckAdditionalArguments }}

    if ($LASTEXITCODE -ne 0) {
      exit $LASTEXITCODE
    }
  displayName: 'OWASP Dependency Check (local CLI)'
  condition: and(succeeded(), eq('${{ parameters.runDependencyCheck }}', 'true'))
  env:
    NVD_API_KEY: $(NVD_API_KEY)
