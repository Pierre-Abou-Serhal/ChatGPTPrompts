- template: deploy-iis.yml
  parameters:
    environmentName: 'prod'
    deployPool: 'MyPool'
    deployAgentName: 'MyAgent'
    variableGroup: 'VG-PROD'
    zipName: 'api.zip'
    siteName: 'MySite'
    appPoolName: 'MyPool'
    iisTargetPath: 'D:\Sites\MyApi'

    enableJsonTransform: true
    jsonFiles: '**/appsettings.json'

    enableXmlConfigTransform: true
    xmlConfigFiles:
      - '**/web.config'
      - '**/*.exe.config'

    enableCustomXmlEdits: true
    customXmlEdits:
      - file: '**/APISTRATEGY.xml'
        xpath: '/APISTRATEGY/GET_CUSTOMER/STRATEGY[@VALUE="openFreshAccount"]/@API'
        variable: 'API_OPENFRESHACCOUNT'
      - file: '**/APITOKEN.xml'
        xpath: '/APITOKEN/GET_CUSTOMER/TOKEN[@APPLICATION_NAME="AMS"]/@VALUE'
        variable: 'TOKEN_AMS'
