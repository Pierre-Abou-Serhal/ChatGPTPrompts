- ${{ if and(eq(parameters.deployMvc, true), eq(parameters.deployApi, true)) }}:
  - stage: Rollback_API_SIT
    displayName: 'Rollback API because API deployment failed'
    dependsOn:
    - Deploy_API_SIT
    condition: failed('Deploy_API_SIT')
    jobs:
    - deployment: RollbackAPI
      displayName: 'Rollback API from local backup'
      environment: 'SIT'
      pool:
        name: 'Deployment Pool'
        demands:
        - Agent.Name -equals SIT-ALTERNA-BN1
      strategy:
        runOnce:
          deploy:
            steps:
            - powershell: |
                $ErrorActionPreference = "Stop"

                $serviceName = "CHANGE_ME__AlternaCardManagementApiService"
                $target      = 'C:\Services\AlternaCardManagement-AzureDevOps-API'
                $backupPath  = 'C:\DeployBackups\SIT\API\$(Build.BuildId)'

                if (-not (Test-Path $backupPath)) {
                  throw "Backup path not found: $backupPath"
                }

                $backupItems = Get-ChildItem -Path $backupPath -Force
                if (-not $backupItems -or $backupItems.Count -eq 0) {
                  throw "Backup path is empty: $backupPath"
                }

                $svc = Get-Service -Name $serviceName -ErrorAction Stop
                if ($svc.Status -ne 'Stopped') {
                  Write-Host "Stopping service: $serviceName"
                  Stop-Service -Name $serviceName -Force -ErrorAction Stop
                }

                $maxTries = 30
                for ($i = 1; $i -le $maxTries; $i++) {
                  $state = (Get-Service -Name $serviceName -ErrorAction Stop).Status
                  if ($state -eq 'Stopped') { break }
                  Start-Sleep -Seconds 2
                }

                $exclude = @()
                Get-ChildItem -Path $target -Force | ForEach-Object {
                  if ($exclude -contains $_.Name) {
                    Write-Host "Skipping excluded item: $($_.FullName)"
                  } else {
                    Remove-Item -LiteralPath $_.FullName -Recurse -Force -ErrorAction Stop
                  }
                }

                foreach ($item in $backupItems) {
                  Copy-Item -LiteralPath $item.FullName -Destination $target -Recurse -Force
                }

                Start-Service -Name $serviceName -ErrorAction Stop

                for ($i = 1; $i -le $maxTries; $i++) {
                  $state = (Get-Service -Name $serviceName -ErrorAction Stop).Status
                  if ($state -eq 'Running') { break }
                  Start-Sleep -Seconds 2
                }

                $finalRunningState = (Get-Service -Name $serviceName -ErrorAction Stop).Status
                Write-Host "After rollback => Service state: $finalRunningState"

                if ($finalRunningState -ne 'Running') {
                  throw "Rollback completed, but service '$serviceName' did not start correctly. Final state: $finalRunningState"
                }
              displayName: 'Rollback API from local backup'

- ${{ if and(eq(parameters.deployMvc, true), eq(parameters.deployApi, true)) }}:
  - stage: Rollback_MVC_SIT
    displayName: 'Rollback MVC because API deployment failed'
    dependsOn:
    - Deploy_MVC_SIT
    - Deploy_API_SIT
    condition: and(failed('Deploy_API_SIT'), succeeded('Deploy_MVC_SIT'))
    jobs:
    - deployment: RollbackMVC
      displayName: 'Rollback MVC from local backup'
      environment: 'SIT'
      pool:
        name: 'Deployment Pool'
        demands:
        - Agent.Name -equals SIT-ALTERNA-FN1
      strategy:
        runOnce:
          deploy:
            steps:
            - powershell: |
                $ErrorActionPreference = "Stop"
                Import-Module WebAdministration

                $siteName   = "AlternaCardManagement-AzureDevOps"
                $appPool    = "AlternaCardManagement-AzureDevOps"
                $target     = 'C:\inetpub\wwwroot\AlternaCardManagement-AzureDevOps-FN1'
                $backupPath = 'C:\DeployBackups\SIT\MVC\$(Build.BuildId)'

                if (-not (Test-Path $backupPath)) {
                  throw "Backup path not found: $backupPath"
                }

                $backupItems = Get-ChildItem -Path $backupPath -Force
                if (-not $backupItems -or $backupItems.Count -eq 0) {
                  throw "Backup path is empty: $backupPath"
                }

                $site = Get-Website -Name $siteName
                if ($site.State -ne "Stopped") {
                  Write-Host "Stopping website: $siteName"
                  Stop-Website -Name $siteName
                }

                $poolState = (Get-WebAppPoolState -Name $appPool).Value
                if ($poolState -ne "Stopped") {
                  Write-Host "Stopping app pool: $appPool"
                  Stop-WebAppPool -Name $appPool
                }

                $maxTries = 30
                for ($i = 1; $i -le $maxTries; $i++) {
                  $siteState = (Get-Website -Name $siteName).State
                  $currentPoolState = (Get-WebAppPoolState -Name $appPool).Value
                  if ($siteState -eq "Stopped" -and $currentPoolState -eq "Stopped") { break }
                  Start-Sleep -Seconds 2
                }

                $exclude = @()
                Get-ChildItem -Path $target -Force | ForEach-Object {
                  if ($exclude -contains $_.Name) {
                    Write-Host "Skipping excluded item: $($_.FullName)"
                  } else {
                    Remove-Item -LiteralPath $_.FullName -Recurse -Force -ErrorAction Stop
                  }
                }

                foreach ($item in $backupItems) {
                  Copy-Item -LiteralPath $item.FullName -Destination $target -Recurse -Force
                }

                Start-WebAppPool -Name $appPool
                Start-Website -Name $siteName

                $finalSiteState = (Get-Website -Name $siteName).State
                $finalPoolState = (Get-WebAppPoolState -Name $appPool).Value

                Write-Host "After rollback => Website state: $finalSiteState | AppPool state: $finalPoolState"

                if ($finalSiteState -ne "Started" -or $finalPoolState -ne "Started") {
                  throw "Rollback completed, but IIS did not start correctly. Website=$finalSiteState AppPool=$finalPoolState"
                }
              displayName: 'Rollback MVC from local backup'

- ${{ if and(eq(parameters.deployMvc, true), eq(parameters.deployApi, true)) }}:
  - stage: Tag_APP_LKG_SIT
    displayName: 'Tag application build as LKG'
    dependsOn:
    - Deploy_MVC_SIT
    - Deploy_API_SIT
    condition: and(succeeded('Deploy_MVC_SIT'), succeeded('Deploy_API_SIT'), ne(variables['applicationBuildId'], ''))
    jobs:
    - job: TagApplicationBuild
      displayName: 'Tag MVC and API build'
      pool:
        name: 'Deployment Pool'
        demands:
        - Agent.Name -equals SIT-ALTERNA-BN1
      steps:
      - powershell: |
          $ErrorActionPreference = "Stop"

          $buildId = "$(applicationBuildId)".Trim()
          if ([string]::IsNullOrWhiteSpace($buildId)) {
            throw "applicationBuildId is required for coordinated tagging."
          }

          $collectionUri = "$(System.CollectionUri)".TrimEnd('/')
          $projectName   = [System.Uri]::EscapeDataString("$(System.TeamProject)")
          $apiVersion    = "7.0"

          $headers = @{
            Authorization = "Bearer $env:SYSTEM_ACCESSTOKEN"
          }

          $tags = @('LKG-SIT-MVC', 'LKG-SIT-API')

          foreach ($tag in $tags) {
            $tagEscaped = [System.Uri]::EscapeDataString($tag)
            $uri = '{0}/{1}/_apis/build/builds/{2}/tags/{3}?api-version={4}' -f `
              $collectionUri,
              $projectName,
              $buildId,
              $tagEscaped,
              $apiVersion

            Write-Host "Tagging build [$buildId] with [$tag]"
            Invoke-RestMethod -Method Put -Uri $uri -Headers $headers | Out-Null
          }

          Write-Host "Coordinated tagging completed successfully."
        displayName: 'Tag application build as LKG'
        env:
          SYSTEM_ACCESSTOKEN: $(System.AccessToken)
