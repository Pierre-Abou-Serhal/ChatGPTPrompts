using System.Text;
using BrgccReverseProxy.Common;
using Microsoft.Extensions.Configuration;
using Microsoft.Extensions.DependencyInjection;
using Microsoft.Extensions.Options;
using Yarp.ReverseProxy.Transforms;

namespace BrgccReverseProxy.Extensions;

public static class ReverseProxyAuthExtensions
{
    public static IServiceCollection AddClusterBasedReverseProxyAuth(
        this IServiceCollection services,
        IConfiguration configuration)
    {
        ClusterAuthOption clusterAuthOption = configuration.GetSection("ClusterAuth").Get<ClusterAuthOption>() ?? new();
        
        services
            .AddReverseProxy()
            .LoadFromConfig(configuration.GetSection("ReverseProxy"))
            .AddTransforms(builderContext =>
            {
                String? clusterId = builderContext.Route.ClusterId;
                
                ClusterCredential? clusterCredential = clusterAuthOption.ClusterCredentials
                    .FirstOrDefault(i => i.ClusterId.Equals(clusterId, StringComparison.OrdinalIgnoreCase));
                
                if (String.IsNullOrWhiteSpace(clusterId))
                    return;
                
                if (clusterCredential is null)
                    return;

                if (String.IsNullOrWhiteSpace(clusterCredential.Username) ||
                    String.IsNullOrWhiteSpace(clusterCredential.Password))
                    return;

                builderContext.AddRequestTransform(transformContext =>
                {
                    // OPTION A: Standard HTTP Basic auth
                    var raw = $"{clusterCredential.Username}:{clusterCredential.Password}";
                    var base64 = Convert.ToBase64String(Encoding.UTF8.GetBytes(raw));

                    transformContext.ProxyRequest.Headers.Remove("Authorization");
                    transformContext.ProxyRequest.Headers.TryAddWithoutValidation(
                        "Authorization",
                        $"Basic {base64}");

                    return ValueTask.CompletedTask;
                });
            });

        return services;
    }
}

