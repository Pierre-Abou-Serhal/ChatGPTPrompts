stages:

- stage: Resolve_Selected_Builds
  displayName: 'Resolve selected build numbers'
  jobs:
  - job: ResolveBuildNumbers
    displayName: 'Resolve pipeline names and build numbers'
    pool:
      name: '$(deploymentPool)'
      demands:
      - Agent.Name -equals $(resolveAgentName)
    steps:
    - checkout: none

    - powershell: |
        $ErrorActionPreference = 'Stop'

        $collectionUri = "$(System.CollectionUri)".TrimEnd('/')
        $projectName   = [System.Uri]::EscapeDataString("$(System.TeamProject)")
        $apiVersion    = '7.1'
        $allowedBranchPattern = '$(buildSourceBranchRegex)'

        $headers = @{
          Authorization = "Bearer $env:SYSTEM_ACCESSTOKEN"
        }

        $deployBackend = "${{ parameters.deployBackend }}".ToLower() -eq 'true'
        $deployFrontend = "${{ parameters.deployFrontend }}".ToLower() -eq 'true'
        $deployDb = "${{ parameters.deployDatabase }}".ToLower() -eq 'true'

        if (-not ($deployBackend -or $deployFrontend -or $deployDb)) {
          throw 'At least one deployment target must be selected: Backend, Frontend, or Database.'
        }

        function Normalize-BuildNumber {
          param([string]$BuildNumber)

          if ($BuildNumber -eq '__EMPTY__') {
            return ''
          }

          return $BuildNumber
        }

        function Resolve-DefinitionIdByName {
          param(
            [string]$Label,
            [string]$PipelineName
          )

          if ([string]::IsNullOrWhiteSpace($PipelineName)) {
            throw "$Label pipeline name is empty."
          }

          $encodedName = [System.Uri]::EscapeDataString($PipelineName)
          $uri = "{0}/{1}/_apis/build/definitions?name={2}&includeAllProperties=false&includeLatestBuilds=false&api-version={3}" -f `
            $collectionUri,
            $projectName,
            $encodedName,
            $apiVersion

          Write-Host "Resolving $Label pipeline name [$PipelineName]"
          $response = Invoke-RestMethod -Method Get -Uri $uri -Headers $headers

          if (-not $response.value -or $response.count -lt 1) {
            throw "No pipeline definition found for $Label with name [$PipelineName]."
          }

          $exactMatches = @($response.value | Where-Object { $_.name -eq $PipelineName })

          if ($exactMatches.Count -eq 0) {
            throw "No exact pipeline definition match found for $Label with name [$PipelineName]."
          }

          if ($exactMatches.Count -gt 1) {
            throw "More than one exact pipeline definition match was found for [$PipelineName]. Make the pipeline name unique."
          }

          $definition = $exactMatches[0]

          Write-Host "$Label definition resolved:"
          Write-Host "  Definition ID   = $($definition.id)"
          Write-Host "  Definition Name = $($definition.name)"

          return $definition.id
        }

        function Resolve-Build {
          param(
            [string]$Label,
            [string]$PipelineName,
            [string]$BuildNumber
          )

          $BuildNumber = Normalize-BuildNumber -BuildNumber $BuildNumber

          if ([string]::IsNullOrWhiteSpace($BuildNumber)) {
            throw "$Label build number is required because deployment of $Label was selected."
          }

          $definitionId = Resolve-DefinitionIdByName -Label $Label -PipelineName $PipelineName
          $encodedBuildNumber = [System.Uri]::EscapeDataString($BuildNumber)

          $uri = "{0}/{1}/_apis/build/builds?definitions={2}&buildNumber={3}&statusFilter=completed&resultFilter=succeeded&`$top=1&queryOrder=finishTimeDescending&api-version={4}" -f `
            $collectionUri,
            $projectName,
            $definitionId,
            $encodedBuildNumber,
            $apiVersion

          Write-Host "Resolving $Label build number [$BuildNumber] using pipeline definition [$definitionId]"
          $response = Invoke-RestMethod -Method Get -Uri $uri -Headers $headers

          if (-not $response.value -or $response.count -lt 1) {
            throw "No succeeded build found for $Label with build number [$BuildNumber] in pipeline [$PipelineName]."
          }

          $build = $response.value[0]

          if ($build.sourceBranch -notmatch $allowedBranchPattern) {
            throw "$Label build [$BuildNumber] was resolved, but it belongs to branch [$($build.sourceBranch)]. Only release/* or hotfix/* builds can be deployed."
          }

          Write-Host "$Label build resolved:"
          Write-Host "  Build ID         = $($build.id)"
          Write-Host "  Build Number     = $($build.buildNumber)"
          Write-Host "  Definition ID    = $definitionId"
          Write-Host "  Definition Name  = $PipelineName"
          Write-Host "  Branch           = $($build.sourceBranch)"

          Write-Host "##vso[task.setvariable variable=${Label}PipelineDefinitionId;isOutput=true]$definitionId"
          Write-Host "##vso[task.setvariable variable=${Label}BuildId;isOutput=true]$($build.id)"
          Write-Host "##vso[task.setvariable variable=${Label}ResolvedBuildNumber;isOutput=true]$($build.buildNumber)"
          Write-Host "##vso[task.setvariable variable=${Label}SourceBranch;isOutput=true]$($build.sourceBranch)"
        }

        if ($deployBackend) {
          Resolve-Build -Label 'Backend' -PipelineName '$(backendPipelineName)' -BuildNumber '${{ parameters.backendBuildNumber }}'
        } else {
          Write-Host '##vso[task.setvariable variable=BackendPipelineDefinitionId;isOutput=true]'
          Write-Host '##vso[task.setvariable variable=BackendBuildId;isOutput=true]'
          Write-Host '##vso[task.setvariable variable=BackendResolvedBuildNumber;isOutput=true]'
          Write-Host '##vso[task.setvariable variable=BackendSourceBranch;isOutput=true]'
        }

        if ($deployFrontend) {
          Resolve-Build -Label 'Frontend' -PipelineName '$(frontendPipelineName)' -BuildNumber '${{ parameters.frontendBuildNumber }}'
        } else {
          Write-Host '##vso[task.setvariable variable=FrontendPipelineDefinitionId;isOutput=true]'
          Write-Host '##vso[task.setvariable variable=FrontendBuildId;isOutput=true]'
          Write-Host '##vso[task.setvariable variable=FrontendResolvedBuildNumber;isOutput=true]'
          Write-Host '##vso[task.setvariable variable=FrontendSourceBranch;isOutput=true]'
        }

        if ($deployDb) {
          Resolve-Build -Label 'Db' -PipelineName '$(dbPipelineName)' -BuildNumber '${{ parameters.dbBuildNumber }}'
        } else {
          Write-Host '##vso[task.setvariable variable=DbPipelineDefinitionId;isOutput=true]'
          Write-Host '##vso[task.setvariable variable=DbBuildId;isOutput=true]'
          Write-Host '##vso[task.setvariable variable=DbResolvedBuildNumber;isOutput=true]'
          Write-Host '##vso[task.setvariable variable=DbSourceBranch;isOutput=true]'
        }
      name: Resolve
      displayName: 'Resolve pipeline names and build numbers'
      env:
        SYSTEM_ACCESSTOKEN: $(System.AccessToken)

- stage: Generate_DB_Preview
  displayName: 'Generate DB preview for $(environmentName)'
  dependsOn:
  - Resolve_Selected_Builds
  condition: and(succeeded('Resolve_Selected_Builds'), eq('${{ parameters.deployDatabase }}', 'true'))
  variables:
    DbPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbPipelineDefinitionId'] ]
    DbBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbBuildId'] ]
    DbSourceBranch: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbSourceBranch'] ]
  jobs:
  - job: GenerateDbPreview
    displayName: 'Generate preview SQL and deploy report'
    pool:
      name: '$(deploymentPool)'
      demands:
      - Agent.Name -equals $(dbAgentName)
    steps:
    - checkout: none

    - task: DownloadBuildArtifacts@1
      displayName: 'Download DB DACPAC artifact'
      inputs:
        buildType: 'specific'
        project: '$(System.TeamProject)'
        pipeline: '$(DbPipelineDefinitionId)'
        buildVersionToDownload: 'specific'
        buildId: '$(DbBuildId)'
        downloadType: 'single'
        artifactName: '$(dbArtifactName)'
        downloadPath: '$(System.ArtifactsDirectory)\dbdrop'

    - powershell: |
        $ErrorActionPreference = 'Stop'

        $dacpac = Get-ChildItem "$(System.ArtifactsDirectory)\dbdrop" -Recurse -Filter *.dacpac |
                  Select-Object -First 1

        if (-not $dacpac) {
          throw "No .dacpac found in downloaded DB artifact."
        }

        $outDir = "$(Build.ArtifactStagingDirectory)\db-preview"
        New-Item -ItemType Directory -Force -Path $outDir | Out-Null

        $scriptPath = Join-Path $outDir 'preview-deploy.sql'
        $reportPath = Join-Path $outDir 'deploy-report.xml'

        & "SqlPackage" `
          /Action:Script `
          /SourceFile:"$($dacpac.FullName)" `
          /TargetConnectionString:"$(GlobalSettings.ConnString)" `
          /DeployScriptPath:"$scriptPath" `
          /DeployReportPath:"$reportPath" `
          /p:IgnorePermissions=true `
          /p:IgnoreRoleMembership=true `
          /p:IgnoreUserSettingsObjects=true `
          /p:BlockOnPossibleDataLoss=true `
          /p:DropObjectsNotInSource=false

        if ($LASTEXITCODE -ne 0) {
          throw "SqlPackage Script failed with exit code $LASTEXITCODE"
        }
      displayName: 'Generate DB preview files'

    - task: PublishBuildArtifacts@1
      displayName: 'Publish DB preview artifact'
      inputs:
        PathtoPublish: '$(Build.ArtifactStagingDirectory)\db-preview'
        ArtifactName: 'db-preview-$(environmentName)'
        publishLocation: 'Container'

- stage: Approval_Release
  displayName: 'Approval for $(environmentName) release'
  dependsOn:
  - Resolve_Selected_Builds
  - ${{ if eq(parameters.deployDatabase, true) }}:
    - Generate_DB_Preview
  condition: succeeded()
  jobs:
  - ${{ if eq(parameters.targetEnvironment, 'SIT') }}:
    - job: NoApprovalRequired
      displayName: 'No approval required for SIT'
      pool:
        name: '$(deploymentPool)'
        demands:
        - Agent.Name -equals $(resolveAgentName)
      steps:
      - checkout: none
      - powershell: |
          Write-Host 'SIT selected. No manual approval is required.'
        displayName: 'Skip manual approval'

  - ${{ if ne(parameters.targetEnvironment, 'SIT') }}:
    - job: WaitForBusinessApproval
      displayName: 'Wait for Business Approval'
      pool: server
      timeoutInMinutes: 1500
      steps:
      - task: ManualValidation@0
        timeoutInMinutes: 1440
        inputs:
          notifyUsers: '$(approvalNotifyUsers)'
          instructions: '$(approvalInstructions)'
          onTimeout: 'reject'

- stage: Deploy_Applications
  displayName: 'Deploy applications to $(environmentName)'
  dependsOn:
  - Resolve_Selected_Builds
  - Approval_Release
  condition: and(succeeded(), or(${{ eq(parameters.deployBackend, true) }}, ${{ eq(parameters.deployFrontend, true) }}))
  variables:
    BackendPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.BackendPipelineDefinitionId'] ]
    BackendBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.BackendBuildId'] ]
    BackendSourceBranch: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.BackendSourceBranch'] ]
    FrontendPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.FrontendPipelineDefinitionId'] ]
    FrontendBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.FrontendBuildId'] ]
    FrontendSourceBranch: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.FrontendSourceBranch'] ]
  jobs:
  - ${{ if eq(parameters.deployBackend, true) }}:
    - template: pipelines/deploy-iis.yml@templates
      parameters:
        jobDependsOn: []
        jobCondition: succeeded()
        deploymentName: 'DeployBackend'
        deploymentDisplayName: 'Deploy Backend to ${{ parameters.targetEnvironment }} (IIS)'
        environmentName: '${{ parameters.targetEnvironment }}'
        deployPool: '$(deploymentPool)'
        deployAgentName: '$(backendAgentName)'
        ${{ if eq(parameters.targetEnvironment, 'SIT') }}:
          variableGroup: 'SIT_BACK_END_VARIABLE_GROUP'
        ${{ if eq(parameters.targetEnvironment, 'UAT') }}:
          variableGroup: 'UAT_BACK_END_VARIABLE_GROUP'
        ${{ if eq(parameters.targetEnvironment, 'PROD') }}:
          variableGroup: 'PROD_BACK_END_VARIABLE_GROUP'
        componentName: 'BACKEND'
        artifactName: '$(backendArtifactName)'
        artifactBuildType: 'specific'
        artifactProject: '$(System.TeamProject)'
        artifactDefinitionId: '$(BackendPipelineDefinitionId)'
        artifactBuildId: '$(BackendBuildId)'
        artifactBranch: '$(BackendSourceBranch)'
        zipName: '$(backendZipName)'
        siteName: '$(backendSiteName)'
        appPoolName: '$(backendAppPoolName)'
        iisTargetPath: '$(backendTargetPath)'
        cleanTargetBeforeCopy: true
        cleanExcludeCsv: ''
        enableJsonTransform: true
        jsonFiles: '**/appsettings.json'
        enableXmlConfigTransform: false
        xmlConfigFiles: []
        xmlVariableValues: {}
        enableCustomXmlEdits: false
        customXmlEdits: []
        customXmlVariableValues: {}
        enableHealthCheck: true
        healthCheckUrl: '$(backendHealthCheckUrl)'
        healthCheckExpectedStatusCode: '200'
        healthCheckRetries: 6
        healthCheckDelaySeconds: 10
        enableRollbackOnHealthCheckFailure: true
        enableLocalBackup: true
        backupRoot: '$(backupRoot)'
        backupPath: '$(backupRoot)\BACKEND\$(Build.BuildId)'

  - ${{ if eq(parameters.deployFrontend, true) }}:
    - template: pipelines/deploy-iis.yml@templates
      parameters:
        ${{ if eq(parameters.deployBackend, true) }}:
          jobDependsOn:
          - DeployBackend
        ${{ if eq(parameters.deployBackend, false) }}:
          jobDependsOn: []
        jobCondition: succeeded()
        deploymentName: 'DeployFrontend'
        deploymentDisplayName: 'Deploy Frontend to ${{ parameters.targetEnvironment }} (IIS)'
        environmentName: '${{ parameters.targetEnvironment }}'
        deployPool: '$(deploymentPool)'
        deployAgentName: '$(frontendAgentName)'
        ${{ if eq(parameters.targetEnvironment, 'SIT') }}:
          variableGroup: 'SIT_FRONT_END_VARIABLE_GROUP'
        ${{ if eq(parameters.targetEnvironment, 'UAT') }}:
          variableGroup: 'UAT_FRONT_END_VARIABLE_GROUP'
        ${{ if eq(parameters.targetEnvironment, 'PROD') }}:
          variableGroup: 'PROD_FRONT_END_VARIABLE_GROUP'
        componentName: 'FRONTEND'
        artifactName: '$(frontendArtifactName)'
        artifactBuildType: 'specific'
        artifactProject: '$(System.TeamProject)'
        artifactDefinitionId: '$(FrontendPipelineDefinitionId)'
        artifactBuildId: '$(FrontendBuildId)'
        artifactBranch: '$(FrontendSourceBranch)'
        zipName: '$(frontendZipName)'
        siteName: '$(frontendSiteName)'
        appPoolName: '$(frontendAppPoolName)'
        iisTargetPath: '$(frontendTargetPath)'
        cleanTargetBeforeCopy: true
        cleanExcludeCsv: ''
        enableJsonTransform: true
        jsonFiles: '**/appsettings.json'
        enableXmlConfigTransform: false
        xmlConfigFiles: []
        xmlVariableValues: {}
        enableCustomXmlEdits: false
        customXmlEdits: []
        customXmlVariableValues: {}
        enableHealthCheck: true
        healthCheckUrl: '$(frontendHealthCheckUrl)'
        healthCheckExpectedStatusCode: '200'
        healthCheckRetries: 6
        healthCheckDelaySeconds: 10
        enableRollbackOnHealthCheckFailure: true
        enableLocalBackup: true
        backupRoot: '$(backupRoot)'
        backupPath: '$(backupRoot)\FRONTEND\$(Build.BuildId)'

- stage: Rollback_Backend_After_Frontend_Failure
  displayName: 'Rollback Backend because Frontend failed'
  dependsOn:
  - Deploy_Applications
  condition: and(
              always(),
              eq('${{ parameters.deployBackend }}', 'true'),
              eq('${{ parameters.deployFrontend }}', 'true'),
              eq(dependencies.Deploy_Applications.outputs['DeployBackend.DeployBackend.publishSuccessOutcome.DeploymentHealthy'], 'true'),
              ne(dependencies.Deploy_Applications.outputs['DeployFrontend.DeployFrontend.publishSuccessOutcome.DeploymentHealthy'], 'true')
            )
  jobs:
  - template: pipelines/rollback-iis.yml@templates
    parameters:
      deploymentName: 'RollbackBackendAfterFrontendFailure'
      deploymentDisplayName: 'Rollback Backend from local backup because Frontend failed'
      environmentName: '${{ parameters.targetEnvironment }}'
      deployPool: '$(deploymentPool)'
      deployAgentName: '$(backendAgentName)'
      siteName: '$(backendSiteName)'
      appPoolName: '$(backendAppPoolName)'
      iisTargetPath: '$(backendTargetPath)'
      backupPath: '$(backupRoot)\BACKEND\$(Build.BuildId)'
      cleanExcludeCsv: ''

- stage: Tag_APP_LKG
  displayName: 'Tag successful application builds as LKG'
  dependsOn:
  - Resolve_Selected_Builds
  - Deploy_Applications
  condition: and(succeeded('Deploy_Applications'), or(${{ eq(parameters.deployBackend, true) }}, ${{ eq(parameters.deployFrontend, true) }}))
  variables:
    BackendBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.BackendBuildId'] ]
    BackendPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.BackendPipelineDefinitionId'] ]
    FrontendBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.FrontendBuildId'] ]
    FrontendPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.FrontendPipelineDefinitionId'] ]
  jobs:
  - job: TagApplicationBuilds
    displayName: 'Tag Frontend / Backend builds'
    pool:
      name: '$(deploymentPool)'
      demands:
      - Agent.Name -equals $(resolveAgentName)
    steps:
    - checkout: none

    - ${{ if eq(parameters.deployBackend, true) }}:
      - template: pipelines/tag-builds.yml@templates
        parameters:
          tagTargets:
          - name: 'Alterna Telecom Backend'
            buildId: '$(BackendBuildId)'
            definitionId: '$(BackendPipelineDefinitionId)'
            deployedTag: 'DEPLOYED-$(environmentName)-ATC-BACKEND'
            lkgTag: 'LKG-$(environmentName)-ATC-BACKEND'
            makeLkgUnique: true

    - ${{ if eq(parameters.deployFrontend, true) }}:
      - template: pipelines/tag-builds.yml@templates
        parameters:
          tagTargets:
          - name: 'Alterna Telecom Frontend'
            buildId: '$(FrontendBuildId)'
            definitionId: '$(FrontendPipelineDefinitionId)'
            deployedTag: 'DEPLOYED-$(environmentName)-ATC-FRONTEND'
            lkgTag: 'LKG-$(environmentName)-ATC-FRONTEND'
            makeLkgUnique: true

- stage: Deploy_DB_After_Apps
  displayName: 'Deploy DB to $(environmentName) after applications'
  dependsOn:
  - Resolve_Selected_Builds
  - Approval_Release
  - Tag_APP_LKG
  condition: and(succeeded('Approval_Release'), succeeded('Tag_APP_LKG'), eq('${{ parameters.deployDatabase }}', 'true'), or(eq('${{ parameters.deployBackend }}', 'true'), eq('${{ parameters.deployFrontend }}', 'true')))
  variables:
    DbPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbPipelineDefinitionId'] ]
    DbBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbBuildId'] ]
    DbSourceBranch: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbSourceBranch'] ]
  jobs:
  - template: pipelines/deploy-database.yml@templates
    parameters:
      deploymentName: 'DeployDb'
      deploymentDisplayName: 'Deploy Alterna Telecom database'
      environmentName: '${{ parameters.targetEnvironment }}'
      deployPool: '$(deploymentPool)'
      deployAgentName: '$(dbAgentName)'
      artifactName: '$(dbArtifactName)'
      artifactBuildType: 'specific'
      artifactProject: '$(System.TeamProject)'
      artifactDefinitionId: '$(DbPipelineDefinitionId)'
      artifactBuildId: '$(DbBuildId)'
      artifactBranch: '$(DbSourceBranch)'
      targetConnectionString: '$(GlobalSettings.ConnString)'

- stage: Deploy_DB_Only
  displayName: 'Deploy DB to $(environmentName)'
  dependsOn:
  - Resolve_Selected_Builds
  - Approval_Release
  condition: and(
              succeeded('Approval_Release'),
              eq('${{ parameters.deployDatabase }}', 'true'),
              eq('${{ parameters.deployBackend }}', 'false'),
              eq('${{ parameters.deployFrontend }}', 'false')
            )
  variables:
    DbPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbPipelineDefinitionId'] ]
    DbBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbBuildId'] ]
    DbSourceBranch: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbSourceBranch'] ]
  jobs:
  - template: pipelines/deploy-database.yml@templates
    parameters:
      deploymentName: 'DeployDb'
      deploymentDisplayName: 'Deploy Alterna Telecom database'
      environmentName: '${{ parameters.targetEnvironment }}'
      deployPool: '$(deploymentPool)'
      deployAgentName: '$(dbAgentName)'
      artifactName: '$(dbArtifactName)'
      artifactBuildType: 'specific'
      artifactProject: '$(System.TeamProject)'
      artifactDefinitionId: '$(DbPipelineDefinitionId)'
      artifactBuildId: '$(DbBuildId)'
      artifactBranch: '$(DbSourceBranch)'
      targetConnectionString: '$(GlobalSettings.ConnString)'

- stage: Tag_DB_DEPLOYED
  displayName: 'Tag deployed database build'
  dependsOn:
  - Resolve_Selected_Builds
  - Deploy_DB_After_Apps
  - Deploy_DB_Only
  condition: and(eq('${{ parameters.deployDatabase }}', 'true'), or(eq(dependencies.Deploy_DB_After_Apps.result, 'Succeeded'), eq(dependencies.Deploy_DB_Only.result, 'Succeeded')))
  variables:
    DbBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbBuildId'] ]
    DbPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbPipelineDefinitionId'] ]
  jobs:
  - job: TagDatabaseBuild
    displayName: 'Tag DB build'
    pool:
      name: '$(deploymentPool)'
      demands:
      - Agent.Name -equals $(resolveAgentName)
    steps:
    - checkout: none

    - template: pipelines/tag-builds.yml@templates
      parameters:
        tagTargets:
        - name: 'Alterna Telecom DB'
          buildId: '$(DbBuildId)'
          definitionId: '$(DbPipelineDefinitionId)'
          deployedTag: 'DEPLOYED-$(environmentName)-ATC-DB'
          lkgTag: 'LKG-$(environmentName)-ATC-DB'
          makeLkgUnique: true
