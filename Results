            if (dict.TryGetValue("Activities", out dicRetVal))
            {
                Activties = JsonConvert.DeserializeObject<List<String>>(dicRetVal.ToString()!);
            }
            else
            {
                throw new UnauthorizedAccessException("You Have No Permitions in This Application");
