using System.Net;
using Alterna.Archive.Core.Global;
using Microsoft.AspNetCore.Diagnostics;
using Microsoft.AspNetCore.Mvc;
using static NLog.NLogUtil;

namespace Alterna.Archive.Core.Controllers
{
    public class HomeController : BaseController
    {
        public IActionResult Index(String Param1)
        {
#if DEBUG
            if (Param1 is null)
            {
                // Param1 = "cHNhbW1pYXw0MzRkNmJkZC1hYjkxLTQ5M2UtYTViYS05OGY0ZTQ2ZGM3NTU="; // psammia
                // Param1 = "cGFib3VzZXJoYWx8MzYwMjZkZGQtNWIyYS00MTgwLTk5YmEtNTVjZDE1MTZiMjE3"; // Pierre
                Param1 = "Y2xhYmFiaWRpfDQ2NjVkMjFhLTY2ZjItNGNhNS1hZDMxLWRkYjg0OTMyNzM3MQ=="; // Christina
            }
            else
            {
                if (!Param1.Equals("Redirect"))
                {
                    // Param1 = "Y2xhYmFiaWRpfDQ2NjVkMjFhLTY2ZjItNGNhNS1hZDMxLWRkYjg0OTMyNzM3MQ==";
                }
            }


#endif
            try
            {
                if (String.IsNullOrEmpty(Param1))
                {
                    throw new ArgumentNullException(nameof(Param1));
                }

                if (Param1.Equals("Redirect"))
                {
                    try
                    {
                        GetSession("ArchiveData");
                    }
                    catch (Exception)
                    {
                        return RedirectDashboard();
                    }
                }
                else
                {
                    if (Request.Cookies.ContainsKey("ArchiveData"))
                    {
                        Request.Cookies.Append((new("ArchiveData", "")));
                    }

                    HttpContext.Session.Clear();

                    (String data, String user) InitVals = Common.Init(Param1);
                    Response.Headers["Origin"] = Request.Headers.Origin;
                    // Request.Cookies.Append(new("ArchiveData", InitVals.data));
                    Response.Cookies.Append("ArchiveData", InitVals.data);
                    HttpContext.Session.SetString("ArchiveData", InitVals.data);
                    HttpContext.Session.SetString("User", InitVals.user);
                }

                return View();
            }
            catch (Exception ex)
            {
                LogError(ex.Message, new CorrelationInfo()
                {
                    CorrelationId = Guid.NewGuid().ToString(),
                    UserName = $"Not Logged In Ticket: {Param1}",
                    RequestURL = "FrontEndHomeController",
                    StatusCode = HttpStatusCode.InternalServerError,
                    RDirection = RequestDirection.Processing,
                    RType = RequestType.POST
                }, ex);
                return RedirectDashboard();
            }
        }

        public IActionResult LogOut()
        {
            String Data = String.Empty;

            Data = GetSessionLogOut("ArchiveData");
            if (String.IsNullOrEmpty(Data))
            {
                return RedirectDashboard();
            }

            try
            {
                Dictionary<String, Object> dic = [];
                dic = Common.GenerateVariables(HttpContext, Data);

                Common.LogOut(new Common.LogOutClass(
                    dic["user"].ToString() ?? String.Empty,
                    dic["Company"].ToString() ?? String.Empty,
                    dic["Ticket"].ToString() ?? String.Empty
                ));
            }
            catch (Exception ex)
            {
                LogError(ex.Message, new CorrelationInfo()
                {
                    CorrelationId = Guid.NewGuid().ToString(),
                    UserName = "No User",
                    RequestURL = "FrontEndErrorHandler",
                    StatusCode = HttpStatusCode.InternalServerError,
                    RDirection = RequestDirection.Processing,
                    RType = RequestType.POST
                }, ex);
            }

            HttpContext.Session.Clear();
            Response.Cookies.Delete("ArchiveData");
            return RedirectDashboard();
        }

        [ResponseCache(Duration = 0, Location = ResponseCacheLocation.None, NoStore = true)]
        public IActionResult Error()
        {
            try
            {
                String Data = String.Empty;
                ErrorModel Em = new()
                {
                    ErrorCorrelationId = String.IsNullOrEmpty(GetErrorSession("CorrelationId"))
                        ? Guid.NewGuid().ToString()
                        : GetErrorSession("CorrelationId"),
                    ErrorMessage = GetErrorSession("ErrorMessage")
                };
                IExceptionHandlerPathFeature? execeptionHandlerPathFeture =
                    HttpContext.Features.Get<IExceptionHandlerPathFeature>();
                if (String.IsNullOrEmpty(Em.ErrorMessage))
                {
                    Em.ErrorMessage = execeptionHandlerPathFeture?.Error.Message + Environment.NewLine +
                                      execeptionHandlerPathFeture?.Error.StackTrace;
                }

                try
                {
                    Data = GetSession("ArchiveData");
                }
                catch
                {
                    LogError("Session Timed Out", new CorrelationInfo()
                    {
                        CorrelationId = Em.ErrorCorrelationId,
                        UserName = "No User",
                        RequestURL = "FrontEndErrorHandler",
                        StatusCode = HttpStatusCode.InternalServerError,
                        RDirection = RequestDirection.Processing,
                        RType = RequestType.POST
                    }, execeptionHandlerPathFeture?.Error);
                    return RedirectDashboard();
                }

                Dictionary<String, Object> dic = [];
                dic = Common.GenerateVariables(HttpContext, Data);

                Int64 exp = -1;
                if (dic.TryGetValue("Exp", out var value))
                {
                    exp = (Int64)value;
                }

                if (exp < DateTimeOffset.UtcNow.ToUnixTimeSeconds())
                {
                    LogError("Session Timed Out", new CorrelationInfo()
                    {
                        CorrelationId = Em.ErrorCorrelationId,
                        UserName = "No User",
                        RequestURL = "FrontEndErrorHandler",
                        StatusCode = HttpStatusCode.InternalServerError,
                        RDirection = RequestDirection.Processing,
                        RType = RequestType.POST
                    }, execeptionHandlerPathFeture?.Error);
                    return RedirectDashboard();
                }

                LogError(execeptionHandlerPathFeture?.Error.Message, new CorrelationInfo()
                {
                    CorrelationId = Em.ErrorCorrelationId,
                    UserName = dic["user"].ToString() ?? "No User",
                    RequestURL = "FrontEndErrorHandler",
                    StatusCode = HttpStatusCode.InternalServerError,
                    RDirection = RequestDirection.Processing,
                    RType = RequestType.POST
                }, execeptionHandlerPathFeture?.Error);
                return View(Em);
            }
            catch (Exception ex)
            {
                LogError(ex.Message, new CorrelationInfo()
                {
                    CorrelationId = Guid.NewGuid().ToString(),
                    UserName = "No User",
                    RequestURL = "FrontEndErrorHandler",
                    StatusCode = HttpStatusCode.InternalServerError,
                    RDirection = RequestDirection.Processing,
                    RType = RequestType.POST
                }, ex);
                return RedirectDashboard();
            }
        }


        public IActionResult RedirectDashboard()
        {
            HttpContext.Session.Clear();
            Response.Cookies.Delete("ArchiveData");
            return View("RedirectDashboard");
        }
    }
}
