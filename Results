## 7. Replace `GenerateVariablesLkp`

This one is important because it is used by `_Layout.cshtml`. It should **never crash the page** because of an old cookie.

```csharp
public static (bool, Dictionary<string, object>) GenerateVariablesLkp(HttpContext context, string session)
{
    Dictionary<string, object> retDict = [];
    bool expired = false;

    if (!TryDecodeCurrentSession(session, out string plainSession, out bool shouldRewriteCookie))
    {
        DeleteArchiveCookieAndSession(context);
        return (true, retDict);
    }

    try
    {
        retDict = ParseSessionPlainText(plainSession);

        long exp = -1;

        if (retDict.TryGetValue("Exp", out var value))
        {
            exp = Convert.ToInt64(value);
        }

        if (exp < DateTimeOffset.UtcNow.ToUnixTimeSeconds())
        {
            expired = true;
        }

        if (expired)
        {
            DeleteArchiveCookieAndSession(context);
            return (true, retDict);
        }

        retDict["Exp"] = DateTimeOffset.UtcNow.ToUnixTimeSeconds() + (TTL * 60);

        string fullName = "Invalid User";

        if (retDict.TryGetValue("FullName", out var value2))
        {
            fullName = value2?.ToString() ?? "Invalid User";
        }

        string newSession = GenerateSetionVariable(retDict);

        SetArchiveCookieAndSession(context, newSession, fullName);

        context.Response.Headers["Origin"] = context.Request.Headers.Origin;

        return (false, retDict);
    }
    catch
    {
        DeleteArchiveCookieAndSession(context);
        return (true, []);
    }
}
