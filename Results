                  enableRollbackOnHealthCheckFailure: true
                  enableLocalBackup: true
                  backupRoot: '$(backupRoot)'
                  backupPath: '$(backupRoot)\FRONTEND\$(Build.BuildId)'

  - ${{ if and(eq(parameters.deployBackend, true), eq(parameters.deployFrontend, true)) }}:
      - stage: Rollback_Backend_After_Frontend_Failure
        displayName: 'Rollback Backend because Frontend failed'
        dependsOn:
          - Deploy_Applications
        condition: and(always(), eq(dependencies.Deploy_Applications.outputs['DeployBackend.DeployBackend.publishSuccessOutcome.DeploymentHealthy'], 'true'), ne(dependencies.Deploy_Applications.outputs['DeployFrontend.DeployFrontend.publishSuccessOutcome.DeploymentHealthy'], 'true'))
        jobs:
          - template: pipelines/rollback-iis.yml@templates
            parameters:
              deploymentName: 'RollbackBackendAfterFrontendFailure'
