private static void SetArchiveCookieAndSession(HttpContext context, string sessionValue, string fullName)
{
    context.Response.Cookies.Append(
        ArchiveCookieName,
        sessionValue,
        GetArchiveCookieOptions()
    );

    context.Session.SetString(ArchiveCookieName, sessionValue);
    context.Session.SetString("User", fullName);
}

private static void DeleteArchiveCookieAndSession(HttpContext context)
{
    context.Response.Cookies.Delete(
        ArchiveCookieName,
        new CookieOptions
        {
            Path = "/"
        }
    );

    context.Session.Remove(ArchiveCookieName);
    context.Session.Remove("User");
}
```

If your cookie was created with a specific `Domain`, you must also include the same `Domain` when deleting it.

