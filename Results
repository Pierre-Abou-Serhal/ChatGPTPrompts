# 5) Replace `Tag_DB_DEPLOYED` with this

This keeps your DB tagging behavior.

```yaml
- stage: Tag_DB_DEPLOYED
  displayName: 'Tag deployed database build'
  dependsOn:
  - Resolve_Selected_Builds
  - Deploy_DB_After_Apps
  - Deploy_DB_Only
  condition: and(
              eq('${{ parameters.deployDatabase }}', 'true'),
              or(
                eq(dependencies.Deploy_DB_After_Apps.result, 'Succeeded'),
                eq(dependencies.Deploy_DB_Only.result, 'Succeeded')
              )
            )
  variables:
    DbBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbBuildId'] ]
    DbPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbPipelineDefinitionId'] ]
  jobs:
  - job: TagDatabaseBuild
    displayName: 'Tag DB build'
    pool:
      name: '$(deploymentPool)'
      demands:
      - Agent.Name -equals $(resolveAgentName)
    steps:
    - checkout: none

    - template: pipelines/tag-builds.yml@templates
      parameters:
        tagTargets:
        - name: 'Alterna Telecom DB'
          buildId: '$(DbBuildId)'
          definitionId: '$(DbPipelineDefinitionId)'
          deployedTag: 'DEPLOYED-$(environmentName)-ATC-DB'
          lkgTag: 'LKG-$(environmentName)-ATC-DB'
          makeLkgUnique: true
```

