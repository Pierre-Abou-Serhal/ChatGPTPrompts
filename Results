resources:
  repositories:
  - repository: templates
    type: git
    name: 'Azure Templates/Azure Templates'
    ref: refs/heads/main

trigger:
  branches:
    include:
    - sit-temp

stages:
# =========================
# BUILD
# =========================
- stage: Build
  displayName: 'Build & Publish Artifact'
  jobs:
  - template: pipelines/build-dotnet-core-webapi.yml@templates
    parameters:
      jobName: 'BuildJob'
      jobDisplayName: 'Build Alterna Logger Backend'
      buildPool: 'Build Pool'
      buildAgentName: 'UAT-ALTERNA-DK1'
      buildConfiguration: 'Release'
      restoreProjects: '**/*.csproj'
      runTests: false
      testProjects: ''
      publishProject: 'Logger/Logger.csproj'
      nugetConfigPath: 'nuget.config'
      zipName: 'Alterna-Logger-drop.zip'
      publishOutputFolder: '$(Build.ArtifactStagingDirectory)\Alterna-Logger'
      deploymentMode: 'self-contained'
      targetRuntime: 'win-x64'
      produceSingleFile: true
      readyToRun: false
      trim: false

# =========================
# DEPLOY SIT
# =========================
- stage: Deploy_Service_SIT
  displayName: Deploy Windows Service (SIT)
  jobs:
  - template: pipelines/deploy-windows-service.yml@templates
    parameters:
      deploymentName: 'DeploySvcJob'
      deploymentDisplayName: 'Deploy Windows Service - SIT'
      environmentName: 'SIT'
      deployPool: 'Deployment Pool'
      deployAgentName: 'SIT-ALTERNA-BN1'
      variableGroup: 'SIT_VARIABLE_GROUP'
      zipName: 'Alterna-Logger-drop.zip'
      serviceName: 'LoggerServiceAzureDevOps'
      serviceDisplayName: 'Logger Service Azure DevOps'
      serviceDescription: 'Logger Service Azure DevOps that logs data from applications to the database.'
      serviceTargetPath: 'C:\Alterna-Backend-Services\AlternaLoggerAzureDevOps'
      serviceExeName: 'API.exe'
      serviceStartType: 'auto'
      createServiceIfMissing: true
      updateBinPathIfExists: true
      #serviceUser: 'MYDOMAIN\svc_myservice'
      #servicePassword: '$(SvcPassword)'   # from variable group (secret)
      cleanTargetBeforeCopy: true
      #cleanExcludeCsv: 'logs,Keys'
      enableJsonTransform: true
      jsonFiles: |
        **/appsettings.json
      #enableXmlConfigTransform: true
      #xmlConfigFiles:
        #- '**/MyCompany.MyService.exe.config'
        #- '**/MyCompany.MyService.config'
      #xmlVariableValues:
        # these become Env:KEY and will replace <add key="KEY" value="..."/>
        #ConnectionStrings__Main: '$(MainDbConn)'     # from variable group
        #Redis__Host: '$(RedisHost)'                  # from variable group
        #Redis__Password: '$(RedisPassword)'          # from variable group (secret)
      #enableCustomXmlEdits: true
      #customXmlEdits:
        # attribute update example
        #- file: '**/MyCompany.MyService.exe.config'
          #xpath: '/configuration/applicationSettings/MyCompany.MyService.Properties.Settings/setting[@name="ApiBaseUrl"]/value'
          #variable: 'ApiBaseUrl'
        # another attribute example (if you target an attribute)
        #- file: '**/MyCompany.MyService.exe.config'
          #xpath: '/configuration/system.serviceModel/client/endpoint[@name="SomeEndpoint"]/@address'
          #variable: 'SomeEndpointAddress'
      #customXmlVariableValues:
        #ApiBaseUrl: '$(ApiBaseUrl)'                        # from variable group
        #SomeEndpointAddress: '$(SomeEndpointAddress)'      # from variable group
