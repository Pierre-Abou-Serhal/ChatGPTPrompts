Where is the visualstudio demand in this template ?

parameters:
- name: jobName
  type: string
  default: 'BuildJob'

- name: jobDisplayName
  type: string
  default: 'Build (.NET Framework)'

- name: buildPool
  type: string

- name: buildAgentName
  type: string

# Visual Studio used by VSBuild (self-hosted agent must have VS/Build Tools installed)
- name: vsVersion
  type: string
  default: 'latest'

- name: buildPlatform
  type: string
  default: 'Any CPU'

- name: buildConfiguration
  type: string
  default: 'Release'

# Restore/build input
- name: solution
  type: string
  default: '**/*.sln'

- name: nugetConfigPath
  type: string
  default: 'nuget.config'

# Tests
- name: runTests
  type: boolean
  default: false

- name: testAssemblies
  type: string
  default: |
    **\*test*.dll
    **\*tests*.dll
    !**\obj\**
    !**\bin\ref\**
    !**\*TestAdapter.dll
    !**\*vstest*.dll

# “Publish” / packaging
# For .NET Framework web apps, the closest equivalent of dotnet publish is MSBuild Web Deploy packaging
- name: publishProject
  type: string
  default: ''   # optional; if empty we build the whole solution

- name: packageLocation
  type: string
  default: '$(Build.ArtifactStagingDirectory)\publish'

- name: zipName
  type: string
  default: 'WebApp.zip'

- name: artifactName
  type: string
  default: 'drop'

jobs:
- job: ${{ parameters.jobName }}
  displayName: ${{ parameters.jobDisplayName }}

  pool:
    name: ${{ parameters.buildPool }}
    demands:
    - Agent.Name -equals ${{ parameters.buildAgentName }}

  steps:
  - checkout: self
    clean: true

  # NuGet tooling
  - task: NuGetToolInstaller@1
    displayName: 'Use NuGet'

  # Restore using nuget.config (classic .NET Framework)
  - task: NuGetCommand@2
    displayName: 'Restore'
    inputs:
      command: 'restore'
      restoreSolution: '${{ parameters.solution }}'
      feedsToUse: 'config'
      nugetConfigPath: '${{ parameters.nugetConfigPath }}'

  # Build (solution)
  - task: VSBuild@1
    displayName: 'Build'
    inputs:
      solution: '${{ parameters.solution }}'
      vsVersion: '${{ parameters.vsVersion }}'
      platform: '${{ parameters.buildPlatform }}'
      configuration: '${{ parameters.buildConfiguration }}'
      clean: true
      msbuildArgs: >
        /p:SkipInvalidConfigurations=true

  # Tests (optional)
  # - task: VSTest@2
  #   displayName: 'Test'
  #   condition: and(succeeded(), eq('${{ parameters.runTests }}', 'true'))
  #   inputs:
  #     testSelector: 'testAssemblies'
  #     testAssemblyVer2: '${{ parameters.testAssemblies }}'
  #     searchFolder: '$(System.DefaultWorkingDirectory)'
  #     platform: '${{ parameters.buildPlatform }}'
  #     configuration: '${{ parameters.buildConfiguration }}'
  #     diagnosticsEnabled: true

  # Publish/Package the web project (Web Deploy Package)
  # This creates a deployable package under packageLocation (closest to dotnet publish)
  - task: MSBuild@1
    displayName: 'Publish (Package)'
    condition: and(succeeded(), ne('${{ parameters.publishProject }}', ''))
    inputs:
      solution: '${{ parameters.publishProject }}'
      platform: '${{ parameters.buildPlatform }}'
      configuration: '${{ parameters.buildConfiguration }}'
      clean: false
      msbuildArguments: >
        /p:DeployOnBuild=true
        /p:WebPublishMethod=Package
        /p:PackageAsSingleFile=true
        /p:SkipInvalidConfigurations=true
        /p:PackageLocation="${{ parameters.packageLocation }}"
        /p:AutoParameterizationWebConfigConnectionStrings=false

  # Zip package output (same as your dotnet core template)
  - task: ArchiveFiles@2
    displayName: 'Zip publish output'
    inputs:
      rootFolderOrFile: '${{ parameters.packageLocation }}'
      includeRootFolder: false
      archiveType: 'zip'
      archiveFile: '$(Build.ArtifactStagingDirectory)\${{ parameters.zipName }}'
      replaceExistingArchive: true

  # Publish artifact
  - task: PublishBuildArtifacts@1
    displayName: 'Publish Build Artifact'
    inputs:
      PathtoPublish: '$(Build.ArtifactStagingDirectory)\${{ parameters.zipName }}'
      ArtifactName: '${{ parameters.artifactName }}'
      publishLocation: 'Container'
