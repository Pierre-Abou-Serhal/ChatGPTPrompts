parameters:
- name: jobName
  type: string
  default: 'BuildJob'

- name: jobDisplayName
  type: string
  default: 'Build (.NET Framework)'

- name: buildPool
  type: string

- name: buildAgentName
  type: string

- name: vsVersion
  type: string
  default: '17.0'

- name: buildPlatform
  type: string
  default: 'Any CPU'

- name: buildConfiguration
  type: string
  default: 'Release'

- name: solution
  type: string
  default: '**/*.sln'

- name: nugetConfigPath
  type: string
  default: 'nuget.config'

- name: runTests
  type: boolean
  default: false

- name: testAssemblies
  type: string
  default: |
    **\*test*.dll
    **\*tests*.dll
    !**\obj\**
    !**\bin\ref\**
    !**\*TestAdapter.dll
    !**\*vstest*.dll

- name: publishProject
  type: string
  default: ''

- name: packageLocation
  type: string
  default: '$(Build.ArtifactStagingDirectory)\publish'

- name: zipName
  type: string
  default: 'WebApp.zip'

- name: artifactName
  type: string
  default: 'drop'

jobs:
- job: ${{ parameters.jobName }}
  displayName: ${{ parameters.jobDisplayName }}

  pool:
    name: ${{ parameters.buildPool }}
    demands:
    - Agent.Name -equals ${{ parameters.buildAgentName }}

  steps:
  - checkout: self
    clean: true

  - task: NuGetCommand@2
    displayName: 'Restore'
    inputs:
      command: 'restore'
      restoreSolution: '${{ parameters.solution }}'
      feedsToUse: 'config'
      nugetConfigPath: '${{ parameters.nugetConfigPath }}'

  - task: VSBuild@1
    displayName: 'Build'
    inputs:
      solution: '${{ parameters.solution }}'
      vsVersion: '${{ parameters.vsVersion }}'
      platform: '${{ parameters.buildPlatform }}'
      configuration: '${{ parameters.buildConfiguration }}'
      clean: true
      msbuildArgs: >
        /p:SkipInvalidConfigurations=true
        /p:VisualStudioVersion=${{ parameters.vsVersion }}

  - task: VSBuild@1
    displayName: 'Publish (Package)'
    condition: and(succeeded(), ne('${{ parameters.publishProject }}', ''))
    inputs:
      solution: '${{ parameters.publishProject }}'
      vsVersion: '${{ parameters.vsVersion }}'
      platform: '${{ parameters.buildPlatform }}'
      configuration: '${{ parameters.buildConfiguration }}'
      clean: false
      msbuildArgs: >
        /p:VisualStudioVersion=${{ parameters.vsVersion }}
        /p:DeployOnBuild=true
        /p:WebPublishMethod=Package
        /p:PackageAsSingleFile=true
        /p:SkipInvalidConfigurations=true
        /p:PackageLocation="${{ parameters.packageLocation }}"
        /p:AutoParameterizationWebConfigConnectionStrings=false

  - task: ArchiveFiles@2
    displayName: 'Zip publish output'
    inputs:
      rootFolderOrFile: '${{ parameters.packageLocation }}'
      includeRootFolder: false
      archiveType: 'zip'
      archiveFile: '$(Build.ArtifactStagingDirectory)\${{ parameters.zipName }}'
      replaceExistingArchive: true

  - task: PublishBuildArtifacts@1
    displayName: 'Publish Build Artifact'
    inputs:
      PathtoPublish: '$(Build.ArtifactStagingDirectory)\${{ parameters.zipName }}'
      ArtifactName: '${{ parameters.artifactName }}'
      publishLocation: 'Container'
