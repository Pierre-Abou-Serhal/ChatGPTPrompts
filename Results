name: LOGGER_REL_${{ parameters.targetEnvironment }}_$(Date:yyyyMMdd).$(Rev:r)

parameters:
- name: targetEnvironment
  type: string
  default: SIT
  values:
  - SIT
  - UAT
  - PROD
  displayName: 'Target Environment'

- name: deployService
  type: boolean
  default: false
  displayName: 'Deploy Logger Service'

- name: deployDatabase
  type: boolean
  default: false
  displayName: 'Deploy Logger Database'

- name: serviceBuildNumber
  type: string
  default: '__EMPTY__'
  displayName: 'Service Build Number'

- name: dbBuildNumber
  type: string
  default: '__EMPTY__'
  displayName: 'DB Build Number'

resources:
  repositories:
  - repository: templates
    type: git
    name: 'Azure Templates/Azure Templates'
    ref: refs/heads/main

trigger: none
pr: none

variables:
- name: deploymentPool
  value: 'Deployment Pool'

- name: buildSourceBranchRegex
  value: '^refs/heads/(release|hotfix)/'

- name: serviceArtifactName
  value: 'logger-service-drop'

- name: dbArtifactName
  value: 'alterna-logger-db-drop'

- name: serviceZipName
  value: 'Alterna-Logger-drop.zip'

- name: dbDacpacFileName
  value: 'DatabaseProjectAlterna.Logger.dacpac'

