- name: nugetConfigPath
  type: string
  default: 'nuget.config'

- name: runTests
  type: boolean
  default: false

- name: testAssemblies
  type: string
  default: |
    **\*test*.dll
    **\*tests*.dll
    !**\obj\**
    !**\bin\ref\**
    !**\*TestAdapter.dll
    !**\*vstest*.dll

