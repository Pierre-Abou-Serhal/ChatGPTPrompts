      - Agent.Name -equals $(resolveAgentName)
    steps:
    - checkout: none

    - template: pipelines/tag-builds.yml@templates
      parameters:
        tagTargets:
        - name: 'Alterna-DataExport API'
          buildId: '$(ApiBuildId)'
          definitionId: '$(ApiPipelineDefinitionId)'
          deployedTag: 'DEPLOYED-$(environmentName)-DTE-API'
          lkgTag: 'LKG-$(environmentName)-DTE-API'
          makeLkgUnique: true

- stage: Deploy_DB_After_API
  displayName: 'Deploy DB to $(environmentName) after API'
  dependsOn:
  - Resolve_Selected_Builds
  - Tag_API_LKG
  condition: and(succeeded('Tag_API_LKG'), eq('${{ parameters.deployDatabase }}', 'true'), eq('${{ parameters.deployApi }}', 'true'))
  variables:
    DbPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbPipelineDefinitionId'] ]
    DbBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbBuildId'] ]
    DbSourceBranch: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbSourceBranch'] ]
  jobs:
  - template: pipelines/deploy-database.yml@templates
    parameters:
      jobDependsOn: []
      jobCondition: succeeded()
      deploymentName: 'DeployDb'
      deploymentDisplayName: 'Deploy DataExport database'
      environmentName: '${{ parameters.targetEnvironment }}'
      deployPool: '$(deploymentPool)'
      deployAgentName: '$(dbAgentName)'
      artifactName: '$(dbArtifactName)'
      artifactBuildType: 'specific'
      artifactProject: '$(System.TeamProject)'
      artifactDefinitionId: '$(DbPipelineDefinitionId)'
      artifactBuildId: '$(DbBuildId)'
      artifactBranch: '$(DbSourceBranch)'
      targetConnectionString: '$(AppSettings.DataExportConnectionString)'

- stage: Deploy_DB_Only
  displayName: 'Deploy DB to $(environmentName)'
  dependsOn:
  - Resolve_Selected_Builds
  - Approval_Release
  condition: and(succeeded(), eq('${{ parameters.deployDatabase }}', 'true'), eq('${{ parameters.deployApi }}', 'false'))
  variables:
    DbPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbPipelineDefinitionId'] ]
    DbBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbBuildId'] ]
    DbSourceBranch: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbSourceBranch'] ]
  jobs:
  - template: pipelines/deploy-database.yml@templates
    parameters:
      jobDependsOn: []
      jobCondition: succeeded()
      deploymentName: 'DeployDb'
      deploymentDisplayName: 'Deploy DataExport database'
      environmentName: '${{ parameters.targetEnvironment }}'
      deployPool: '$(deploymentPool)'
      deployAgentName: '$(dbAgentName)'
      artifactName: '$(dbArtifactName)'
      artifactBuildType: 'specific'
      artifactProject: '$(System.TeamProject)'
      artifactDefinitionId: '$(DbPipelineDefinitionId)'
      artifactBuildId: '$(DbBuildId)'
      artifactBranch: '$(DbSourceBranch)'
      targetConnectionString: '$(AppSettings.DataExportConnectionString)'

- stage: Tag_DB_DEPLOYED
  displayName: 'Tag deployed database build'
  dependsOn:
  - Resolve_Selected_Builds
  - Deploy_DB_After_API
  - Deploy_DB_Only
  condition: and(eq('${{ parameters.deployDatabase }}', 'true'), or(eq(dependencies.Deploy_DB_After_API.result, 'Succeeded'), eq(dependencies.Deploy_DB_Only.result, 'Succeeded')))
  variables:
    DbBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbBuildId'] ]
    DbPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbPipelineDefinitionId'] ]
  jobs:
  - job: TagDatabaseBuild
    displayName: 'Tag DB build'
    pool:
      name: '$(deploymentPool)'
      demands:
      - Agent.Name -equals $(resolveAgentName)
    steps:
    - checkout: none

    - template: pipelines/tag-builds.yml@templates
      parameters:
        tagTargets:
        - name: 'Alterna-DataExport DB'
          buildId: '$(DbBuildId)'
          definitionId: '$(DbPipelineDefinitionId)'
          deployedTag: 'DEPLOYED-$(environmentName)-DTE-DB'
          lkgTag: 'LKG-$(environmentName)-DTE-DB'
          makeLkgUnique: true
```

Two important notes before you paste these:

The pipeline definition names inside the release and preview flows must match the actual Azure DevOps pipeline names you will end up with, for example `BUILD - API - Alterna-DataExport` and `BUILD - DB - Alterna-DataExport`. Your current pipelines are still SIT-named versions like `DTE_API_SIT_...` and `DTE_DB_SIT_...`, so rename the Azure DevOps pipeline definitions accordingly if you want the resolve step to work as written. 

For UAT and PROD, I used placeholders like `UAT_VARIABLE_GROUP`, `PROD_VARIABLE_GROUP`, `UAT-ALTERNA-BN1`, and the API health-check URLs. Replace those with your real values before running outside SIT. The deploy templates already support this environment-driven pattern.

