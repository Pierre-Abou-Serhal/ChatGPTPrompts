    jobs:
      - template: pipelines/build-dotnet-framework-webapi.yml@templates
        parameters:
          jobName: 'Build_API'
          jobDisplayName: 'Build Web API'
          buildPool: 'Build Pool'
          buildAgentName: 'UAT-ALTERNA-DK1'
