        public static T ApiCall<T>(Object Request, String Endpoint)
        {
            String JsonRequest = JsonConvert.SerializeObject(Request, Formatting.Indented);
            HttpContent content = new StringContent(JsonRequest, Encoding.UTF8, "application/json");
            HttpClient client = new();
            Task<HttpResponseMessage> HttpResp = client.PostAsync(BaseURL + Endpoint, content);
            HttpResp.Wait();
            Task<String> respString = HttpResp.Result.Content.ReadAsStringAsync();
            respString.Wait();
            T RetRes = JsonConvert.DeserializeObject<T>(respString.Result)!;
            return RetRes;
        }

