## 3. Create a reusable Data Export call method

This avoids duplicating the same `Post` logic inside the loop.

```csharp
private DataExportGenerateFileContentResponse GenerateDataExportFileContent(
    string correlationId,
    string fileCode,
    List<Dictionary<string, string>> bodyRecords)
{
    string dataExportGenerateFileContentUrl =
        $"{_globalSettings.DataExportUrl}GenerateFileContent";

    DataExportGenerateFileContentRequest dataExportGenerateFileContentRequest = new()
    {
        CorrelationId = correlationId,
        FileCode = fileCode,
        BodyRecords = bodyRecords
    };

    DataExportGenerateFileContentResponse responseData =
        Post<DataExportGenerateFileContentResponse>(
            dataExportGenerateFileContentRequest,
            dataExportGenerateFileContentUrl);

    if (responseData is not { WebResp.StatusCode: HttpStatusCode.OK })
    {
        throw new CustomExceptions.SGBLBadRequestException(
            string.Join(',', responseData.WebResp.Errors));
    }

    return responseData;
}
```

