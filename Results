        /// <summary>
        /// The convert2utf8.
        /// </summary>
        /// <param name="inputFilePath">The inputFilePath.</param>
        /// <param name="outputFilePath">The outputFilePath.</param>
        public static void Convert2Utf8(string inputFilePath, string outputFilePath, string subFolderName, string codePage = "Windows-1256")
        {
            string fileContent = File.ReadAllText(inputFilePath, System.Text.Encoding.GetEncoding(codePage));
            if (!Directory.Exists(outputPath + pathSeparator + subFolderName))
            {
                Directory.CreateDirectory(outputPath + pathSeparator + subFolderName);
            }
            File.WriteAllText(outputPath + pathSeparator + subFolderName + pathSeparator + Path.GetFileName(outputFilePath), fileContent, new System.Text.UTF8Encoding(false));
        }

