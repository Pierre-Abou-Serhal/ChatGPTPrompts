SELECT
    comp.Code AS CompanyCode,
    comp.CompanyName,
    c.Id AS ContainerId,
    c.Code AS ContainerCode,
    c.StatusCode AS ContainerStatus,
    cs.CreatedBy AS SentStatusCreatedBy,
    cs.CreatedDate AS SentStatusCreatedDate,
    f.Id AS FileId,
    f.Name AS FileName,
    f.FileTypeCode,
    f.StatusCode AS FileStatus,
    f.FromDate,
    f.ToDate
FROM dbo.t_Container c
INNER JOIN dbo.t_CurrentContainerFileRelationship ccfr
    ON ccfr.ContainerId = c.Id
INNER JOIN dbo.t_File f
    ON f.Id = ccfr.FileId
INNER JOIN dbo.t_Company comp
    ON comp.Code = c.CompanyCode
INNER JOIN dbo.t_ContainerStatus cs
    ON cs.ContainerId = c.Id
   AND cs.StatusCode = 'SENT'
   AND cs.isCurrentStatus = 1
WHERE c.StatusCode = 'SENT'
  AND c.isDeleted = 0
  AND f.isDeleted = 0
ORDER BY comp.Code, c.Code, f.Name;
