```yaml
name: DATAGATEWAY_REL_SIT_$(Date:yyyyMMdd).$(Rev:r)

parameters:
- name: deployApi
  type: boolean
  default: false

- name: apiBuildNumber
  type: string
  default: '__EMPTY__'

resources:
  repositories:
  - repository: templates
    type: git
    name: 'Azure Templates/Azure Templates'
    ref: refs/heads/main

trigger: none
pr: none

variables:
- group: SIT_VARIABLE_GROUP

- name: apiPipelineName
  value: 'SIT - BUILD - API - DataGateway'

stages:

- stage: Resolve_Selected_Build
  displayName: 'Resolve selected build number'
  jobs:
  - job: ResolveBuildNumber
    displayName: 'Resolve pipeline name and build number'
    pool:
      name: 'Deployment Pool'
      demands:
      - Agent.Name -equals SIT-ALTERNA-BN1
    steps:
    - checkout: none

    - powershell: |
        $ErrorActionPreference = 'Stop'

        $collectionUri = "$(System.CollectionUri)".TrimEnd('/')
        $projectName   = [System.Uri]::EscapeDataString("$(System.TeamProject)")
        $apiVersion    = '7.1'

        $headers = @{
          Authorization = "Bearer $env:SYSTEM_ACCESSTOKEN"
        }

        $deployApi = "${{ parameters.deployApi }}".ToLower() -eq 'true'

        if (-not $deployApi) {
          throw 'At least one deployment target must be selected: API.'
        }

        function Normalize-BuildNumber {
          param([string]$BuildNumber)

          if ($BuildNumber -eq '__EMPTY__') {
            return ''
          }

          return $BuildNumber
        }

        function Resolve-DefinitionIdByName {
          param(
            [string]$Label,
            [string]$PipelineName
          )

          if ([string]::IsNullOrWhiteSpace($PipelineName)) {
            throw "$Label pipeline name is empty."
          }

          $encodedName = [System.Uri]::EscapeDataString($PipelineName)
          $uri = "{0}/{1}/_apis/build/definitions?name={2}&includeAllProperties=false&includeLatestBuilds=false&api-version={3}" -f `
            $collectionUri,
            $projectName,
            $encodedName,
            $apiVersion

          Write-Host "Resolving $Label pipeline name [$PipelineName]"
          $response = Invoke-RestMethod -Method Get -Uri $uri -Headers $headers

          if (-not $response.value -or $response.count -lt 1) {
            throw "No pipeline definition found for $Label with name [$PipelineName]."
          }

          $exactMatches = @($response.value | Where-Object { $_.name -eq $PipelineName })

          if ($exactMatches.Count -eq 0) {
            throw "No exact pipeline definition match found for $Label with name [$PipelineName]."
          }

          if ($exactMatches.Count -gt 1) {
            throw "More than one exact pipeline definition match was found for [$PipelineName]. Make the pipeline name unique."
          }

          $definition = $exactMatches[0]

          Write-Host "$Label definition resolved:"
          Write-Host "  Definition ID   = $($definition.id)"
          Write-Host "  Definition Name = $($definition.name)"

          return $definition.id
        }

        function Resolve-Build {
          param(
            [string]$Label,
            [string]$PipelineName,
            [string]$BuildNumber
          )

          $BuildNumber = Normalize-BuildNumber -BuildNumber $BuildNumber

          if ([string]::IsNullOrWhiteSpace($BuildNumber)) {
            throw "$Label build number is required because deployment of $Label was selected."
          }

          $definitionId = Resolve-DefinitionIdByName -Label $Label -PipelineName $PipelineName
          $encodedBuildNumber = [System.Uri]::EscapeDataString($BuildNumber)

          $uri = "{0}/{1}/_apis/build/builds?definitions={2}&buildNumber={3}&statusFilter=completed&resultFilter=succeeded&`$top=1&queryOrder=finishTimeDescending&api-version={4}" -f `
            $collectionUri,
            $projectName,
            $definitionId,
            $encodedBuildNumber,
            $apiVersion

          Write-Host "Resolving $Label build number [$BuildNumber] using pipeline definition [$definitionId]"
          $response = Invoke-RestMethod -Method Get -Uri $uri -Headers $headers

          if (-not $response.value -or $response.count -lt 1) {
            throw "No succeeded build found for $Label with build number [$BuildNumber] in pipeline [$PipelineName]."
          }

          $build = $response.value[0]

          if ($build.sourceBranch -ne 'refs/heads/sit') {
            throw "$Label build [$BuildNumber] was resolved, but it belongs to branch [$($build.sourceBranch)] instead of [refs/heads/sit]."
          }

          Write-Host "$Label build resolved:"
          Write-Host "  Build ID         = $($build.id)"
          Write-Host "  Build Number     = $($build.buildNumber)"
          Write-Host "  Definition ID    = $definitionId"
          Write-Host "  Definition Name  = $PipelineName"
          Write-Host "  Branch           = $($build.sourceBranch)"

          Write-Host "##vso[task.setvariable variable=${Label}PipelineDefinitionId;isOutput=true]$definitionId"
          Write-Host "##vso[task.setvariable variable=${Label}BuildId;isOutput=true]$($build.id)"
          Write-Host "##vso[task.setvariable variable=${Label}ResolvedBuildNumber;isOutput=true]$($build.buildNumber)"
        }

        Resolve-Build -Label 'Api' -PipelineName '$(apiPipelineName)' -BuildNumber '${{ parameters.apiBuildNumber }}'
      name: Resolve
      displayName: 'Resolve pipeline name and build number'
      env:
        SYSTEM_ACCESSTOKEN: $(System.AccessToken)

- stage: Approval_SIT_Release
  displayName: 'Approval for SIT release'
  dependsOn:
  - Resolve_Selected_Build
  condition: succeeded('Resolve_Selected_Build')
  jobs:
  - job: WaitForBusinessApproval
    displayName: 'Wait for Business Approval'
    pool: server
    timeoutInMinutes: 1500
    steps:
    - task: ManualValidation@0
      timeoutInMinutes: 1440
      inputs:
        notifyUsers: 'SGBL\pabouserhal'
        instructions: 'Approve SIT DataGateway deployment.'
        onTimeout: 'reject'

  - job: WaitForManagementApproval
    displayName: 'Wait for Management Approval'
    dependsOn: WaitForBusinessApproval
    pool: server
    timeoutInMinutes: 1500
    steps:
    - task: ManualValidation@0
      timeoutInMinutes: 1440
      inputs:
        notifyUsers: 'SGBL\kabbas'
        instructions: 'Approve SIT DataGateway deployment.'
        onTimeout: 'reject'

- stage: Deploy_API_SIT
  displayName: 'Deploy API to SIT'
  dependsOn:
  - Resolve_Selected_Build
  - Approval_SIT_Release
  condition: and(succeeded(), eq('${{ parameters.deployApi }}', 'true'))
  variables:
    ApiPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Build.ResolveBuildNumber.outputs['Resolve.ApiPipelineDefinitionId'] ]
    ApiBuildId: $[ stageDependencies.Resolve_Selected_Build.ResolveBuildNumber.outputs['Resolve.ApiBuildId'] ]
  jobs:
  - template: pipelines/deploy-iis.yml@templates
    parameters:
      jobDependsOn: []
      jobCondition: succeeded()
      deploymentName: 'DeployAPI'
      deploymentDisplayName: 'Deploy DataGateway API to SIT (IIS)'
      environmentName: 'SIT'
      deployPool: 'Deployment Pool'
      deployAgentName: 'SIT-ALTERNA-BN1'
      variableGroup: 'SIT_VARIABLE_GROUP'
      componentName: 'API'
      artifactName: 'datagateway-api-drop'
      artifactBuildType: 'specific'
      artifactProject: '$(System.TeamProject)'
      artifactDefinitionId: '$(ApiPipelineDefinitionId)'
      artifactBuildId: '$(ApiBuildId)'
      artifactBranch: 'refs/heads/sit'
      zipName: 'DataGatewayService.zip'
      siteName: 'AlternaDataGatewayServiceAzureDevOps'
      appPoolName: 'AlternaDataGatewayServiceAzureDevOps'
      iisTargetPath: 'C:\inetpub\wwwroot\AlternaDataGatewayService-AzureDevOps-BN1'
      cleanTargetBeforeCopy: true
      cleanExcludeCsv: ''
      enableJsonTransform: false
      jsonFiles: ''
      enableXmlConfigTransform: true
      xmlConfigFiles:
      - '**/App.config'
      - '**/API.dll.config'
      xmlVariableValues:
        API_TOKEN_CHECK: $(API_TOKEN_CHECK)
        CONN_STRING_User: $(CONN_STRING_User)
        NLog_MaxArchiveDays: $(NLog_MaxArchiveDays)
      enableCustomXmlEdits: true
      customXmlVariableValues:
        TOKEN_GET_CUSTOMER_APPORTEUR_AFFAIRE: $(TOKEN_GET_CUSTOMER_APPORTEUR_AFFAIRE)
        TOKEN_GET_CUSTOMER_AMS: $(TOKEN_GET_CUSTOMER_AMS)
        TOKEN_GET_CUSTOMER_FRESH_ACCOUNT: $(TOKEN_GET_CUSTOMER_FRESH_ACCOUNT)
        TOKEN_GET_CUSTOMER_APPORTEUR_AFFAIRE_HAVE_ACCESS_TO_GET_AVAILABLE_VARIABLES: $(TOKEN_GET_CUSTOMER_APPORTEUR_AFFAIRE_HAVE_ACCESS_TO_GET_AVAILABLE_VARIABLES)
        TOKEN_GET_COMPANY_APPORTEUR_AFFAIRE: $(TOKEN_GET_COMPANY_APPORTEUR_AFFAIRE)
        TOKEN_GET_T24USER_AMS: $(TOKEN_GET_T24USER_AMS)
        TOKEN_LDAP_PSS: $(TOKEN_LDAP_PSS)
        TOKEN_GET_PRODUCT_FRESH_ACCOUNT: $(TOKEN_GET_PRODUCT_FRESH_ACCOUNT)
      customXmlEdits:
      - file: '**/APITOKENS.xml'
        xpath: '/APITOKEN/GET_CUSTOMER/TOKEN[@APPLICATION_NAME="APPORTEUR_AFFAIRE"]/@VALUE'
        variable: 'TOKEN_GET_CUSTOMER_APPORTEUR_AFFAIRE'
      - file: '**/APITOKENS.xml'
        xpath: '/APITOKEN/GET_CUSTOMER/TOKEN[@APPLICATION_NAME="AMS"]/@VALUE'
        variable: 'TOKEN_GET_CUSTOMER_AMS'
      - file: '**/APITOKENS.xml'
        xpath: '/APITOKEN/GET_CUSTOMER/TOKEN[@APPLICATION_NAME="FRESH_ACCOUNT"]/@VALUE'
        variable: 'TOKEN_GET_CUSTOMER_FRESH_ACCOUNT'
      - file: '**/APITOKENS.xml'
        xpath: '/APITOKEN/GET_CUSTOMER/TOKEN[@APPLICATION_NAME="APPORTEUR_AFFAIRE"]/@HAVE_ACCESS_TO_GET_AVAILABLE_VARIABLES'
        variable: 'TOKEN_GET_CUSTOMER_APPORTEUR_AFFAIRE_HAVE_ACCESS_TO_GET_AVAILABLE_VARIABLES'
      - file: '**/APITOKENS.xml'
        xpath: '/APITOKEN/GET_COMPANY/TOKEN[@APPLICATION_NAME="APPORTEUR_AFFAIRE"]/@VALUE'
        variable: 'TOKEN_GET_COMPANY_APPORTEUR_AFFAIRE'
      - file: '**/APITOKENS.xml'
        xpath: '/APITOKEN/GET_T24USER/TOKEN[@APPLICATION_NAME="AMS"]/@VALUE'
        variable: 'TOKEN_GET_T24USER_AMS'
      - file: '**/APITOKENS.xml'
        xpath: '/APITOKEN/LDAP/TOKEN[@APPLICATION_NAME="PSS"]/@VALUE'
        variable: 'TOKEN_LDAP_PSS'
      - file: '**/APITOKENS.xml'
        xpath: '/APITOKEN/GET_PRODUCT/TOKEN[@APPLICATION_NAME="FRESH_ACCOUNT"]/@VALUE'
        variable: 'TOKEN_GET_PRODUCT_FRESH_ACCOUNT'
      enableHealthCheck: true
      healthCheckUrl: 'http://10.0.40.41:8046/api/Host/GetIndividualCustomerRange?fromCustomerId=1&toCustomerId=1'
      healthCheckExpectedStatusCode: '200'
      healthCheckRetries: 6
      healthCheckDelaySeconds: 10
      enableRollbackOnHealthCheckFailure: true
      enableLocalBackup: true
      backupRoot: 'C:\DeployBackups'
      backupPath: 'C:\DeployBackups\SIT\DataGateway\API\$(Build.BuildId)'

- stage: Tag_API_LKG_SIT
  displayName: 'Tag successful API build as LKG'
  dependsOn:
  - Resolve_Selected_Build
  - Deploy_API_SIT
  condition: and(succeeded('Deploy_API_SIT'), eq('${{ parameters.deployApi }}', 'true'))
  variables:
    ApiBuildId: $[ stageDependencies.Resolve_Selected_Build.ResolveBuildNumber.outputs['Resolve.ApiBuildId'] ]
    ApiPipelineDefinitionId: $[ stageDependencies.Resolve_Selected_Build.ResolveBuildNumber.outputs['Resolve.ApiPipelineDefinitionId'] ]
  jobs:
  - job: TagApiBuild
    displayName: 'Tag API build'
    pool:
      name: 'Deployment Pool'
      demands:
      - Agent.Name -equals SIT-ALTERNA-BN1
    steps:
    - checkout: none

    - template: pipelines/tag-builds.yml@templates
      parameters:
        tagTargets:
        - name: 'DataGateway API'
          buildId: '$(ApiBuildId)'
          definitionId: '$(ApiPipelineDefinitionId)'
          deployedTag: 'DEPLOYED-SIT-DATAGATEWAY-API'
          lkgTag: 'LKG-SIT-DATAGATEWAY-API'
