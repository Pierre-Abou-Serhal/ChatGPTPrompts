stages:
- stage: Deploy_SIT
  jobs:
  - template: pipelines/templates/deploy-windows-service.yml
    parameters:
      jobName: Deploy_MyWorker_SIT
      jobDisplayName: 'Deploy Worker (SIT)'
      deployPool: 'Build Pool'
      deployAgentName: 'UAT-ALTERNA-DK1'
      artifactName: 'drop'
      zipName: 'Worker.zip'
      installDir: 'C:\Apps\Workers\MyWorker'
      serviceName: 'MyWorkerService'
      serviceDisplayName: 'My Worker Service'
      exeRelativePath: 'MyWorker.exe'
      serviceArgs: '--environment SIT'
      #serviceUser: 'DOMAIN\svc_myworker'
      #servicePassword: '$(svc_myworker_password)'   # secret variable
