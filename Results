Perfect. The **next YAML file** is:

**`SIT - RELEASE - AlternaCardManagement.yml`**

Because now that MVC and API have their own build pipelines, the release pipeline must be changed to:

* accept **build numbers** for MVC / API / DB
* resolve them to internal **build IDs**
* deploy **API first**, then **MVC**
* ask for **app approval only once**
* deploy **DB last**
* trigger **rollback and stop**
* tag the successfully deployed builds as LKG

---

## Important before you paste this YAML

There are **2 environment assumptions** in this design:

* `SIT` → approval for the application deployment
* `SIT-DB` → approval for DB deployment only

That is how you get:

* one approval for app deployment
* DBA approval only when DB is selected

Also, replace these 3 variables with your real pipeline IDs:

* `mvcPipelineDefinitionId`
* `apiPipelineDefinitionId`
* `dbPipelineDefinitionId`

---

# New `SIT - RELEASE - AlternaCardManagement.yml`

```yaml
name: ACM_REL_SIT_$(Date:yyyyMMdd).$(Rev:r)

parameters:
- name: deployDatabase
  type: boolean
  default: false

- name: deployMvc
  type: boolean
  default: false

- name: deployApi
  type: boolean
  default: false

- name: mvcBuildNumber
  type: string
  default: ''

- name: apiBuildNumber
  type: string
  default: ''

- name: dbBuildNumber
  type: string
  default: ''

resources:
  repositories:
  - repository: templates
    type: git
    name: 'Azure Templates/Azure Templates'
    ref: refs/heads/main

trigger: none
pr: none

variables:
- group: SIT_API_VARIABLE_GROUP

# Replace these with the real Azure DevOps pipeline definition IDs
- name: mvcPipelineDefinitionId
  value: 'REPLACE_WITH_MVC_BUILD_PIPELINE_ID'

- name: apiPipelineDefinitionId
  value: 'REPLACE_WITH_API_BUILD_PIPELINE_ID'

- name: dbPipelineDefinitionId
  value: 'REPLACE_WITH_DB_BUILD_PIPELINE_ID'

stages:

# ============================================================
# 1) Resolve readable build numbers to internal build IDs
# ============================================================
- stage: Resolve_Selected_Builds
  displayName: 'Resolve selected build numbers'
  jobs:
  - job: ResolveBuildNumbers
    displayName: 'Resolve MVC / API / DB build numbers'
    pool:
      name: 'Deployment Pool'
      demands:
      - Agent.Name -equals SIT-ALTERNA-BN1
    steps:
    - checkout: none

    - powershell: |
        $ErrorActionPreference = 'Stop'

        $collectionUri = "$(System.CollectionUri)".TrimEnd('/')
        $projectName   = [System.Uri]::EscapeDataString("$(System.TeamProject)")
        $apiVersion    = "7.1"

        $headers = @{
          Authorization = "Bearer $env:SYSTEM_ACCESSTOKEN"
        }

        $deployMvc = "${{ parameters.deployMvc }}".ToLower() -eq "true"
        $deployApi = "${{ parameters.deployApi }}".ToLower() -eq "true"
        $deployDb  = "${{ parameters.deployDatabase }}".ToLower() -eq "true"

        if (-not ($deployMvc -or $deployApi -or $deployDb)) {
          throw "At least one deployment target must be selected: MVC, API, or Database."
        }

        function Resolve-Build {
          param(
            [string]$Label,
            [string]$DefinitionId,
            [string]$BuildNumber
          )

          if ([string]::IsNullOrWhiteSpace($DefinitionId)) {
            throw "$Label pipeline definition ID is empty."
          }

          if ([string]::IsNullOrWhiteSpace($BuildNumber)) {
            throw "$Label build number is required because deployment of $Label was selected."
          }

          $encodedBuildNumber = [System.Uri]::EscapeDataString($BuildNumber)

          $uri = "{0}/{1}/_apis/build/builds?definitions={2}&buildNumber={3}&statusFilter=completed&resultFilter=succeeded&`$top=1&queryOrder=finishTimeDescending&api-version={4}" -f `
            $collectionUri,
            $projectName,
            $DefinitionId,
            $encodedBuildNumber,
            $apiVersion

          Write-Host "Resolving $Label build number [$BuildNumber] using pipeline definition [$DefinitionId]"
          $response = Invoke-RestMethod -Method Get -Uri $uri -Headers $headers

          if (-not $response.value -or $response.count -lt 1) {
            throw "No succeeded build found for $Label with build number [$BuildNumber] in pipeline definition [$DefinitionId]."
          }

          $build = $response.value[0]

          Write-Host "$Label resolved:"
          Write-Host "  Build ID     = $($build.id)"
          Write-Host "  Build Number = $($build.buildNumber)"
          Write-Host "  Branch       = $($build.sourceBranch)"

          Write-Host "##vso[task.setvariable variable=${Label}BuildId;isOutput=true]$($build.id)"
          Write-Host "##vso[task.setvariable variable=${Label}ResolvedBuildNumber;isOutput=true]$($build.buildNumber)"
        }

        if ($deployMvc) {
          Resolve-Build -Label "Mvc" -DefinitionId "$(mvcPipelineDefinitionId)" -BuildNumber "${{ parameters.mvcBuildNumber }}"
        } else {
          Write-Host "##vso[task.setvariable variable=MvcBuildId;isOutput=true]"
          Write-Host "##vso[task.setvariable variable=MvcResolvedBuildNumber;isOutput=true]"
        }

        if ($deployApi) {
          Resolve-Build -Label "Api" -DefinitionId "$(apiPipelineDefinitionId)" -BuildNumber "${{ parameters.apiBuildNumber }}"
        } else {
          Write-Host "##vso[task.setvariable variable=ApiBuildId;isOutput=true]"
          Write-Host "##vso[task.setvariable variable=ApiResolvedBuildNumber;isOutput=true]"
        }

        if ($deployDb) {
          Resolve-Build -Label "Db" -DefinitionId "$(dbPipelineDefinitionId)" -BuildNumber "${{ parameters.dbBuildNumber }}"
        } else {
          Write-Host "##vso[task.setvariable variable=DbBuildId;isOutput=true]"
          Write-Host "##vso[task.setvariable variable=DbResolvedBuildNumber;isOutput=true]"
        }
      name: Resolve
      displayName: 'Resolve selected build numbers to build IDs'
      env:
        SYSTEM_ACCESSTOKEN: $(System.AccessToken)

# ============================================================
# 2) Deploy applications in one stage
#    - one approval on environment SIT
#    - API first
#    - MVC second
# ============================================================
- stage: Deploy_Applications_SIT
  displayName: 'Deploy applications to SIT'
  dependsOn:
  - Resolve_Selected_Builds
  condition: or(eq('${{ parameters.deployApi }}', 'true'), eq('${{ parameters.deployMvc }}', 'true'))
  variables:
    ApiBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.ApiBuildId'] ]
    ApiResolvedBuildNumber: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.ApiResolvedBuildNumber'] ]
    MvcBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.MvcBuildId'] ]
    MvcResolvedBuildNumber: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.MvcResolvedBuildNumber'] ]
  jobs:

  # ---------------- API first ----------------
  - ${{ if eq(parameters.deployApi, true) }}:
    - template: pipelines/deploy-iis.yml@templates
      parameters:
        deploymentName: 'DeployAPI'
        deploymentDisplayName: 'Deploy API to SIT (IIS)'
        environmentName: 'SIT'
        deployPool: 'Deployment Pool'
        deployAgentName: 'SIT-ALTERNA-BN1'
        variableGroup: 'SIT_API_VARIABLE_GROUP'
        componentName: 'API'
        artifactName: 'api-drop'
        artifactBuildType: 'specific'
        artifactProject: '$(System.TeamProject)'
        artifactDefinitionId: '$(apiPipelineDefinitionId)'
        artifactBuildId: '$(ApiBuildId)'
        artifactBranch: 'refs/heads/sit'
        zipName: 'AlternaCardManagementAPI.zip'
        siteName: 'AlternaCardManagement-AzureDevOps'
        appPoolName: 'AlternaCardManagement-AzureDevOps'
        iisTargetPath: 'C:\inetpub\wwwroot\AlternaCardManagement-AzureDevOps-BN1'
        cleanTargetBeforeCopy: true
        cleanExcludeCsv: ''
        enableJsonTransform: false
        jsonFiles: ''
        enableXmlConfigTransform: true
        xmlConfigFiles:
          - '**/*.config'
        xmlVariableValues:
          BaseUrl: $(BaseUrl)
          BrefBaseUrl: $(BrefBaseUrl)
          CONN_STRING: $(CONN_STRING)
          SMSUrl: $(SMSUrl)
        enableCustomXmlEdits: false
        customXmlEdits: []
        enableHealthCheck: true
        healthCheckUrl: 'http://10.0.40.41:8046/api/Host/GetIndividualCustomerRange?fromCustomerId=1&toCustomerId=1'
        healthCheckExpectedStatusCode: '200'
        healthCheckRetries: 6
        healthCheckDelaySeconds: 10
        enableRollbackOnHealthCheckFailure: true
        enableLocalBackup: true
        backupRoot: 'C:\DeployBackups'
        backupPath: 'C:\DeployBackups\SIT\API\$(Build.BuildId)'
        orchestratedRollback: ${{ parameters.deployMvc }}
        rollbackTag: 'LKG-SIT-API'
        tagSuccessfulBuild: false

  # ---------------- MVC second ----------------
  - ${{ if eq(parameters.deployMvc, true) }}:
    - template: pipelines/deploy-iis.yml@templates
      parameters:
        deploymentName: 'DeployMVC'
        deploymentDisplayName: 'Deploy MVC to SIT (IIS)'
        environmentName: 'SIT'
        deployPool: 'Deployment Pool'
        deployAgentName: 'SIT-ALTERNA-FN1'
        variableGroup: 'SIT_MVC_VARIABLE_GROUP'
        componentName: 'MVC'
        artifactName: 'mvc-drop'
        artifactBuildType: 'specific'
        artifactProject: '$(System.TeamProject)'
        artifactDefinitionId: '$(mvcPipelineDefinitionId)'
        artifactBuildId: '$(MvcBuildId)'
        artifactBranch: 'refs/heads/sit'
        zipName: 'AlternaCardManagementMVC.zip'
        siteName: 'AlternaCardManagement-AzureDevOps'
        appPoolName: 'AlternaCardManagement-AzureDevOps'
        iisTargetPath: 'C:\inetpub\wwwroot\AlternaCardManagement-AzureDevOps-FN1'
        cleanTargetBeforeCopy: true
        cleanExcludeCsv: ''
        enableJsonTransform: false
        jsonFiles: ''
        enableXmlConfigTransform: true
        xmlConfigFiles:
          - '**/Web.config'
        xmlVariableValues:
          BaseUrl: $(BaseUrl)
          BaseUrlOsb: $(BaseUrlOsb)
          CDN_IP_LINK: $(CDN_IP_LINK)
          DASHBOARD_LINK: $(DASHBOARD_LINK)
          GenerateAccountFileImportFileNameChecking: $(GenerateAccountFileImportFileNameChecking)
          GeneratePaymentFileImportFileNameChecking: $(GeneratePaymentFileImportFileNameChecking)
          LDAP_WEB_SERVICES_IP_ADDRESS: $(LDAP_WEB_SERVICES_IP_ADDRESS)
          UploadFilesPath: $(UploadFilesPath)
          USER_GUIDE_LINK: $(USER_GUIDE_LINK)
        enableCustomXmlEdits: false
        customXmlEdits: []
        enableHealthCheck: true
        healthCheckUrl: 'http://10.0.40.41:8046/'
        healthCheckExpectedStatusCode: '200'
        healthCheckRetries: 6
        healthCheckDelaySeconds: 10
        enableRollbackOnHealthCheckFailure: true
        enableLocalBackup: true
        backupRoot: 'C:\DeployBackups'
        backupPath: 'C:\DeployBackups\SIT\MVC\$(Build.BuildId)'
        orchestratedRollback: ${{ parameters.deployApi }}
        rollbackTag: 'LKG-SIT-MVC'
        tagSuccessfulBuild: false

# ============================================================
# 3) Rollback when API fails
#    - if API alone fails -> rollback API
#    - if API fails before MVC -> rollback API and stop
# ============================================================
- ${{ if eq(parameters.deployApi, true) }}:
  - stage: Rollback_API_SIT
    displayName: 'Rollback API'
    dependsOn:
    - Deploy_Applications_SIT
    condition: and(always(), eq(stageDependencies.Deploy_Applications_SIT.DeployAPI.result, 'Failed'))
    jobs:
    - template: pipelines/rollback-iis.yml@templates
      parameters:
        deploymentName: 'RollbackAPI'
        deploymentDisplayName: 'Rollback API from local backup'
        environmentName: 'SIT'
        deployPool: 'Deployment Pool'
        deployAgentName: 'SIT-ALTERNA-BN1'
        siteName: 'AlternaCardManagement-AzureDevOps'
        appPoolName: 'AlternaCardManagement-AzureDevOps'
        iisTargetPath: 'C:\inetpub\wwwroot\AlternaCardManagement-AzureDevOps-BN1'
        backupPath: 'C:\DeployBackups\SIT\API\$(Build.BuildId)'
        cleanExcludeCsv: ''

# ============================================================
# 4) Rollback MVC when MVC fails
# ============================================================
- ${{ if eq(parameters.deployMvc, true) }}:
  - stage: Rollback_MVC_SIT
    displayName: 'Rollback MVC'
    dependsOn:
    - Deploy_Applications_SIT
    condition: and(always(), eq(stageDependencies.Deploy_Applications_SIT.DeployMVC.result, 'Failed'))
    jobs:
    - template: pipelines/rollback-iis.yml@templates
      parameters:
        deploymentName: 'RollbackMVC'
        deploymentDisplayName: 'Rollback MVC from local backup'
        environmentName: 'SIT'
        deployPool: 'Deployment Pool'
        deployAgentName: 'SIT-ALTERNA-FN1'
        siteName: 'AlternaCardManagement-AzureDevOps'
        appPoolName: 'AlternaCardManagement-AzureDevOps'
        iisTargetPath: 'C:\inetpub\wwwroot\AlternaCardManagement-AzureDevOps-FN1'
        backupPath: 'C:\DeployBackups\SIT\MVC\$(Build.BuildId)'
        cleanExcludeCsv: ''

# ============================================================
# 5) If API succeeded but MVC failed, rollback API too
# ============================================================
- ${{ if and(eq(parameters.deployApi, true), eq(parameters.deployMvc, true)) }}:
  - stage: Rollback_API_After_MVC_Failure_SIT
    displayName: 'Rollback API because MVC failed'
    dependsOn:
    - Rollback_MVC_SIT
    - Deploy_Applications_SIT
    condition: and(
      always(),
      eq(stageDependencies.Deploy_Applications_SIT.DeployAPI.result, 'Succeeded'),
      eq(stageDependencies.Deploy_Applications_SIT.DeployMVC.result, 'Failed')
      )
    jobs:
    - template: pipelines/rollback-iis.yml@templates
      parameters:
        deploymentName: 'RollbackAPIAfterMVCFailure'
        deploymentDisplayName: 'Rollback API from local backup because MVC failed'
        environmentName: 'SIT'
        deployPool: 'Deployment Pool'
        deployAgentName: 'SIT-ALTERNA-BN1'
        siteName: 'AlternaCardManagement-AzureDevOps'
        appPoolName: 'AlternaCardManagement-AzureDevOps'
        iisTargetPath: 'C:\inetpub\wwwroot\AlternaCardManagement-AzureDevOps-BN1'
        backupPath: 'C:\DeployBackups\SIT\API\$(Build.BuildId)'
        cleanExcludeCsv: ''

# ============================================================
# 6) Tag successful application builds as LKG
# ============================================================
- stage: Tag_APP_LKG_SIT
  displayName: 'Tag successful application builds as LKG'
  dependsOn:
  - Resolve_Selected_Builds
  - Deploy_Applications_SIT
  condition: and(
    or(eq('${{ parameters.deployApi }}', 'true'), eq('${{ parameters.deployMvc }}', 'true')),
    succeeded('Deploy_Applications_SIT')
    )
  variables:
    ApiBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.ApiBuildId'] ]
    MvcBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.MvcBuildId'] ]
  jobs:
  - job: TagApplicationBuilds
    displayName: 'Tag MVC / API builds'
    pool:
      name: 'Deployment Pool'
      demands:
      - Agent.Name -equals SIT-ALTERNA-BN1
    steps:
    - checkout: none

    - powershell: |
        $ErrorActionPreference = "Stop"

        $collectionUri = "$(System.CollectionUri)".TrimEnd('/')
        $projectName   = [System.Uri]::EscapeDataString("$(System.TeamProject)")
        $apiVersion    = "7.1"

        $headers = @{
          Authorization = "Bearer $env:SYSTEM_ACCESSTOKEN"
        }

        function Add-BuildTag {
          param(
            [string]$BuildId,
            [string]$Tag
          )

          if ([string]::IsNullOrWhiteSpace($BuildId)) {
            return
          }

          $tagEscaped = [System.Uri]::EscapeDataString($Tag)
          $uri = "{0}/{1}/_apis/build/builds/{2}/tags/{3}?api-version={4}" -f `
            $collectionUri,
            $projectName,
            $BuildId,
            $tagEscaped,
            $apiVersion

          Write-Host "Tagging build [$BuildId] with [$Tag]"
          Invoke-RestMethod -Method Put -Uri $uri -Headers $headers | Out-Null
        }

        if ("${{ parameters.deployApi }}" -eq "true") {
          Add-BuildTag -BuildId "$(ApiBuildId)" -Tag "LKG-SIT-API"
          Add-BuildTag -BuildId "$(ApiBuildId)" -Tag "DEPLOYED-SIT-API"
        }

        if ("${{ parameters.deployMvc }}" -eq "true") {
          Add-BuildTag -BuildId "$(MvcBuildId)" -Tag "LKG-SIT-MVC"
          Add-BuildTag -BuildId "$(MvcBuildId)" -Tag "DEPLOYED-SIT-MVC"
        }
      displayName: 'Tag deployed application builds'
      env:
        SYSTEM_ACCESSTOKEN: $(System.AccessToken)

# ============================================================
# 7) Deploy DB last
#    IMPORTANT:
#    This stage becomes fully usable after deploy-database.yml
#    is updated to accept artifactBuildId.
# ============================================================
- stage: Deploy_DB_SIT
  displayName: 'Deploy DB to SIT'
  dependsOn:
  - Resolve_Selected_Builds
  - Deploy_Applications_SIT
  - Tag_APP_LKG_SIT
  condition: and(
    eq('${{ parameters.deployDatabase }}', 'true'),
    in(dependencies.Deploy_Applications_SIT.result, 'Succeeded', 'Skipped'),
    in(dependencies.Tag_APP_LKG_SIT.result, 'Succeeded', 'Skipped')
    )
  variables:
    DbBuildId: $[ stageDependencies.Resolve_Selected_Builds.ResolveBuildNumbers.outputs['Resolve.DbBuildId'] ]
  jobs:
  - template: pipelines/deploy-database.yml@templates
    parameters:
      deploymentName: 'DeployDb'
      deploymentDisplayName: 'Deploy database'
      environmentName: 'SIT-DB'
      deployPool: 'Deployment Pool'
      deployAgentName: 'SIT-ALTERNA-BN1'
      artifactName: 'db-drop'
      artifactBuildType: 'specific'
      artifactProject: '$(System.TeamProject)'
      artifactDefinitionId: '$(dbPipelineDefinitionId)'
      artifactBranch: 'refs/heads/sit'
      targetConnectionString: '$(CONN_STRING)'
```

