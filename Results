        public static (String, String) Init(String Ticket)
        {
            String user;
            List<String> Role = [];
            String Company;
            String Departement;
            String Email;
            String FullName;
            List<String> Activities = [];

            Byte[] SessionBytes = Convert.FromBase64String(Ticket);
            String DecodedUser = Encoding.UTF8.GetString(SessionBytes);
            user = DecodedUser.Split('|')[0];
            GetUserCollection getUserCollection = new(user, "", user);

            String User = GeneralCall(getUserCollection, $"{Ldap}/api/ActiveDirectoryHost/GetUserCollection");
            JToken GetUserInfo = JObject.Parse(User)["UserInfo"]!;
            Email = GetUserInfo["Email"]!.ToString();
            Departement = GetUserInfo["Department"]!.ToString();
            FullName = GetUserInfo["FullName"]!.ToString();
            GetUserByEmail getUserByEmail = new(user, "", Email);
            String Branches = GeneralCall(getUserByEmail, $"{Bref}/api/Authorization/GetUserBranchesByEmail");
            JToken BranchesData = JObject.Parse(Branches)["Branches"]!;
            StringBuilder branchesString = new();
            foreach (JToken Data in BranchesData)
            {
                if (Data["AccessAllowedInT24"]!.ToString().ToLower() == "true" ||
                    Data["AccessAllowedInModule"]!.ToString().ToLower() == "true")
                {
                    branchesString.Append(Data["BranchCode"] + ",");
                }
            }

            if (branchesString.Length != 0)
            {
                branchesString.Remove(branchesString.Length - 1, 1);
            }

            Company = branchesString.ToString();

            GetRoleWithActivities getRoleWithActivities = new(user, Company);
            String RoleByUserName = GeneralCall(getRoleWithActivities, $"{OSB}/Rest/Authorization/RoleByUserName");
            JToken RoleByUserNameObject = JObject.Parse(RoleByUserName)["userRoles"]!;
            RoleByUserNameObject = RoleByUserNameObject["userRole"]!;

            foreach (JToken Data in RoleByUserNameObject)
            {
                if (!Role.Contains(Data["roleCode"]!.ToString()))
                {
                    Role.Add(Data["roleCode"]!.ToString());
                }
            }

            String RoleWithActivitiesByModuleName = GeneralCall(getRoleWithActivities,
                $"{OSB}/Rest/Authorization/RoleWithActivitiesByModuleName");
            JToken RoleWithActivitiesByModuleNameObject =
                JObject.Parse(RoleWithActivitiesByModuleName)["roleActivities"]!;
            RoleWithActivitiesByModuleNameObject = RoleWithActivitiesByModuleNameObject["roleActivity"]!;

            foreach (JToken Data in RoleWithActivitiesByModuleNameObject)
            {
                if (Role.Contains(Data["roleCode"]!.ToString()))
                {
                    Activities.Add(Data["actionName"]!.ToString());
                }
            }

            Dictionary<String, Object> dict = new()
            {
                ["Ticket"] = Ticket,
                ["user"] = user,
                ["Role"] = Role,
                ["Activities"] = Activities,
                ["Company"] = Company,
                ["Departement"] = Departement,
                ["Email"] = Email,
                ["Exp"] = DateTimeOffset.UtcNow.ToUnixTimeSeconds() + (TTL * 60),
                ["FullName"] = FullName
            };

            return (GenerateSetionVariable(dict), FullName);
        }

        public static String EncryptString(String plainText)
        {
            String key = "(╯°□°）╯︵ ┻━┻";
            Byte[] iv = new Byte[16];
            Byte[] array;

            using (Aes aes = Aes.Create())
            {
                aes.Key = Encoding.Unicode.GetBytes(key);
                aes.IV = iv;

                ICryptoTransform encryptor = aes.CreateEncryptor(aes.Key, aes.IV);

                using (MemoryStream memoryStream = new())
                {
                    using (CryptoStream cryptoStream = new(memoryStream, encryptor, CryptoStreamMode.Write))
                    {
                        using (StreamWriter streamWriter = new(cryptoStream))
                        {
                            streamWriter.Write(plainText);
                        }

                        array = memoryStream.ToArray();
                    }
                }
            }

            return Convert.ToBase64String(array);
        }

        public static String DecryptString(String cipherText)
        {
            String key = "(╯°□°）╯︵ ┻━┻";
            Byte[] iv = new Byte[16];
            Byte[] buffer = Convert.FromBase64String(cipherText);

            using (Aes aes = Aes.Create())
            {
                aes.Key = Encoding.Unicode.GetBytes(key);
                aes.IV = iv;
                ICryptoTransform decryptor = aes.CreateDecryptor(aes.Key, aes.IV);

                using (MemoryStream memoryStream = new(buffer))
                {
                    using (CryptoStream cryptoStream = new(memoryStream, decryptor, CryptoStreamMode.Read))
                    {
                        using (StreamReader streamReader = new(cryptoStream))
                        {
                            return streamReader.ReadToEnd();
                        }
                    }
                }
            }
        }

        public static String GenerateSetionVariable(Dictionary<String, Object> variables)
        {
            StringBuilder sb = new();
            foreach (KeyValuePair<String, Object> Variable in variables)
            {
                sb.Append(Variable.Key);
                sb.Append("[==]");
                sb.Append(JsonConvert.SerializeObject(Variable.Value));
                sb.Append("ᓚᘏᗢ");
            }

            if (sb.Length != 0)
            {
                sb.Remove(sb.Length - 3, 3);
            }
            
            return CompressString(EncryptString(sb.ToString()));
        }
        public static string CompressString(string uncompressedString)
        {
          if (string.IsNullOrEmpty(uncompressedString))
            return uncompressedString;

          byte[] buffer = Encoding.UTF8.GetBytes(uncompressedString);

          using (var memoryStream = new MemoryStream())
          {
            // Use optimal compression level for best size reduction
            using (var gZipStream = new GZipStream(memoryStream, CompressionLevel.Optimal))
            {
              gZipStream.Write(buffer, 0, buffer.Length);
            }

            return Convert.ToBase64String(memoryStream.ToArray());
          }
        }

        public static string DecompressString(string compressedString)
        {
          if (string.IsNullOrEmpty(compressedString))
            return compressedString;

          byte[] gZipBuffer = Convert.FromBase64String(compressedString);

          using (var memoryStream = new MemoryStream(gZipBuffer))
          using (var gZipStream = new GZipStream(memoryStream, CompressionMode.Decompress))
          using (var outputStream = new MemoryStream())
          {
            gZipStream.CopyTo(outputStream);
            return Encoding.UTF8.GetString(outputStream.ToArray());
          }
        }

    public static Dictionary<String, Object> GenerateVariables(HttpContext Context, String Session)
        {

            Dictionary<String, Object> RetDict = [];
            Session = DecompressString(Session);
            Session = DecryptString(Session);

            String[] Items = Session.Split(new String[] { "ᓚᘏᗢ" }, StringSplitOptions.RemoveEmptyEntries);

            foreach (String Item in Items)
            {
                String[] Data = Item.Split(new String[] { "[==]" }, StringSplitOptions.RemoveEmptyEntries);
                RetDict[Data[0]] = JsonConvert.DeserializeObject(Data[1])!;
            }

            Int64 exp = -1;
            if (RetDict.TryGetValue("Exp", out var value))
            {
                exp = (Int64)value;
            }

            if (exp < DateTimeOffset.UtcNow.ToUnixTimeSeconds())
            {
                throw new Exception("Session expired");
            }

            RetDict["Exp"] = DateTimeOffset.UtcNow.ToUnixTimeSeconds() + (TTL * 60);
            String FN = "Invalid User";
            if (RetDict.TryGetValue("FullName", out var value2))
            {
                FN = value2.ToString() ?? "Invalid User";
            }

            Context.Response.Cookies.Append("ArchiveData", GenerateSetionVariable(RetDict));
            Context.Session.SetString("ArchiveData", GenerateSetionVariable(RetDict));
            Context.Session.SetString("User", FN);
            Context.Response.Headers["Origin"] = Context.Request.Headers.Origin;
            return RetDict;
        }

