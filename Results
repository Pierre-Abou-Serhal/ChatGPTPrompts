  branches:
    include:
    - sit
  paths:
    include:
    - DatabaseProjectAlterna.CardManagement/**

pr: none

variables:
- group: SIT_API_VARIABLE_GROUP
- group: OWASP_SECRETS

stages:
- stage: Build_DB
  displayName: 'Build DB'
  jobs:
  - template: pipelines/build-database-project.yml@templates
    parameters:
      jobName: 'BuildDb'
      jobDisplayName: 'Build database project'
      buildPool: 'Build Pool'
      buildAgentName: 'UAT-ALTERNA-DK1'
      sqlProjectPath: 'DatabaseProjectAlterna.CardManagement/DatabaseProjectAlterna.CardManagement.sqlproj'
      artifactName: 'card-management-db-drop'
      previewConnectionString: '$(CONN_STRING)'

      runDependencyCheck: ${{ parameters.runDependencyCheck }}
      dependencyCheckProjectName: 'AlternaCardManagement-DB'
      dependencyCheckCliPath: 'C:\Tools\dependency-check\dependency-check-12.2.0\bin\dependency-check.bat'
      dependencyCheckDataPath: 'C:\Tools\dependency-check-data'
